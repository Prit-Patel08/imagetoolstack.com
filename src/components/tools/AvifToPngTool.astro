---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="avif-converter-root" class="w-full flex flex-col items-center">
  <div class="w-full max-w-2xl bg-green-50 border border-green-200 rounded-lg p-4 mb-6 text-center shadow-sm">
    <p class="text-green-800 text-sm font-medium">100% Private: Your images never leave your computer. Converted locally in your browser.</p>
  </div>

  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 hover:border-link transition-colors cursor-pointer group">
    <div class="mb-4 h-16 w-16 rounded-full bg-canvas flex items-center justify-center text-link border border-hairline group-hover:border-link transition-colors shadow-sm">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
    </div>
    <div class="text-center">
      <p class="text-xl font-bold text-ink mb-2">Drag & Drop AVIF Images Here</p>
      <p class="text-sm text-body">Or click to browse your files.</p>
      <p class="text-xs text-mute mt-4 bg-canvas-soft inline-block px-3 py-1 rounded-full border border-hairline">Supported: AVIF</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="image/avif" multiple />
  </div>

  <!-- Processing State -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center gap-6 py-12">
    <div class="w-full max-w-md bg-canvas border border-hairline rounded-xl p-8 shadow-sm text-center">
      <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-blue-50 text-link">
        <svg class="h-8 w-8 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-ink mb-2">Converting Images</h3>
      <p id="progress-text" class="text-sm text-body mb-6">Processing...</p>
      
      <div class="w-full bg-canvas-soft rounded-full h-3 border border-hairline overflow-hidden shadow-inner">
        <div id="progress-bar" class="bg-link h-3 rounded-full transition-all duration-300 relative overflow-hidden" style="width: 0%">
          <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Result State -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-12">
    <div class="h-20 w-20 bg-green-50 border-2 border-green-200 text-green-500 rounded-full flex items-center justify-center mb-2 shadow-sm">
      <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <div class="text-center">
      <h3 class="text-2xl font-bold text-ink">Conversion Complete!</h3>
      <p id="result-summary" class="text-base text-body mt-2">Your AVIF files have been converted to PNG.</p>
    </div>
    
    <div class="flex flex-col items-center gap-4 mt-6 w-full max-w-sm">
      <a id="download-btn" class="w-full btn-primary text-center cursor-pointer text-lg py-4 shadow-md flex items-center justify-center gap-2">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Download Converted Files
      </a>
      <button id="reset-btn" class="text-sm font-medium text-mute hover:text-ink hover:underline transition-colors mt-2">Convert more files</button>
    </div>
  </div>
</div>

<script>
  import JSZip from 'jszip';

  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    const resultSummary = document.getElementById('result-summary');
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');

    if (!dropZone || !fileInput) return;

    // --- Drag and Drop Logic ---
    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault(); e.stopPropagation();
      }, false);
    });
    
    dropZone.addEventListener('dragenter', () => dropZone.classList.add('border-link', 'bg-blue-50/50'));
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-link', 'bg-blue-50/50'));
    dropZone.addEventListener('drop', (e) => {
      dropZone.classList.remove('border-link', 'bg-blue-50/50');
      const files = e.dataTransfer?.files;
      if (files?.length) processFiles(Array.from(files));
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.length) processFiles(Array.from(fileInput.files));
      fileInput.value = '';
    });

    async function processFiles(files: File[]) {
      const validFiles = files.filter(f => f.name.toLowerCase().endsWith('.avif') || f.type === 'image/avif');
      
      if (validFiles.length === 0) {
        alert("Please select valid AVIF files.");
        return;
      }

      showState('processing');
      const total = validFiles.length;
      let completed = 0;
      updateProgress(0, total);

      const zip = new JSZip();
      let singleBlob: Blob | null = null;
      let singleFilename = "";

      for (const file of validFiles) {
        try {
          // Natively decode AVIF using browser's createImageBitmap
          const bitmap = await createImageBitmap(file);
          const canvas = new OffscreenCanvas(bitmap.width, bitmap.height);
          const ctx = canvas.getContext('2d');
          
          if (!ctx) throw new Error("Could not get 2D context");
          ctx.drawImage(bitmap, 0, 0);

          const pngBlob = await canvas.convertToBlob({ type: 'image/png' });
          const baseName = file.name.replace(/\.[^/.]+$/, "");
          
          if (total === 1) {
            singleBlob = pngBlob;
            singleFilename = `${baseName}.png`;
          } else {
            zip.file(`${baseName}.png`, pngBlob);
          }
        } catch (error) {
          console.error(`Failed to convert ${file.name}:`, error);
        }

        completed++;
        updateProgress(completed, total);
      }

      progressText!.textContent = "Finalizing download...";

      if (total === 1 && singleBlob) {
        const url = URL.createObjectURL(singleBlob);
        downloadBtn.href = url;
        downloadBtn.download = singleFilename;
        downloadBtn.textContent = "Download PNG Image";
      } else {
        const zipContent = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(zipContent);
        downloadBtn.href = url;
        downloadBtn.download = `imagetoolstack-avif-converted-${Date.now()}.zip`;
        downloadBtn.innerHTML = `<svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Download ZIP Archive`;
      }

      resultSummary!.textContent = `Successfully converted ${completed} AVIF image${completed > 1 ? 's' : ''} to PNG.`;
      showState('result');
    }

    function updateProgress(current: number, total: number) {
      if (!progressBar || !progressText) return;
      const pct = Math.round((current / total) * 100);
      progressBar.style.width = `${pct}%`;
      progressText.textContent = `Converted ${current} of ${total} files...`;
    }

    resetBtn?.addEventListener('click', () => {
      showState('upload');
      if (progressBar) progressBar.style.width = '0%';
    });

    function showState(state: 'upload' | 'processing' | 'result') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }
  })();
</script>
