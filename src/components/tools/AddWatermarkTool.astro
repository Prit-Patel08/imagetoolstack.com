---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="watermark-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 transition-colors cursor-pointer group">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline group-hover:border-hairline-strong transition-colors">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 19v-8.93a2 2 0 01.89-1.664l7-4.666a2 2 0 012.22 0l7 4.666A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5m0 0l-1.14.76a2 2 0 01-2.22 0l-1.14-.76" /></svg>
    </div>
    <div class="text-center">
      <p class="text-base font-semibold text-ink">Select an image to watermark</p>
      <p class="mt-1 text-sm text-body">Supports JPG, PNG, and WebP.</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="image/jpeg,image/png,image/webp" />
  </div>

  <!-- Settings State -->
  <div id="settings-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    
    <!-- Image Preview -->
    <div class="w-full max-w-2xl bg-canvas-soft border border-hairline rounded-xl p-4 flex items-center justify-center overflow-hidden min-h-[300px] relative">
      <img id="image-preview" class="max-w-full max-h-[500px] object-contain shadow-sm" src="" alt="Preview" />
      <div id="watermark-preview" class="absolute text-white font-bold text-shadow pointer-events-none opacity-80" style="bottom: 10%; right: 10%;">© 2026 MyBrand</div>
    </div>

    <!-- Controls -->
    <div class="w-full max-w-2xl bg-canvas border border-hairline rounded-xl p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-ink mb-4 text-center">Watermark Settings</h3>
      
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-ink mb-2">Watermark Text</label>
          <input type="text" id="watermark-text" class="w-full bg-canvas-soft border border-hairline rounded px-3 py-2 text-sm text-ink outline-none focus:border-link" value="© 2026 MyBrand" placeholder="Enter your text">
        </div>

        <div>
          <label class="block text-sm font-medium text-ink mb-2">Position</label>
          <select id="watermark-pos" class="w-full bg-canvas-soft border border-hairline rounded px-3 py-2 text-sm text-ink outline-none focus:border-link">
            <option value="bottom-right">Bottom Right</option>
            <option value="bottom-left">Bottom Left</option>
            <option value="top-right">Top Right</option>
            <option value="top-left">Top Left</option>
            <option value="center">Center</option>
          </select>
        </div>
      </div>

      <div class="mt-8 flex gap-4">
        <button id="start-btn" class="flex-1 btn-primary">Apply & Download</button>
        <button id="cancel-btn" class="px-6 py-2 border border-hairline rounded text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft transition-colors">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Processing State -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center gap-6 py-12">
    <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
    <div class="w-full max-w-md text-center">
      <p class="text-sm font-mono text-mute uppercase tracking-widest">Stamping Image...</p>
    </div>
  </div>

  <!-- Result State -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-12">
    <div class="h-16 w-16 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <div class="text-center">
      <h3 class="text-xl font-bold text-ink">Watermark Applied!</h3>
      <p class="text-sm text-body mt-2">Your protected image is ready to download.</p>
    </div>
    
    <div class="flex flex-col items-center gap-4 mt-4 w-full max-w-xs">
      <a id="download-btn" class="w-full btn-primary text-center cursor-pointer">Download Image</a>
      <button id="reset-btn" class="text-sm font-medium text-link hover:underline">Watermark another image</button>
    </div>
  </div>
</div>

<style>
  .text-shadow {
    text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
  }
</style>

<script>
  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const settingsZone = document.getElementById('settings-zone');
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    
    const imagePreview = document.getElementById('image-preview') as HTMLImageElement;
    const watermarkPreview = document.getElementById('watermark-preview') as HTMLDivElement;
    const watermarkText = document.getElementById('watermark-text') as HTMLInputElement;
    const watermarkPos = document.getElementById('watermark-pos') as HTMLSelectElement;
    
    const startBtn = document.getElementById('start-btn');
    const cancelBtn = document.getElementById('cancel-btn');
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');

    let originalFile: File | null = null;
    let originalImage: HTMLImageElement | null = null;

    if (!dropZone || !fileInput) return;

    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault(); e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const file = e.dataTransfer?.files?.[0];
      if (file) handleFile(file);
    });

    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleFile(file);
    });

    watermarkText?.addEventListener('input', () => {
      if (watermarkPreview) watermarkPreview.textContent = watermarkText.value;
    });

    watermarkPos?.addEventListener('change', updatePreviewPosition);

    function updatePreviewPosition() {
      if (!watermarkPreview) return;
      const pos = watermarkPos.value;
      watermarkPreview.style.top = 'auto';
      watermarkPreview.style.bottom = 'auto';
      watermarkPreview.style.left = 'auto';
      watermarkPreview.style.right = 'auto';
      watermarkPreview.style.transform = 'none';

      switch(pos) {
        case 'bottom-right': watermarkPreview.style.bottom = '10%'; watermarkPreview.style.right = '10%'; break;
        case 'bottom-left': watermarkPreview.style.bottom = '10%'; watermarkPreview.style.left = '10%'; break;
        case 'top-right': watermarkPreview.style.top = '10%'; watermarkPreview.style.right = '10%'; break;
        case 'top-left': watermarkPreview.style.top = '10%'; watermarkPreview.style.left = '10%'; break;
        case 'center': 
          watermarkPreview.style.top = '50%'; 
          watermarkPreview.style.left = '50%'; 
          watermarkPreview.style.transform = 'translate(-50%, -50%)';
          break;
      }
    }

    function handleFile(file: File) {
      if (!file.type.startsWith('image/')) {
        alert("Please select a valid image file.");
        return;
      }
      originalFile = file;
      
      const reader = new FileReader();
      reader.onload = (e) => {
        imagePreview.src = e.target?.result as string;
        
        originalImage = new Image();
        originalImage.src = e.target?.result as string;
        
        updatePreviewPosition();
        showState('settings');
      };
      reader.readAsDataURL(file);
    }

    startBtn?.addEventListener('click', async () => {
      if (!originalFile || !originalImage) return;
      showState('processing');
      
      try {
        await new Promise(r => setTimeout(r, 50));
        
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) throw new Error("Could not get canvas context");
        
        canvas.width = originalImage.width;
        canvas.height = originalImage.height;
        
        ctx.drawImage(originalImage, 0, 0);
        
        // Add watermark
        const text = watermarkText.value;
        if (text) {
          const fontSize = Math.max(24, Math.floor(canvas.width * 0.05));
          ctx.font = `bold ${fontSize}px sans-serif`;
          ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
          ctx.shadowColor = 'rgba(0, 0, 0, 0.8)';
          ctx.shadowBlur = 4;
          ctx.shadowOffsetX = 2;
          ctx.shadowOffsetY = 2;
          
          const textMetrics = ctx.measureText(text);
          const pos = watermarkPos.value;
          
          let x = 0;
          let y = 0;
          const padding = canvas.width * 0.05;
          
          ctx.textBaseline = 'middle';
          
          switch(pos) {
            case 'bottom-right':
              x = canvas.width - textMetrics.width - padding;
              y = canvas.height - padding - (fontSize/2);
              break;
            case 'bottom-left':
              x = padding;
              y = canvas.height - padding - (fontSize/2);
              break;
            case 'top-right':
              x = canvas.width - textMetrics.width - padding;
              y = padding + (fontSize/2);
              break;
            case 'top-left':
              x = padding;
              y = padding + (fontSize/2);
              break;
            case 'center':
              x = (canvas.width - textMetrics.width) / 2;
              y = canvas.height / 2;
              break;
          }
          
          ctx.fillText(text, x, y);
        }
        
        let mimeType = originalFile.type;
        if (mimeType !== 'image/jpeg' && mimeType !== 'image/webp' && mimeType !== 'image/png') {
            mimeType = 'image/png';
        }
        
        const dataUrl = canvas.toDataURL(mimeType, 0.95);
        
        const ext = mimeType.split('/')[1] === 'jpeg' ? 'jpg' : mimeType.split('/')[1];
        const baseName = originalFile.name.substring(0, originalFile.name.lastIndexOf('.')) || originalFile.name;
        
        downloadBtn.href = dataUrl;
        downloadBtn.download = `${baseName}-watermarked.${ext}`;
        
        showState('result');
        
      } catch (e) {
        console.error('Watermark error', e);
        alert('An error occurred. Check console for details.');
        showState('settings');
      }
    });

    cancelBtn?.addEventListener('click', resetTool);
    resetBtn?.addEventListener('click', resetTool);

    function resetTool() {
      fileInput.value = '';
      originalFile = null;
      originalImage = null;
      imagePreview.src = '';
      showState('upload');
    }

    function showState(state: 'upload' | 'settings' | 'processing' | 'result') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      settingsZone?.classList.toggle('hidden', state !== 'settings');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }
  })();
</script>
