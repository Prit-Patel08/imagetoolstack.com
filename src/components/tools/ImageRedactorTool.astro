---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="redactor-tool-root" class="w-full flex flex-col items-center">
  <div class="w-full max-w-2xl bg-green-50 border border-green-200 rounded-lg p-4 mb-6 text-center shadow-sm">
    <p class="text-green-800 text-sm font-medium">100% Private: Your files never leave your computer. Redactions are permanent and secure.</p>
  </div>

  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 hover:border-link transition-colors cursor-pointer group">
    <div class="mb-4 h-16 w-16 rounded-full bg-canvas flex items-center justify-center text-link border border-hairline group-hover:border-link transition-colors shadow-sm">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
    </div>
    <div class="text-center">
      <p class="text-xl font-bold text-ink mb-2">Drag & Drop Image or Screenshot Here</p>
      <p class="text-sm text-body">Or click to browse your files.</p>
      <p class="text-xs text-mute mt-4 bg-canvas-soft inline-block px-3 py-1 rounded-full border border-hairline">Supported: PDF, JPG, PNG, WebP, AVIF</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="application/pdf,image/jpeg,image/png,image/webp,image/avif" />
  </div>

  <!-- Editor State -->
  <div id="editor-zone" class="hidden w-full flex flex-col items-center gap-6">
    
    <!-- Toolbar -->
    <div class="w-full bg-canvas border border-hairline rounded-xl p-4 shadow-sm flex flex-wrap items-center justify-between gap-4 sticky top-20 z-10">
      
      <div class="flex items-center gap-2 bg-canvas-soft p-1 rounded-lg border border-hairline">
        <button class="mode-btn active px-4 py-2 text-sm font-semibold rounded-md transition-colors bg-white shadow-sm text-ink" data-mode="whiteout">
          <span class="w-3 h-3 inline-block rounded-full border border-hairline bg-white mr-2"></span>Whiteout
        </button>
        <button class="mode-btn px-4 py-2 text-sm font-semibold rounded-md transition-colors text-mute hover:text-ink" data-mode="blackout">
          <span class="w-3 h-3 inline-block rounded-full bg-black mr-2"></span>Blackout
        </button>
        <button class="mode-btn px-4 py-2 text-sm font-semibold rounded-md transition-colors text-mute hover:text-ink" data-mode="blur">
          <svg class="h-4 w-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z M9 12h6 M12 9v6" /></svg>Blur
        </button>
        <button class="mode-btn px-4 py-2 text-sm font-semibold rounded-md transition-colors text-mute hover:text-ink" data-mode="pixelate">
          <svg class="h-4 w-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h16v16H4z M10 4v16 M14 4v16 M4 10h16 M4 14h16" /></svg>Pixelate
        </button>
      </div>

      <div class="flex items-center gap-3">
        <button id="undo-btn" class="btn-secondary px-4 py-2 flex items-center gap-2 text-sm disabled:opacity-50" disabled>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" /></svg>
          Undo
        </button>
        <button id="download-btn" class="btn-primary px-6 py-2 flex items-center gap-2 text-sm">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download Redacted
        </button>
        <button id="reset-btn" class="text-mute hover:text-danger ml-2 p-2 transition-colors" title="Start Over">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    </div>

    <!-- PDF Navigation (Hidden by default) -->
    <div id="pdf-controls" class="hidden w-full bg-blue-50 border border-blue-200 rounded-lg p-3 flex-row justify-between items-center shadow-sm">
      <button id="pdf-prev" class="btn-secondary px-4 py-1 text-sm disabled:opacity-50 bg-white border border-hairline shadow-sm rounded-md transition-colors hover:bg-gray-50">&larr; Previous Page</button>
      <span id="pdf-page-indicator" class="text-sm font-semibold text-blue-800">Page 1 of 1</span>
      <button id="pdf-next" class="btn-secondary px-4 py-1 text-sm disabled:opacity-50 bg-white border border-hairline shadow-sm rounded-md transition-colors hover:bg-gray-50">Next Page &rarr;</button>
    </div>

    <!-- Canvas Container -->
    <div class="w-full relative bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+CjxyZWN0IHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCIgZmlsbD0iI2ZmZiIgLz4KPHBhdGggZD0iTTAgMTBoMTB2MTBIMHptMTAgMGgxMHYtMTBIMTB6IiBmaWxsPSIjZjBmMHViIiAvPgo8L3N2Zz4=')] rounded-xl overflow-hidden shadow-md border border-hairline cursor-crosshair touch-none" style="min-height: 400px; display: flex; justify-content: center; align-items: center;" id="canvas-container">
      <canvas id="image-canvas" class="block max-w-full h-auto" style="box-shadow: 0 0 20px rgba(0,0,0,0.1);"></canvas>
      <canvas id="overlay-canvas" class="absolute top-0 left-0 pointer-events-none"></canvas>
    </div>

    <p class="text-sm text-mute italic">Click and drag over the image to apply the selected censor effect.</p>

  </div>

  <!-- PDF Export Modal -->
  <div id="pdf-export-modal" class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-canvas w-full max-w-md rounded-2xl shadow-xl overflow-hidden flex flex-col">
      <div class="px-6 py-4 border-b border-hairline flex justify-between items-center">
        <h3 class="text-lg font-bold text-ink">Download Options</h3>
        <button id="close-modal-btn" class="text-mute hover:text-ink transition-colors">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      
      <div id="modal-content" class="p-6 space-y-4">
        <div class="space-y-3">
          <label class="flex items-center gap-3 p-3 border border-link bg-blue-50/50 rounded-lg cursor-pointer">
            <input type="radio" name="export-type" value="current" class="w-4 h-4 text-link" checked>
            <span class="text-ink font-medium">Current Page Only (PNG)</span>
          </label>
          <label class="flex items-center gap-3 p-3 border border-hairline rounded-lg cursor-pointer hover:bg-canvas-soft">
            <input type="radio" name="export-type" value="all" class="w-4 h-4 text-link">
            <span class="text-ink font-medium">All Pages (PDF)</span>
          </label>
          <label class="flex flex-col gap-2 p-3 border border-hairline rounded-lg cursor-pointer hover:bg-canvas-soft">
            <div class="flex items-center gap-3">
              <input type="radio" name="export-type" value="range" class="w-4 h-4 text-link">
              <span class="text-ink font-medium">Custom Range (PDF)</span>
            </div>
            <input type="text" id="custom-range-input" class="mt-2 w-full px-3 py-2 border border-hairline rounded text-sm bg-canvas-soft disabled:opacity-50" placeholder="e.g. 1-3, 5" disabled>
          </label>
        </div>
        
        <button id="confirm-download-btn" class="w-full btn-primary mt-6">Download Now</button>
      </div>
      
      <div id="modal-loading" class="hidden p-8 flex flex-col items-center justify-center space-y-4">
        <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
        <p id="modal-loading-text" class="text-sm font-medium text-mute">Generating PDF...</p>
      </div>
    </div>
  </div>
</div>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  import { jsPDF } from 'jspdf';
  
  if (!pdfjsLib.GlobalWorkerOptions.workerSrc) {
    pdfjsLib.GlobalWorkerOptions.workerSrc = `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjsLib.version}/pdf.worker.min.js`;
  }

  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const editorZone = document.getElementById('editor-zone');
    const canvasContainer = document.getElementById('canvas-container');
    const imageCanvas = document.getElementById('image-canvas') as HTMLCanvasElement;
    const overlayCanvas = document.getElementById('overlay-canvas') as HTMLCanvasElement;
    const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
    const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
    const resetBtn = document.getElementById('reset-btn');
    const modeBtns = document.querySelectorAll('.mode-btn');

    const pdfControls = document.getElementById('pdf-controls');
    const pdfPrevBtn = document.getElementById('pdf-prev') as HTMLButtonElement;
    const pdfNextBtn = document.getElementById('pdf-next') as HTMLButtonElement;
    const pdfPageIndicator = document.getElementById('pdf-page-indicator');

    const modal = document.getElementById('pdf-export-modal');
    const closeModalBtn = document.getElementById('close-modal-btn');
    const confirmDownloadBtn = document.getElementById('confirm-download-btn');
    const radioButtons = document.querySelectorAll('input[name="export-type"]') as NodeListOf<HTMLInputElement>;
    const customRangeInput = document.getElementById('custom-range-input') as HTMLInputElement;
    const modalContent = document.getElementById('modal-content');
    const modalLoading = document.getElementById('modal-loading');
    const modalLoadingText = document.getElementById('modal-loading-text');

    if (!dropZone || !fileInput || !imageCanvas || !overlayCanvas) return;

    let currentMode: 'whiteout' | 'blackout' | 'blur' | 'pixelate' = 'whiteout';
    let originalImage: HTMLImageElement | null = null;
    let baseFilename = "redacted-image";
    let history: ImageData[] = [];
    
    let currentPdfDocument: any = null;
    let currentPdfPage = 1;
    let totalPdfPages = 1;
    let pageEdits = new Map<number, string>();

    // Drawing State
    let isDrawing = false;
    let startX = 0;
    let startY = 0;
    let scale = 1;

    // --- Mode Selection ---
    modeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        modeBtns.forEach(b => {
          b.classList.remove('active', 'bg-white', 'shadow-sm', 'text-ink');
          b.classList.add('text-mute');
        });
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.remove('text-mute');
        target.classList.add('active', 'bg-white', 'shadow-sm', 'text-ink');
        currentMode = target.dataset.mode as any;
      });
    });

    // --- File Handling ---
    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => { e.preventDefault(); e.stopPropagation(); }, false);
    });
    
    dropZone.addEventListener('dragenter', () => dropZone.classList.add('border-link', 'bg-blue-50/50'));
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-link', 'bg-blue-50/50'));
    dropZone.addEventListener('drop', (e) => {
      dropZone.classList.remove('border-link', 'bg-blue-50/50');
      const file = e.dataTransfer?.files[0];
      if (file && (file.type.startsWith('image/') || file.type === 'application/pdf')) {
        loadImage(file);
      }
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) loadImage(fileInput.files[0]);
      fileInput.value = '';
    });

    function loadImage(file: File) {
      baseFilename = file.name.replace(/\.[^/.]+$/, "");

      if (file.type === 'application/pdf') {
        const reader = new FileReader();
        reader.onload = async (e) => {
          const arrayBuffer = e.target?.result as ArrayBuffer;
          const loadingTask = pdfjsLib.getDocument({ data: arrayBuffer });
          currentPdfDocument = await loadingTask.promise;
          totalPdfPages = currentPdfDocument.numPages;
          currentPdfPage = 1;
          
          if (totalPdfPages > 1) {
            pdfControls!.classList.remove('hidden');
            pdfControls!.classList.add('flex');
          } else {
            pdfControls!.classList.add('hidden');
            pdfControls!.classList.remove('flex');
          }
          
          renderPdfPage(currentPdfPage);
        };
        reader.readAsArrayBuffer(file);
        return;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          originalImage = img;
          dropZone!.classList.add('hidden');
          editorZone!.classList.remove('hidden');
          setupCanvas(img);
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    async function renderPdfPage(pageNum: number) {
      if (!currentPdfDocument) return;

      if (pageEdits.has(pageNum)) {
        const img = new Image();
        img.onload = () => {
          originalImage = img;
          dropZone!.classList.add('hidden');
          editorZone!.classList.remove('hidden');
          setupCanvas(img);
        };
        img.src = pageEdits.get(pageNum)!;
      } else {
        const page = await currentPdfDocument.getPage(pageNum);
        const viewport = page.getViewport({ scale: 2.0 });
        const tempCanvas = document.createElement('canvas');
        const ctx = tempCanvas.getContext('2d');
        tempCanvas.height = viewport.height;
        tempCanvas.width = viewport.width;
        
        if (ctx) {
          await page.render({ canvasContext: ctx, viewport }).promise;
          const img = new Image();
          img.onload = () => {
            originalImage = img;
            dropZone!.classList.add('hidden');
            editorZone!.classList.remove('hidden');
            setupCanvas(img);
          };
          img.src = tempCanvas.toDataURL('image/png');
        }
      }
      
      pdfPageIndicator!.textContent = `Page ${pageNum} of ${totalPdfPages}`;
      pdfPrevBtn.disabled = pageNum <= 1;
      pdfNextBtn.disabled = pageNum >= totalPdfPages;
    }

    function saveCurrentPageEdit() {
      if (currentPdfDocument && imageCanvas) {
        pageEdits.set(currentPdfPage, imageCanvas.toDataURL('image/png', 1.0));
      }
    }

    pdfPrevBtn?.addEventListener('click', () => {
      if (currentPdfPage > 1) {
        saveCurrentPageEdit();
        currentPdfPage--;
        renderPdfPage(currentPdfPage);
      }
    });

    pdfNextBtn?.addEventListener('click', () => {
      if (currentPdfPage < totalPdfPages) {
        saveCurrentPageEdit();
        currentPdfPage++;
        renderPdfPage(currentPdfPage);
      }
    });

    function setupCanvas(img: HTMLImageElement) {
      imageCanvas.width = img.naturalWidth;
      imageCanvas.height = img.naturalHeight;
      overlayCanvas.width = img.naturalWidth;
      overlayCanvas.height = img.naturalHeight;

      history = []; // Reset history for new page/image

      const ctx = imageCanvas.getContext('2d');
      if (ctx) {
        ctx.drawImage(img, 0, 0);
        saveHistoryState();
      }
      
      syncCanvasSize();
    }

    function syncCanvasSize() {
      // The CSS scales the imageCanvas. We need to match overlayCanvas size and position.
      const rect = imageCanvas.getBoundingClientRect();
      const containerRect = canvasContainer!.getBoundingClientRect();
      
      overlayCanvas.style.width = `${rect.width}px`;
      overlayCanvas.style.height = `${rect.height}px`;
      overlayCanvas.style.top = `${rect.top - containerRect.top}px`;
      overlayCanvas.style.left = `${rect.left - containerRect.left}px`;
      
      scale = imageCanvas.width / rect.width;
    }

    window.addEventListener('resize', syncCanvasSize);

    // --- Drawing Logic ---
    function getCoords(e: MouseEvent | TouchEvent) {
      const rect = imageCanvas.getBoundingClientRect();
      const clientX = e instanceof MouseEvent ? e.clientX : e.touches[0].clientX;
      const clientY = e instanceof MouseEvent ? e.clientY : e.touches[0].clientY;
      return {
        x: (clientX - rect.left) * scale,
        y: (clientY - rect.top) * scale
      };
    }

    function handleStart(e: MouseEvent | TouchEvent) {
      e.preventDefault();
      if (!originalImage) return;
      isDrawing = true;
      const coords = getCoords(e);
      startX = coords.x;
      startY = coords.y;
    }

    function handleMove(e: MouseEvent | TouchEvent) {
      if (!isDrawing) return;
      e.preventDefault();
      const coords = getCoords(e);
      drawOverlayRect(startX, startY, coords.x - startX, coords.y - startY);
    }

    function handleEnd(e: MouseEvent | TouchEvent) {
      if (!isDrawing) return;
      e.preventDefault();
      isDrawing = false;
      
      const coords = getCoords(e instanceof MouseEvent ? e : e.changedTouches[0]);
      const width = coords.x - startX;
      const height = coords.y - startY;
      
      if (Math.abs(width) > 5 && Math.abs(height) > 5) {
        applyRedaction(startX, startY, width, height);
      }
      
      clearOverlay();
    }

    imageCanvas.addEventListener('mousedown', handleStart);
    imageCanvas.addEventListener('mousemove', handleMove);
    window.addEventListener('mouseup', handleEnd);

    imageCanvas.addEventListener('touchstart', handleStart, {passive: false});
    imageCanvas.addEventListener('touchmove', handleMove, {passive: false});
    window.addEventListener('touchend', handleEnd);

    function drawOverlayRect(x: number, y: number, w: number, h: number) {
      const ctx = overlayCanvas.getContext('2d');
      if (!ctx) return;
      ctx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
      
      ctx.strokeStyle = '#ef4444'; // Red dash
      ctx.lineWidth = 2 * scale;
      ctx.setLineDash([10 * scale, 10 * scale]);
      ctx.strokeRect(x, y, w, h);
      
      ctx.fillStyle = currentMode === 'whiteout' ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.5)';
      ctx.fillRect(x, y, w, h);
    }

    function clearOverlay() {
      const ctx = overlayCanvas.getContext('2d');
      if (ctx) ctx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
    }

    function applyRedaction(x: number, y: number, w: number, h: number) {
      const ctx = imageCanvas.getContext('2d');
      if (!ctx) return;

      // Normalize negative widths/heights
      if (w < 0) { x += w; w = Math.abs(w); }
      if (h < 0) { y += h; h = Math.abs(h); }

      ctx.save();
      
      if (currentMode === 'whiteout') {
        ctx.fillStyle = 'white';
        ctx.fillRect(x, y, w, h);
      } else if (currentMode === 'blackout') {
        ctx.fillStyle = 'black';
        ctx.fillRect(x, y, w, h);
      } else if (currentMode === 'blur') {
        ctx.filter = `blur(${Math.max(10, Math.min(w, h) * 0.05)}px)`;
        ctx.drawImage(imageCanvas, x, y, w, h, x, y, w, h);
      } else if (currentMode === 'pixelate') {
        // Pixelate effect: draw tiny, then scale up
        const pixelSize = Math.max(8, Math.min(w, h) * 0.05);
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = w; tempCanvas.height = h;
        const tCtx = tempCanvas.getContext('2d');
        if (tCtx) {
          // Draw region
          tCtx.drawImage(imageCanvas, x, y, w, h, 0, 0, w, h);
          // Scale down
          const downW = Math.max(1, w / pixelSize);
          const downH = Math.max(1, h / pixelSize);
          const tinyCanvas = document.createElement('canvas');
          tinyCanvas.width = downW; tinyCanvas.height = downH;
          const tinyCtx = tinyCanvas.getContext('2d');
          if (tinyCtx) {
            tinyCtx.drawImage(tempCanvas, 0, 0, downW, downH);
            // Turn off smoothing
            ctx.imageSmoothingEnabled = false;
            ctx.drawImage(tinyCanvas, 0, 0, downW, downH, x, y, w, h);
            ctx.imageSmoothingEnabled = true;
          }
        }
      }
      
      ctx.restore();
      saveHistoryState();
    }

    // --- History & Undo ---
    function saveHistoryState() {
      const ctx = imageCanvas.getContext('2d');
      if (!ctx) return;
      history.push(ctx.getImageData(0, 0, imageCanvas.width, imageCanvas.height));
      undoBtn.disabled = history.length <= 1;
    }

    undoBtn.addEventListener('click', () => {
      if (history.length > 1) {
        history.pop(); // Remove current
        const previous = history[history.length - 1];
        const ctx = imageCanvas.getContext('2d');
        if (ctx) ctx.putImageData(previous, 0, 0);
        undoBtn.disabled = history.length <= 1;
      }
    });

    // --- Export ---
    downloadBtn.addEventListener('click', () => {
      if (currentPdfDocument) {
        modal?.classList.remove('hidden');
      } else {
        downloadPng();
      }
    });

    closeModalBtn?.addEventListener('click', () => {
      modal?.classList.add('hidden');
    });

    radioButtons.forEach(radio => {
      radio.addEventListener('change', () => {
        radioButtons.forEach(r => {
          const parent = r.closest('label');
          if (r.checked) {
            parent?.classList.add('border-link', 'bg-blue-50/50');
            parent?.classList.remove('border-hairline');
            if (r.value === 'range') customRangeInput.disabled = false;
            else customRangeInput.disabled = true;
          } else {
            parent?.classList.remove('border-link', 'bg-blue-50/50');
            parent?.classList.add('border-hairline');
          }
        });
      });
    });

    function downloadPng() {
      imageCanvas.toBlob((blob) => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${baseFilename}-redacted.png`;
        a.click();
        URL.revokeObjectURL(url);
      }, 'image/png');
    }

    function parseRange(rangeStr: string, max: number): number[] {
      const pages = new Set<number>();
      const parts = rangeStr.split(',');
      for (const p of parts) {
        if (p.includes('-')) {
          const [start, end] = p.split('-').map(s => parseInt(s.trim()));
          if (!isNaN(start) && !isNaN(end)) {
            for (let i = start; i <= end; i++) {
              if (i >= 1 && i <= max) pages.add(i);
            }
          }
        } else {
          const num = parseInt(p.trim());
          if (!isNaN(num) && num >= 1 && num <= max) pages.add(num);
        }
      }
      return Array.from(pages).sort((a,b) => a - b);
    }

    confirmDownloadBtn?.addEventListener('click', async () => {
      const selected = document.querySelector('input[name="export-type"]:checked') as HTMLInputElement;
      if (!selected) return;

      if (selected.value === 'current') {
        downloadPng();
        modal?.classList.add('hidden');
        return;
      }

      let pagesToExport: number[] = [];
      if (selected.value === 'all') {
        for (let i = 1; i <= totalPdfPages; i++) pagesToExport.push(i);
      } else if (selected.value === 'range') {
        pagesToExport = parseRange(customRangeInput.value, totalPdfPages);
        if (pagesToExport.length === 0) {
          alert('Please enter a valid page range.');
          return;
        }
      }

      modalContent?.classList.add('hidden');
      modalLoading?.classList.remove('hidden');
      
      saveCurrentPageEdit(); // Save current page before export
      
      try {
        const doc = new jsPDF({ orientation: 'p', unit: 'mm', format: 'a4' });
        doc.deletePage(1); // remove default

        for (let i = 0; i < pagesToExport.length; i++) {
          const pageNum = pagesToExport[i];
          modalLoadingText!.textContent = `Processing page ${pageNum} / ${totalPdfPages}...`;
          
          let imgDataUrl = '';
          if (pageEdits.has(pageNum)) {
            imgDataUrl = pageEdits.get(pageNum)!;
          } else {
            const page = await currentPdfDocument.getPage(pageNum);
            const viewport = page.getViewport({ scale: 2.0 });
            const tempCanvas = document.createElement('canvas');
            const ctx = tempCanvas.getContext('2d');
            tempCanvas.height = viewport.height;
            tempCanvas.width = viewport.width;
            await page.render({ canvasContext: ctx!, viewport }).promise;
            imgDataUrl = tempCanvas.toDataURL('image/jpeg', 0.95);
          }

          const imgProps = doc.getImageProperties(imgDataUrl);
          const w = imgProps.width * 0.264583;
          const h = imgProps.height * 0.264583;
          doc.addPage([w, h], w > h ? 'l' : 'p');
          doc.addImage(imgDataUrl, 'JPEG', 0, 0, w, h);
        }

        const pdfBlob = doc.output('blob');
        const url = URL.createObjectURL(pdfBlob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${baseFilename}-redacted.pdf`;
        a.click();
        URL.revokeObjectURL(url);
      } catch (e) {
        console.error(e);
        alert('Failed to generate PDF.');
      }

      modal?.classList.add('hidden');
      modalContent?.classList.remove('hidden');
      modalLoading?.classList.add('hidden');
    });

    resetBtn?.addEventListener('click', () => {
      if(confirm("Start over? All edits will be lost.")) {
        dropZone?.classList.remove('hidden');
        editorZone?.classList.add('hidden');
        pdfControls?.classList.add('hidden');
        pdfControls?.classList.remove('flex');
        history = [];
        pageEdits.clear();
        undoBtn.disabled = true;
        originalImage = null;
        currentPdfDocument = null;
        fileInput.value = '';
      }
    });

  })();
</script>
