---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="flip-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 transition-colors cursor-pointer group">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline group-hover:border-hairline-strong transition-colors">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
    </div>
    <div class="text-center">
      <p class="text-base font-semibold text-ink">Select an image to flip</p>
      <p class="mt-1 text-sm text-body">Supports JPG, PNG, and WebP.</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="image/jpeg,image/png,image/webp" />
  </div>

  <!-- Settings State -->
  <div id="settings-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    
    <!-- Image Preview -->
    <div class="w-full max-w-2xl bg-canvas-soft border border-hairline rounded-xl p-4 flex items-center justify-center overflow-hidden min-h-[300px]">
      <img id="image-preview" class="max-w-full max-h-[500px] object-contain shadow-sm transition-transform duration-300" src="" alt="Preview" />
    </div>

    <!-- Controls -->
    <div class="w-full max-w-2xl bg-canvas border border-hairline rounded-xl p-6 shadow-sm">
      <h3 class="text-lg font-semibold text-ink mb-4 text-center">Flip Controls</h3>
      
      <div class="flex flex-wrap justify-center gap-4">
        <button id="btn-flip-h" class="px-6 py-3 bg-canvas-soft border border-hairline rounded-lg font-medium text-ink hover:border-link transition-colors flex items-center gap-2">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
          Flip Horizontally
        </button>
        <button id="btn-flip-v" class="px-6 py-3 bg-canvas-soft border border-hairline rounded-lg font-medium text-ink hover:border-link transition-colors flex items-center gap-2">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>
          Flip Vertically
        </button>
      </div>

      <div class="mt-8 flex gap-4">
        <button id="start-btn" class="flex-1 btn-primary">Apply & Download</button>
        <button id="cancel-btn" class="px-6 py-2 border border-hairline rounded text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft transition-colors">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Processing State -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center gap-6 py-12">
    <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
    <div class="w-full max-w-md text-center">
      <p class="text-sm font-mono text-mute uppercase tracking-widest">Processing Image...</p>
    </div>
  </div>

  <!-- Result State -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-12">
    <div class="h-16 w-16 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <div class="text-center">
      <h3 class="text-xl font-bold text-ink">Image Flipped!</h3>
      <p class="text-sm text-body mt-2">Your new image is ready to download.</p>
    </div>
    
    <div class="flex flex-col items-center gap-4 mt-4 w-full max-w-xs">
      <a id="download-btn" class="w-full btn-primary text-center cursor-pointer">Download Image</a>
      <button id="reset-btn" class="text-sm font-medium text-link hover:underline">Flip another image</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const settingsZone = document.getElementById('settings-zone');
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    
    const imagePreview = document.getElementById('image-preview') as HTMLImageElement;
    const btnFlipH = document.getElementById('btn-flip-h');
    const btnFlipV = document.getElementById('btn-flip-v');
    
    const startBtn = document.getElementById('start-btn');
    const cancelBtn = document.getElementById('cancel-btn');
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');

    let originalFile: File | null = null;
    let originalImage: HTMLImageElement | null = null;
    let flipH = false;
    let flipV = false;

    if (!dropZone || !fileInput) return;

    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault(); e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const file = e.dataTransfer?.files?.[0];
      if (file) handleFile(file);
    });

    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleFile(file);
    });

    function handleFile(file: File) {
      if (!file.type.startsWith('image/')) {
        alert("Please select a valid image file.");
        return;
      }
      originalFile = file;
      flipH = false;
      flipV = false;
      updatePreviewFlip();
      
      const reader = new FileReader();
      reader.onload = (e) => {
        imagePreview.src = e.target?.result as string;
        
        originalImage = new Image();
        originalImage.src = e.target?.result as string;
        
        showState('settings');
      };
      reader.readAsDataURL(file);
    }
    
    function updatePreviewFlip() {
      imagePreview.style.transform = `scaleX(${flipH ? -1 : 1}) scaleY(${flipV ? -1 : 1})`;
    }

    btnFlipH?.addEventListener('click', () => { flipH = !flipH; updatePreviewFlip(); });
    btnFlipV?.addEventListener('click', () => { flipV = !flipV; updatePreviewFlip(); });

    startBtn?.addEventListener('click', async () => {
      if (!originalFile || !originalImage) return;
      showState('processing');
      
      try {
        await new Promise(r => setTimeout(r, 50));
        
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) throw new Error("Could not get canvas context");
        
        canvas.width = originalImage.width;
        canvas.height = originalImage.height;
        
        ctx.translate(
            flipH ? canvas.width : 0,
            flipV ? canvas.height : 0
        );
        ctx.scale(
            flipH ? -1 : 1,
            flipV ? -1 : 1
        );
        
        ctx.drawImage(originalImage, 0, 0);
        
        let mimeType = originalFile.type;
        if (mimeType !== 'image/jpeg' && mimeType !== 'image/webp' && mimeType !== 'image/png') {
            mimeType = 'image/png';
        }
        
        const dataUrl = canvas.toDataURL(mimeType, 1.0);
        
        const ext = mimeType.split('/')[1] === 'jpeg' ? 'jpg' : mimeType.split('/')[1];
        const baseName = originalFile.name.substring(0, originalFile.name.lastIndexOf('.')) || originalFile.name;
        
        downloadBtn.href = dataUrl;
        downloadBtn.download = `${baseName}-flipped.${ext}`;
        
        showState('result');
        
      } catch (e) {
        console.error('Flip error', e);
        alert('An error occurred. Check console for details.');
        showState('settings');
      }
    });

    cancelBtn?.addEventListener('click', resetTool);
    resetBtn?.addEventListener('click', resetTool);

    function resetTool() {
      fileInput.value = '';
      originalFile = null;
      originalImage = null;
      flipH = false;
      flipV = false;
      imagePreview.src = '';
      updatePreviewFlip();
      showState('upload');
    }

    function showState(state: 'upload' | 'settings' | 'processing' | 'result') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      settingsZone?.classList.toggle('hidden', state !== 'settings');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }
  })();
</script>
