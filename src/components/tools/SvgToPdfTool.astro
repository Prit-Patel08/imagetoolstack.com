---
// Generated automatically for Batch 3 Phase 2 (PDF Toolkit)

interface Props {
  toolId?: string;
}
---

<div class="w-full max-w-4xl mx-auto flex flex-col gap-8">
  <div class="bg-canvas border border-hairline rounded-2xl p-6 sm:p-8 shadow-sm">
    <div class="flex items-center gap-3 mb-6 pb-6 border-b border-hairline">
      <div class="h-10 w-10 bg-link/10 text-link rounded-lg flex items-center justify-center">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-ink">SVG to PDF</h2>
        <p class="text-sm text-body">100% Secure & Local Processing via PDF-Lib</p>
      </div>
    </div>

    <!-- Upload Area -->
    <div class="flex flex-col gap-6">
      <div id="dropzone" class="border-2 border-dashed border-hairline rounded-xl p-8 sm:p-12 text-center hover:border-link hover:bg-canvas-soft transition-colors cursor-pointer group">
        <input type="file" id="fileInput" class="hidden" accept="image/svg+xml" />
        <div class="flex flex-col items-center gap-4">
          <div class="h-16 w-16 bg-canvas-soft rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="h-8 w-8 text-mute group-hover:text-link transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
          </div>
          <div>
            <p class="text-base font-semibold text-ink">Click to upload or drag and drop</p>
            <p class="text-sm text-body mt-1">Accepts image/svg+xml</p>
          </div>
        </div>
      </div>

      <!-- Settings UI -->
      <div id="settingsArea" class="hidden flex flex-col gap-6">
        <div class="bg-canvas-soft-2 p-6 rounded-xl border border-hairline">
          <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-4">Settings</h3>
          
      <div class="p-4 bg-canvas-soft border border-hairline rounded-lg">
        <p class="text-sm text-ink">Converts your vector SVG into a standardized PDF document.</p>
      </div>
    
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-hairline">
          <button id="processBtn" class="px-6 py-2.5 bg-link hover:bg-link-hover text-white font-medium rounded-lg shadow-sm transition-all focus:ring-2 focus:ring-link focus:ring-offset-2">
            Process File
          </button>
        </div>
      </div>

      <!-- Result Area -->
      <div id="resultArea" class="hidden flex flex-col gap-4">
        <div class="p-8 border border-hairline rounded-lg text-center bg-success/10 text-success">
          <svg class="w-12 h-12 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <h3 class="text-lg font-semibold">Processing Complete!</h3>
          <p class="text-sm opacity-80 mt-1">Your file has been processed securely in your browser.</p>
        </div>
        <button id="downloadBtn" class="hidden w-full py-3 bg-success hover:bg-success/90 text-white font-semibold rounded-lg shadow-sm transition-all">
          Download File
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>

<script>
  let file: File | null = null;
  const dropzone = document.getElementById('dropzone')!;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const settingsArea = document.getElementById('settingsArea')!;
  const processBtn = document.getElementById('processBtn')!;
  const resultArea = document.getElementById('resultArea')!;
  const downloadBtn = document.getElementById('downloadBtn') as HTMLButtonElement;

  dropzone.addEventListener('click', () => fileInput.click());
  
  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-link', 'bg-canvas-soft');
  });

  dropzone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-link', 'bg-canvas-soft');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-link', 'bg-canvas-soft');
    if (e.dataTransfer?.files.length) {
      file = e.dataTransfer.files[0];
      handleFileSelected();
    }
  });

  fileInput.addEventListener('change', (e) => {
    if (fileInput.files?.length) {
      file = fileInput.files[0];
      handleFileSelected();
    }
  });

  function handleFileSelected() {
    dropzone.classList.add('hidden');
    settingsArea.classList.remove('hidden');
  }

  function downloadBlob(blob: Blob, filename: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  processBtn.addEventListener('click', async () => {
    if (!file && !document.getElementById('b64input')?.value) return;
    
    processBtn.disabled = true;
    processBtn.textContent = 'Processing...';

    try {
      // -- CORE PDF LOGIC --
      
      const pdfDoc = await PDFLib.PDFDocument.create();
      const page = pdfDoc.addPage();
      
      const img = new Image();
      img.src = URL.createObjectURL(file);
      await new Promise(resolve => img.onload = resolve);
      
      const cvs = document.createElement('canvas');
      cvs.width = img.width || 800; cvs.height = img.height || 600;
      cvs.getContext('2d').drawImage(img, 0, 0);
      const pngDataUrl = cvs.toDataURL('image/png');
      
      const pngImage = await pdfDoc.embedPng(pngDataUrl);
      const { width, height } = pngImage.scale(1);
      
      page.setSize(width, height);
      page.drawImage(pngImage, { x: 0, y: 0, width, height });
      
      const pdfBytes = await pdfDoc.save();
      downloadBlob(new Blob([pdfBytes], { type: 'application/pdf' }), 'converted.pdf');
    
      // --------------------

      settingsArea.classList.add('hidden');
      resultArea.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      alert('An error occurred during processing.');
      processBtn.disabled = false;
      processBtn.textContent = 'Process File';
    }
  });
</script>

<!-- SEO Content Section -->
<div class="mt-24 pt-16 border-t border-hairline max-w-4xl mx-auto">
  <div class="prose prose-vercel max-w-none text-body">
    <h2 class="text-3xl font-bold text-ink mb-6">Why Convert SVG to PDF?</h2>
    <p class="text-lg leading-relaxed mb-6">
      SVG (Scalable Vector Graphics) is the absolute best format for the web. It's lightweight, scalable, and perfect for logos and icons. However, SVG files fall apart the moment you try to use them outside of a web browser. If you need to print a document, email a contract, or send a design to a manufacturer, you must convert your SVG to a PDF.
    </p>

    <h3 class="text-2xl font-bold text-ink mt-12 mb-4">1. Print Compatibility</h3>
    <p class="mb-6">
      Standard desktop printers and commercial printing presses do not understand SVG files. They rely on fixed-layout formats that dictate exactly how ink should be applied to paper. PDF (Portable Document Format) is the global standard for printing. Converting your SVG to a PDF ensures that your vector lines, curves, and colors print exactly as they appear on your screen, without pixelating.
    </p>

    <h3 class="text-2xl font-bold text-ink mt-8 mb-4">2. Fixed Layouts & Typography</h3>
    <p class="mb-6">
      If an SVG file uses a custom font, and you send that SVG to someone who doesn't have that font installed, their computer will automatically swap it for a default font like Times New Roman, completely destroying your design. PDFs embed fonts and layout coordinates directly into the file. When you convert an SVG to a PDF, the document becomes "frozen" in its perfect state, meaning it will look identical on every device in the world.
    </p>

    <div class="bg-link/5 border border-link/20 rounded-xl p-8 mt-12">
      <h3 class="text-xl font-bold text-ink flex items-center gap-2 mb-4">
        <svg class="w-6 h-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        100% Private, Local Processing
      </h3>
      <p class="m-0">
        Unlike other conversion websites that force you to upload your sensitive vector files to their servers, our SVG to PDF converter runs entirely inside your own web browser using local Web Workers. Your data <strong>never leaves your computer</strong>. This means no waiting for uploads, no server limits, and zero risk of your proprietary designs or sensitive documents being intercepted.
      </p>
    </div>
  </div>
</div>
