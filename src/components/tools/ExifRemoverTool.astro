---
// ExifRemoverTool.astro - Lossless metadata stripper for JPEGs, canvas-based for others
interface Props {
  toolId?: string;
}
---

<div class="w-full max-w-4xl mx-auto flex flex-col gap-8">
  <div class="bg-canvas border border-hairline rounded-2xl p-6 sm:p-8 shadow-sm">
    <div class="flex items-center gap-3 mb-6 pb-6 border-b border-hairline">
      <div class="h-10 w-10 bg-link/10 text-link rounded-lg flex items-center justify-center">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-ink">EXIF Metadata Remover</h2>
        <p class="text-sm text-body">Advanced Local Processing via Client-Side Libraries</p>
      </div>
    </div>

    <!-- Upload Area -->
    <div class="flex flex-col gap-6">
      <div id="dropzone" class="border-2 border-dashed border-hairline rounded-xl p-8 sm:p-12 text-center hover:border-link hover:bg-canvas-soft transition-colors cursor-pointer group">
        <input type="file" id="fileInput" class="hidden" accept="image/jpeg, image/png, image/webp" />
        <div class="flex flex-col items-center gap-4">
          <div class="h-16 w-16 bg-canvas-soft rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="h-8 w-8 text-mute group-hover:text-link transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
          </div>
          <div>
            <p class="text-base font-semibold text-ink">Click to upload or drag and drop</p>
            <p class="text-sm text-body mt-1">Accepts JPG, PNG, and WebP formats</p>
          </div>
        </div>
      </div>

      <!-- Settings UI -->
      <div id="settingsArea" class="hidden flex flex-col gap-6">
        <div class="bg-canvas-soft-2 p-6 rounded-xl border border-hairline">
          <h3 class="text-sm font-semibold text-ink uppercase tracking-wider mb-4">Settings</h3>
          
          <div class="p-4 bg-canvas-soft border border-hairline rounded-lg flex flex-col gap-1.5">
            <p class="text-sm font-semibold text-ink">Securely strips GPS location, camera settings, and hidden metadata.</p>
            <p id="format-notice" class="text-xs text-mute">Analyzing file...</p>
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-hairline">
          <button id="processBtn" class="px-6 py-2.5 bg-link hover:bg-link-hover text-white font-medium rounded-lg shadow-sm transition-all focus:ring-2 focus:ring-link focus:ring-offset-2">
            Execute Removal
          </button>
        </div>
      </div>

      <!-- Result Area -->
      <div id="resultArea" class="hidden flex flex-col gap-4">
        <div class="p-6 border border-hairline rounded-lg text-center bg-success/5 text-success">
          <svg class="w-8 h-8 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <h3 class="text-base font-semibold">Metadata Stripped Successfully!</h3>
          <p id="savings-text" class="text-xs opacity-90 mt-1 font-mono">0 bytes removed</p>
        </div>
        
        <div class="aspect-video w-full rounded-lg border border-hairline overflow-hidden bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+CjxyZWN0IHdpZHRoPSIxMCIgaGVpZ2h0PSIxMCIgZmlsbD0iI2Y4ZjhmOCIvPgo8cmVjdCB4PSIxMCIgeT0iMTAiIHdpZHRoPSIxMCIgaGVpZ2h0PSIxMCIgZmlsbD0iI2Y4ZjhmOCIvPgo8L3N2Zz4=')] flex items-center justify-center p-4">
          <img id="preview-img" class="max-h-full max-w-full object-contain drop-shadow" />
        </div>
        
        <button id="downloadBtn" class="w-full py-3 bg-success hover:bg-success/90 text-white font-semibold rounded-lg shadow-sm transition-all flex items-center justify-center gap-2">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download Cleaned Image
        </button>
        <button id="reset-btn-result" class="text-xs font-medium text-body hover:text-ink transition-colors mt-1 text-center">Process another image</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/piexifjs/1.0.6/piexif.min.js"></script>

<script>
  let file: File | null = null;
  let processedDataUrl = '';

  const dropzone = document.getElementById('dropzone')!;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const settingsArea = document.getElementById('settingsArea')!;
  const formatNotice = document.getElementById('format-notice')!;
  const processBtn = document.getElementById('processBtn')!;
  const resultArea = document.getElementById('resultArea')!;
  const downloadBtn = document.getElementById('downloadBtn') as HTMLButtonElement;
  const resetBtnResult = document.getElementById('reset-btn-result')!;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const savingsText = document.getElementById('savings-text')!;

  dropzone.addEventListener('click', () => fileInput.click());
  
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    dropzone.addEventListener(eventName, e => {
      e.preventDefault();
      e.stopPropagation();
    });
  });

  dropzone.addEventListener('dragover', () => {
    dropzone.classList.add('border-link', 'bg-canvas-soft');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-link', 'bg-canvas-soft');
  });

  dropzone.addEventListener('drop', (e) => {
    dropzone.classList.remove('border-link', 'bg-canvas-soft');
    if (e.dataTransfer?.files.length) {
      file = e.dataTransfer.files[0];
      handleFileSelected();
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) {
      file = fileInput.files[0];
      handleFileSelected();
    }
  });

  function handleFileSelected() {
    if (!file) return;
    dropzone.classList.add('hidden');
    settingsArea.classList.remove('hidden');

    if (file.type === 'image/jpeg' || file.type === 'image/jpg') {
      formatNotice.innerHTML = '<strong>JPEG Format Detected:</strong> Metadata will be stripped losslessly at the binary level. Image pixels and quality remain 100% untouched.';
    } else {
      formatNotice.innerHTML = `<strong>${file.type.split('/')[1].toUpperCase()} Format Detected:</strong> Metadata will be removed by regenerating the image via HTML5 Canvas (which naturally discards metadata chunks).`;
    }
  }

  processBtn.addEventListener('click', async () => {
    if (!file) return;
    
    processBtn.disabled = true;
    processBtn.textContent = 'Stripping Metadata...';

    try {
      const reader = new FileReader();

      reader.onload = function(e) {
        const resultSrc = e.target?.result as string;

        if (file!.type === 'image/jpeg' || file!.type === 'image/jpg') {
          // LOSSLESS JPEG STRIPPING
          try {
            // piexif.remove strips all APP1 and APP2 tags (EXIF/GPS/IPTC) losslessly
            processedDataUrl = (window as any).piexif.remove(resultSrc);
            
            // Calculate size differences
            const cleanedSize = Math.round((processedDataUrl.length - (processedDataUrl.indexOf(',') + 1)) * 3 / 4);
            const savedBytes = file!.size - cleanedSize;
            savingsText.textContent = savedBytes > 0 
              ? `${(savedBytes / 1024).toFixed(2)} KB of metadata removed losslessly` 
              : '0 bytes of metadata found (image already clean). Lossless copy generated.';

            previewImg.onload = () => showResult();
            previewImg.src = processedDataUrl;
          } catch (err) {
            console.warn('piexif failed, falling back to canvas binarization', err);
            processViaCanvas(resultSrc);
          }
        } else {
          // PNG / WEBP CAN-STRIP
          processViaCanvas(resultSrc);
        }
      };

      reader.readAsDataURL(file);

    } catch (err) {
      console.error(err);
      alert('An error occurred during processing.');
      processBtn.disabled = false;
      processBtn.textContent = 'Execute Removal';
    }
  });

  function processViaCanvas(src: string) {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = img.width;
      canvas.height = img.height;
      const ctx = canvas.getContext('2d')!;
      ctx.drawImage(img, 0, 0);

      // Re-exporting via Canvas naturally strips metadata blocks
      processedDataUrl = canvas.toDataURL(file!.type);
      
      const cleanedSize = Math.round((processedDataUrl.length - (processedDataUrl.indexOf(',') + 1)) * 3 / 4);
      const savedBytes = file!.size - cleanedSize;
      savingsText.textContent = savedBytes > 0 
        ? `${(savedBytes / 1024).toFixed(2)} KB of file size reduced by stripping metadata chunks` 
        : '0 bytes of metadata found. Clean copy generated.';

      previewImg.onload = () => showResult();
      previewImg.src = processedDataUrl;
    };
    img.src = src;
  }

  function showResult() {
    settingsArea.classList.add('hidden');
    resultArea.classList.remove('hidden');
  }

  downloadBtn.addEventListener('click', () => {
    if (!processedDataUrl) return;
    const a = document.createElement('a');
    a.href = processedDataUrl;
    const baseName = file ? file.name.replace(/\.[^/.]+$/, "") : 'clean';
    const ext = file && (file.type === 'image/jpeg' || file.type === 'image/jpg') ? 'jpg' : (file && file.type === 'image/webp' ? 'webp' : 'png');
    a.download = `${baseName}-clean.${ext}`;
    a.click();
  });

  const resetHandler = () => {
    file = null;
    processedDataUrl = '';
    fileInput.value = '';
    previewImg.src = '';
    processBtn.disabled = false;
    processBtn.textContent = 'Execute Removal';
    resultArea.classList.add('hidden');
    dropzone.classList.remove('hidden');
  };
  resetBtnResult.addEventListener('click', resetHandler);
</script>

<!-- SEO Content Section -->
<div class="mt-24 pt-16 border-t border-hairline max-w-4xl mx-auto">
  <div class="prose prose-vercel max-w-none text-body">
    <h2 class="text-3xl font-bold text-ink mb-6 font-sans">Why You Should Always Remove EXIF Data</h2>
    <p class="text-lg leading-relaxed mb-6">
      Every time you take a photo with your smartphone or digital camera, it silently records hidden information directly into the image file. This hidden metadata is called <strong>EXIF data</strong> (Exchangeable Image File Format), and while it can be useful for photographers, it poses a massive privacy risk when uploading photos to the internet.
    </p>

    <h3 class="text-2xl font-bold text-ink mt-12 mb-4 font-sans">What Exactly Is Hidden in Your Photos?</h3>
    <p class="mb-6">
      Depending on your camera settings, a standard JPG photo can contain incredibly sensitive information that anyone can extract with a free tool. This usually includes:
    </p>
    <ul class="list-disc pl-6 space-y-4 mb-8">
      <li><strong>Exact GPS Coordinates:</strong> The exact latitude and longitude of where you were standing when you took the photo. If you take a picture in your living room, you are permanently attaching your home address to that image.</li>
      <li><strong>Date and Time Stamps:</strong> The exact second the photo was captured.</li>
      <li><strong>Device Information:</strong> The exact make and model of your smartphone or camera (e.g., iPhone 15 Pro, Canon EOS R5).</li>
      <li><strong>Camera Settings:</strong> The aperture, shutter speed, ISO, and focal length used.</li>
    </ul>

    <h3 class="text-2xl font-bold text-ink mt-8 mb-4 font-sans">The Privacy Risk</h3>
    <p class="mb-6">
      While major social media platforms like Instagram and Twitter automatically strip EXIF data when you upload a photo, many personal blogs, forums, dating apps, and classified sites (like Craigslist) do not. If you upload a photo of an item you are selling online without wiping the EXIF data, any stranger can download the photo and see exactly where you live.
    </p>

    <div class="bg-link/5 border border-link/20 rounded-xl p-8 mt-12">
      <h3 class="text-xl font-bold text-ink flex items-center gap-2 mb-4 font-sans">
        <svg class="w-6 h-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        100% Secure, Client-Side Removal
      </h3>
      <p class="m-0">
        Most EXIF removal tools online require you to upload your sensitive photos to their remote servers so their scripts can clean them. This defeats the entire purpose of privacy! Our tool uses advanced Web Workers to strip the EXIF data directly inside your own web browser. Your photos <strong>never leave your computer</strong>, guaranteeing 100% security and privacy.
      </p>
    </div>
  </div>
</div>
