---
import { Tool } from "../../utils/seo-generator";
interface Props { tool: Tool; }
const { tool } = Astro.props;
---
<div class="converter-tool-root flex flex-col gap-8 w-full max-w-4xl mx-auto">
  <div class="bg-surface rounded-2xl shadow-sm border border-border overflow-hidden p-6">
    <div id="drop-zone" class="relative group cursor-pointer mb-6">
        <div class="absolute inset-0 bg-primary/5 rounded-xl border-2 border-dashed border-primary/30 group-hover:border-primary transition-colors"></div>
        <div class="relative py-12 px-6 text-center">
            <p class="text-lg font-medium text-heading">Click to select PDF</p>
        </div>
        <input type="file" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept=".pdf" />
    </div>

    <div id="controls" class="hidden">
      <p id="page-count" class="text-sm text-body mb-4 font-medium"></p>
      <label class="block text-sm font-medium text-heading mb-2">Pages to REMOVE (comma separated e.g. 1, 3, 5):</label>
      <input type="text" id="remove-input" class="w-full p-3 border border-border rounded-lg bg-surface mb-4">
      <button id="remove-btn" class="px-6 py-2.5 bg-primary text-white font-medium rounded-lg w-full hover:bg-primary-dark transition-colors">Remove Pages</button>
    </div>
  </div>
</div>

<script>
  import { PDFDocument } from 'pdf-lib';

  let currentFile: File | null = null;
  let totalPages = 0;
  
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const controls = document.getElementById('controls');
  const pageCountLabel = document.getElementById('page-count');
  const removeBtn = document.getElementById('remove-btn');
  const removeInput = document.getElementById('remove-input') as HTMLInputElement;

  fileInput?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    currentFile = file;
    
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await PDFDocument.load(arrayBuffer);
      totalPages = pdf.getPageCount();
      if(pageCountLabel) pageCountLabel.innerText = `Total Pages: ${totalPages}`;
      controls?.classList.remove('hidden');
    } catch (e) {}
  });

  removeBtn?.addEventListener('click', async () => {
    if (!currentFile) return;
    removeBtn.innerHTML = "Processing...";
    try {
      const toRemove = new Set(removeInput.value.split(',').map(n => parseInt(n.trim()) - 1).filter(n => !isNaN(n) && n >= 0 && n < totalPages));
      
      const arrayBuffer = await currentFile.arrayBuffer();
      const srcPdf = await PDFDocument.load(arrayBuffer);
      
      const sortedToRemove = Array.from(toRemove).sort((a,b)=>b-a);
      sortedToRemove.forEach(idx => {
        srcPdf.removePage(idx);
      });
      
      const pdfBytes = await srcPdf.save();
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'cleaned.pdf';
      a.click();
      
      if (window.gtag) window.gtag('event', 'tool_usage', { tool_id: 'remove-pdf-pages' });
    } catch(e) {
      alert("Failed to remove pages");
    } finally {
      removeBtn.innerHTML = "Remove Pages";
    }
  });
</script>
