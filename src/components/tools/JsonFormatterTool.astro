---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="json-formatter-root" class="w-full flex flex-col gap-6">
  <!-- Controls Bar -->
  <div class="flex flex-wrap items-center justify-between gap-4 p-4 bg-canvas-soft border border-hairline rounded-xl shadow-sm">
    <div class="flex items-center gap-3">
      <label for="indent-select" class="text-xs font-bold text-ink uppercase tracking-wider">Tab Size:</label>
      <select id="indent-select" class="bg-canvas border border-hairline rounded px-2 py-1 text-xs text-ink focus:border-link outline-none">
        <option value="2" selected>2 Spaces</option>
        <option value="4">4 Spaces</option>
        <option value="tab">Tabs</option>
      </select>
    </div>
    
    <div class="flex flex-wrap items-center gap-2">
      <button id="beautify-btn" class="px-4 py-2 bg-link hover:bg-link-hover text-white text-xs font-semibold rounded-lg transition-colors shadow-sm">
        Beautify
      </button>
      <button id="minify-btn" class="px-4 py-2 border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold rounded-lg transition-colors">
        Minify
      </button>
      <button id="sample-btn" class="px-4 py-2 border border-hairline text-link hover:bg-link/5 text-xs font-semibold rounded-lg transition-colors">
        Load Sample
      </button>
      <button id="clear-btn" class="px-4 py-2 border border-hairline text-error hover:bg-error/5 text-xs font-semibold rounded-lg transition-colors">
        Clear
      </button>
    </div>
  </div>

  <!-- Status Bar (Validation Feedback) -->
  <div id="validation-status" class="w-full p-4 rounded-xl border flex items-center gap-3 transition-colors duration-200 bg-canvas-soft border-hairline text-body text-sm font-medium">
    <span class="h-2.5 w-2.5 rounded-full bg-mute inline-block" id="status-indicator"></span>
    <span id="status-text">Enter or paste JSON to start validation...</span>
  </div>

  <!-- Editor Workspace -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Input Panel -->
    <div class="flex flex-col gap-2">
      <div class="flex justify-between items-center px-1">
        <label for="json-input" class="text-xs font-bold text-mute uppercase tracking-wider">Input JSON</label>
        <span id="input-lines" class="text-xs font-mono text-mute">0 lines</span>
      </div>
      <textarea 
        id="json-input" 
        class="w-full min-h-[400px] p-4 bg-canvas border border-hairline rounded-xl font-mono text-xs text-ink focus:border-link outline-none leading-relaxed resize-y shadow-inner shadow-sm"
        placeholder='{
  "name": "ImageToolStack",
  "features": ["client-side", "offline-first", "multilingual"],
  "pageCount": 4020,
  "isActive": true
}'
      ></textarea>
    </div>

    <!-- Output Panel -->
    <div class="flex flex-col gap-2">
      <div class="flex justify-between items-center px-1">
        <label for="json-output" class="text-xs font-bold text-mute uppercase tracking-wider">Formatted Output</label>
        <div class="flex gap-2">
          <button id="copy-btn" class="text-[10px] font-semibold text-link bg-link/5 hover:bg-link/10 border border-link/20 px-3 py-1 rounded transition-colors">
            Copy
          </button>
          <button id="download-btn" class="text-[10px] font-semibold text-link bg-link/5 hover:bg-link/10 border border-link/20 px-3 py-1 rounded transition-colors">
            Download .json
          </button>
        </div>
      </div>
      <textarea 
        id="json-output" 
        readonly
        class="w-full min-h-[400px] p-4 bg-canvas-soft border border-hairline rounded-xl font-mono text-xs text-ink leading-relaxed resize-y cursor-text shadow-sm"
        placeholder="Output will be displayed here..."
      ></textarea>
    </div>
  </div>
</div>

<script>
  (function() {
    const inputArea = document.getElementById('json-input') as HTMLTextAreaElement;
    const outputArea = document.getElementById('json-output') as HTMLTextAreaElement;
    
    const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
    const beautifyBtn = document.getElementById('beautify-btn');
    const minifyBtn = document.getElementById('minify-btn');
    const sampleBtn = document.getElementById('sample-btn');
    const clearBtn = document.getElementById('clear-btn');
    const copyBtn = document.getElementById('copy-btn');
    const downloadBtn = document.getElementById('download-btn');
    
    const validationStatus = document.getElementById('validation-status');
    const statusIndicator = document.getElementById('status-indicator');
    const statusText = document.getElementById('status-text');
    const inputLines = document.getElementById('input-lines');

    if (!inputArea || !outputArea) return;

    // Sample JSON Data
    const sampleJson = {
      "id": "imagetoolstack-config",
      "name": "ImageToolStack Developer Utilities",
      "version": "1.0.0",
      "features": {
        "clientSideOnly": true,
        "supportedLocales": ["en", "es", "fr", "de", "pt", "id"],
        "maxFileSizeMb": 50,
        "toolsAvailable": 87
      },
      "buildSettings": {
        "framework": "Astro",
        "outputDirectory": "dist",
        "gzipAssets": true
      },
      "author": {
        "name": "Prit Patel",
        "profile": "https://github.com/Prit-Patel08"
      }
    };

    // Helper to get selected indentation
    function getIndent() {
      const value = indentSelect.value;
      if (value === 'tab') return '\t';
      return parseInt(value, 10);
    }

    // Real-time validation & line count
    inputArea.addEventListener('input', () => {
      const val = inputArea.value.trim();
      
      // Update line count
      const lines = val ? val.split('\n').length : 0;
      inputLines!.textContent = `${lines} line${lines === 1 ? '' : 's'}`;

      if (!val) {
        showStatus('idle', 'Enter or paste JSON to start validation...');
        return;
      }

      try {
        JSON.parse(val);
        showStatus('success', 'Valid JSON format');
      } catch (err: any) {
        showStatus('error', `Invalid JSON: ${err.message}`);
      }
    });

    // Formatting Actions
    beautifyBtn?.addEventListener('click', () => {
      const raw = inputArea.value.trim();
      if (!raw) return;

      trackToolUsage('json-formatter-beautify');

      try {
        const parsed = JSON.parse(raw);
        const indent = getIndent();
        const formatted = JSON.stringify(parsed, null, indent);
        outputArea.value = formatted;
        showStatus('success', 'JSON Beautified Successfully');
      } catch (err: any) {
        showStatus('error', `Format Failed: ${err.message}`);
      }
    });

    minifyBtn?.addEventListener('click', () => {
      const raw = inputArea.value.trim();
      if (!raw) return;

      trackToolUsage('json-formatter-minify');

      try {
        const parsed = JSON.parse(raw);
        const minified = JSON.stringify(parsed);
        outputArea.value = minified;
        showStatus('success', 'JSON Minified Successfully');
      } catch (err: any) {
        showStatus('error', `Minification Failed: ${err.message}`);
      }
    });

    sampleBtn?.addEventListener('click', () => {
      const sampleText = JSON.stringify(sampleJson, null, 2);
      inputArea.value = sampleText;
      inputArea.dispatchEvent(new Event('input'));
      outputArea.value = '';
      trackToolUsage('json-formatter-sample');
    });

    clearBtn?.addEventListener('click', () => {
      inputArea.value = '';
      outputArea.value = '';
      inputArea.dispatchEvent(new Event('input'));
    });

    // Output Clipboard Actions
    copyBtn?.addEventListener('click', () => {
      const text = outputArea.value;
      if (!text) return;

      navigator.clipboard.writeText(text).then(() => {
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = originalText;
        }, 1500);
      });
    });

    // Download JSON file
    downloadBtn?.addEventListener('click', () => {
      const text = outputArea.value;
      if (!text) return;

      const blob = new Blob([text], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `formatted-${Date.now()}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // UI Status Helpers
    function showStatus(type: 'idle' | 'success' | 'error', message: string) {
      if (!validationStatus || !statusIndicator || !statusText) return;

      // Reset classes
      validationStatus.className = 'w-full p-4 rounded-xl border flex items-center gap-3 transition-colors duration-200';
      statusIndicator.className = 'h-2.5 w-2.5 rounded-full inline-block';

      if (type === 'success') {
        validationStatus.classList.add('bg-success/5', 'border-success/20', 'text-success');
        statusIndicator.classList.add('bg-success');
      } else if (type === 'error') {
        validationStatus.classList.add('bg-error/5', 'border-error/20', 'text-error');
        statusIndicator.classList.add('bg-error');
      } else {
        validationStatus.classList.add('bg-canvas-soft', 'border-hairline', 'text-body');
        statusIndicator.classList.add('bg-mute');
      }

      statusText.textContent = message;
    }

    function trackToolUsage(action: string) {
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'tool_usage', {
          'event_category': 'JSON Formatter',
          'event_label': action,
          'value': 1
        });
      }
    }
  })();
</script>
