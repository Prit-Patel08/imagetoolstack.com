---
import BeforeAfterSlider from "./BeforeAfterSlider.astro";
import SizeLinks from "../seo/SizeLinks.astro";

interface Props {
  toolId: string;
  targetKb?: number;
}

const { toolId, targetKb } = Astro.props;
---

<div id="converter-tool-root" class="w-full flex flex-col items-center" data-target-kb={targetKb}>
  {targetKb && (
    <div class="mb-4 bg-primary/10 border border-primary/20 text-primary px-4 py-2 rounded-lg flex items-center gap-2 text-sm font-medium">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
      Targeting: Compress to {targetKb} KB
    </div>
  )}
  <!-- Upload State -->
  <div id="drop-zone-wrapper" class="w-full flex flex-col items-center">
    <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline-strong rounded-xl bg-canvas hover:bg-canvas-soft hover:border-link transition-all cursor-pointer group shadow-sm">
      <div class="mb-6 h-16 w-16 rounded-full bg-canvas-soft-2 flex items-center justify-center text-ink border border-hairline group-hover:bg-link/10 group-hover:border-link/30 group-hover:text-link group-hover:scale-110 transition-all duration-300">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" /></svg>
      </div>
      <div class="text-center">
        <p class="text-xl font-bold text-ink mb-2">Click to upload or drag & drop</p>
        <p class="text-sm text-body">Supports JPG, PNG, WebP, SVG and more.</p>
      </div>
      <input type="file" id="file-input" class="hidden" accept="image/*,.svg" />
    </div>
    
    <div class="mt-6">
      <button id="sample-btn" class="text-xs font-semibold text-link bg-link/5 hover:bg-link/10 border border-link/20 px-4 py-2 rounded-full transition-colors flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        Don't have an image? Try a sample
      </button>
    </div>
  </div>

  <!-- Processing State (hidden initially) -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center justify-center gap-6 h-[300px]">
    <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
    <p class="text-sm font-mono text-mute uppercase tracking-widest">Processing Image…</p>
  </div>

  <!-- Result State (hidden initially) -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    <BeforeAfterSlider />

    <!-- Compressor Settings Slider -->
    <div id="compressor-settings" class="hidden w-full max-w-[400px] bg-canvas-soft border border-hairline p-5 rounded-xl flex flex-col gap-3 shadow-sm">
      <div class="flex justify-between items-center">
        <label for="quality-slider" class="text-sm font-bold text-ink">Compression Quality</label>
        <span id="quality-val" class="text-sm font-mono font-bold text-link">70%</span>
      </div>
      <input type="range" id="quality-slider" min="10" max="100" value="70" class="w-full h-1.5 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-link" />
      <div class="text-[10px] text-mute flex justify-between">
        <span>Max Compression (Smaller File)</span>
        <span>Best Quality (Larger File)</span>
      </div>
    </div>
    
    <div class="flex flex-col items-center gap-2">
      <span id="result-info" class="text-xs font-mono text-mute"></span>
      <a id="download-btn" class="btn-primary">Download Image</a>
      <button id="reset-btn" class="text-xs font-medium text-body hover:text-ink transition-colors mt-2">Process another image</button>
    </div>
  </div>
</div>

<script>
  import { injectBrandingMetadata } from "../../utils/metadata-injector";

  // Scoped to avoid conflicts
  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    const previewImgOrig = document.getElementById('ba-original') as HTMLImageElement;
    const previewImgOpt = document.getElementById('ba-optimized') as HTMLImageElement;
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');
    const resultInfo = document.getElementById('result-info');

    const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
    const qualityVal = document.getElementById('quality-val');
    const settingsContainer = document.getElementById('compressor-settings');

    const toolId = window.location.pathname.split('/').pop() || '';

    let currentImg: HTMLImageElement | null = null;
    let currentFileType = '';
    let currentFileName = '';
    let currentFileSize = 0;

    if (!dropZone || !fileInput) return;

    dropZone.addEventListener('click', () => fileInput.click());
    
    // Sample Button Logic
    const sampleBtn = document.getElementById('sample-btn');
    sampleBtn?.addEventListener('click', async (e) => {
      e.stopPropagation();
      showState('processing');
      try {
        // Fetch a tiny sample 1px white image as fallback if no real URL
        const base64 = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+ip1sAAAAASUVORK5CYII=";
        const res = await fetch(base64);
        const blob = await res.blob();
        const file = new File([blob], "sample-image.png", { type: "image/png" });
        handleFile(file);
      } catch (err) {
        console.error("Failed to load sample", err);
      }
    });

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const files = e.dataTransfer?.files;
      if (files?.length) handleFile(files[0]);
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.length) handleFile(fileInput.files[0]);
    });

    function handleFile(file: File) {
      // Fire Google Analytics Event
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'tool_usage', {
          'event_category': 'Image Tool',
          'event_label': toolId,
          'value': 1
        });
      }

      showState('processing');

      const reader = new FileReader();
      reader.onload = async (e) => {
        const img = new Image();
        img.onload = async () => {
          currentImg = img;
          currentFileType = file.type;
          currentFileName = file.name;
          currentFileSize = file.size;

          // Detect if we should show quality slider
          const isJpg = toolId.includes('to-jpg') || toolId.includes('to-jpeg') || (toolId === 'image-compressor' && file.type !== 'image/png');
          const isWebp = toolId.includes('to-webp');
          const isAvif = toolId.includes('to-avif');
          const isLossy = toolId === 'image-compressor' || isJpg || isWebp || isAvif;

          if (settingsContainer) {
            settingsContainer.classList.toggle('hidden', !isLossy);
          }

          let defaultQuality = 0.9;
          if (toolId === 'image-compressor') {
            defaultQuality = 0.7;
          }
          if (qualitySlider) {
            qualitySlider.value = String(Math.round(defaultQuality * 100));
          }
          if (qualityVal) {
            qualityVal.textContent = `${Math.round(defaultQuality * 100)}%`;
          }

          let processedBlob = await processImage(img, file.type, toolId, defaultQuality);
          if (processedBlob) {
            processedBlob = await injectBrandingMetadata(processedBlob, processedBlob.type);
            const url = URL.createObjectURL(processedBlob);
            previewImgOrig.src = e.target?.result as string;
            previewImgOpt.src = url;
            downloadBtn.href = url;
            downloadBtn.download = `output-${Date.now()}.${getExt(toolId)}`;
            
            const origSize = file.size;
            const optSize = processedBlob.size;
            const pctSavings = Math.round(((origSize - optSize) / origSize) * 100);
            
            if (pctSavings > 0) {
              resultInfo!.innerHTML = `${file.name} (${(origSize / 1024).toFixed(1)} KB) &rarr; <strong>${(optSize / 1024).toFixed(1)} KB</strong> <span class="bg-success/10 text-success text-[10px] font-semibold px-2 py-0.5 rounded ml-2">-${pctSavings}% Saved</span>`;
            } else {
              resultInfo!.innerHTML = `${file.name} (${(origSize / 1024).toFixed(1)} KB) &rarr; <strong>${(optSize / 1024).toFixed(1)} KB</strong>`;
            }
            showState('result');
          }
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    async function updateQuality(quality: number) {
      if (!currentImg) return;
      
      let processedBlob = await processImage(currentImg, currentFileType, toolId, quality);
      if (processedBlob) {
        processedBlob = await injectBrandingMetadata(processedBlob, processedBlob.type);
        const url = URL.createObjectURL(processedBlob);
        
        if (previewImgOpt.src.startsWith('blob:')) {
          URL.revokeObjectURL(previewImgOpt.src);
        }
        
        previewImgOpt.src = url;
        downloadBtn.href = url;
        
        const origSize = currentFileSize;
        const optSize = processedBlob.size;
        const pctSavings = Math.round(((origSize - optSize) / origSize) * 100);
        
        if (pctSavings > 0) {
          resultInfo!.innerHTML = `${currentFileName} (${(origSize / 1024).toFixed(1)} KB) &rarr; <strong>${(optSize / 1024).toFixed(1)} KB</strong> <span class="bg-success/10 text-success text-[10px] font-semibold px-2 py-0.5 rounded ml-2">-${pctSavings}% Saved</span>`;
        } else {
          resultInfo!.innerHTML = `${currentFileName} (${(origSize / 1024).toFixed(1)} KB) &rarr; <strong>${(optSize / 1024).toFixed(1)} KB</strong>`;
        }

        // Force slider width resync
        window.dispatchEvent(new Event('resize'));
      }
    }

    let debounceTimer: any;
    qualitySlider?.addEventListener('input', () => {
      const val = qualitySlider.value;
      if (qualityVal) {
        qualityVal.textContent = `${val}%`;
      }
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        updateQuality(parseInt(val) / 100);
      }, 100);
    });

    async function processImage(img: HTMLImageElement, originalType: string, id: string, customQuality?: number): Promise<Blob | null> {
      const canvas = document.createElement('canvas');
      canvas.width = img.width;
      canvas.height = img.height;
      const ctx = canvas.getContext('2d');
      if (!ctx) return null;

      ctx.drawImage(img, 0, 0);

      let targetType = originalType;
      let quality = customQuality !== undefined ? customQuality : 0.9;

      const isJpg = id.includes('to-jpg') || id.includes('to-jpeg') || (id === 'image-compressor' && originalType !== 'image/png');
      const isWebp = id.includes('to-webp');
      const isAvif = id.includes('to-avif');

      if (id === 'image-compressor') {
        targetType = originalType === 'image/png' ? 'image/png' : 'image/jpeg';
        if (customQuality === undefined) {
          quality = 0.7;
        }
      } else if (isJpg) {
        targetType = 'image/jpeg';
        // Fill background white for transparent PNG to JPG
        ctx.globalCompositeOperation = 'destination-over';
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      } else if (isWebp) {
        targetType = 'image/webp';
      } else if (isAvif) {
        targetType = 'image/avif';
      } else if (id.includes('to-png')) {
        targetType = 'image/png';
      }

      return new Promise(resolve => {
        canvas.toBlob(blob => resolve(blob), targetType, quality);
      });
    }

    function showState(state: 'upload' | 'processing' | 'result') {
      const wrapper = document.getElementById('drop-zone-wrapper');
      wrapper?.classList.toggle('hidden', state !== 'upload');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }

    function getExt(id: string) {
      if (id.includes('to-jpg')) return 'jpg';
      if (id.includes('to-png')) return 'png';
      if (id.includes('to-webp')) return 'webp';
      if (id === 'image-compressor') return 'jpg'; // simplified fallback
      return 'png';
    }

    resetBtn?.addEventListener('click', () => {
      fileInput.value = '';
      currentImg = null;
      showState('upload');
    });
  })();
</script>

{toolId === 'image-compressor' && <SizeLinks />}
