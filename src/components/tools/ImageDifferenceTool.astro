---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="diff-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 transition-colors">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
    </div>
    <div class="text-center w-full max-w-sm">
      <p class="text-base font-semibold text-ink mb-4">Upload two images to compare</p>
      
      <div class="flex gap-4 w-full">
        <label class="flex-1 p-3 border border-hairline rounded cursor-pointer hover:bg-canvas transition-colors bg-canvas text-sm text-ink text-center">
          Upload Image 1
          <input type="file" id="file-input-1" class="hidden" accept="image/jpeg,image/png,image/webp" />
        </label>
        <label class="flex-1 p-3 border border-hairline rounded cursor-pointer hover:bg-canvas transition-colors bg-canvas text-sm text-ink text-center">
          Upload Image 2
          <input type="file" id="file-input-2" class="hidden" accept="image/jpeg,image/png,image/webp" />
        </label>
      </div>
      
      <p id="upload-status" class="mt-4 text-sm text-body min-h-[20px]"></p>
    </div>
  </div>

  <!-- Settings State -->
  <div id="settings-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    
    <div class="w-full max-w-2xl bg-canvas-soft border border-hairline rounded-xl p-4 flex flex-col items-center justify-center overflow-hidden min-h-[300px]">
      <canvas id="preview-canvas" class="max-w-full max-h-[500px] object-contain shadow-sm bg-[url('/checker.svg')]"></canvas>
    </div>

    <div class="w-full max-w-2xl bg-canvas border border-hairline rounded-xl p-6 shadow-sm text-center">
      <h3 class="text-lg font-semibold text-ink mb-2">Difference Map Generated</h3>
      <p class="text-sm text-body mb-6">Pixels that are perfectly identical are black. Differences are highlighted in color.</p>
      
      <div class="mt-8 flex gap-4">
        <button id="download-btn" class="flex-1 btn-primary">Download Diff Image</button>
        <button id="cancel-btn" class="px-6 py-2 border border-hairline rounded text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft transition-colors">Start Over</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const fileInput1 = document.getElementById('file-input-1') as HTMLInputElement;
    const fileInput2 = document.getElementById('file-input-2') as HTMLInputElement;
    const uploadStatus = document.getElementById('upload-status');
    
    const dropZone = document.getElementById('drop-zone');
    const settingsZone = document.getElementById('settings-zone');
    
    const previewCanvas = document.getElementById('preview-canvas') as HTMLCanvasElement;
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const cancelBtn = document.getElementById('cancel-btn');

    let img1: HTMLImageElement | null = null;
    let img2: HTMLImageElement | null = null;

    fileInput1?.addEventListener('change', () => handleFile(fileInput1, 1));
    fileInput2?.addEventListener('change', () => handleFile(fileInput2, 2));

    function handleFile(input: HTMLInputElement, num: number) {
      const file = input.files?.[0];
      if (!file) return;
      
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          if (num === 1) img1 = img;
          if (num === 2) img2 = img;
          updateStatus();
          checkReady();
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    function updateStatus() {
      if (!uploadStatus) return;
      if (img1 && !img2) uploadStatus.textContent = "Image 1 loaded. Waiting for Image 2...";
      else if (!img1 && img2) uploadStatus.textContent = "Image 2 loaded. Waiting for Image 1...";
      else if (img1 && img2) uploadStatus.textContent = "Processing difference...";
    }

    function checkReady() {
      if (img1 && img2) {
        setTimeout(renderCanvas, 100);
      }
    }

    function renderCanvas() {
      if (!img1 || !img2 || !previewCanvas) return;
      
      // Use dimensions of the first image
      previewCanvas.width = img1.width;
      previewCanvas.height = img1.height;
      
      const ctx = previewCanvas.getContext('2d');
      if (!ctx) return;
      
      // Draw first image
      ctx.drawImage(img1, 0, 0);
      
      // Set blend mode to difference
      ctx.globalCompositeOperation = 'difference';
      
      // Draw second image over it
      // Differences will appear as colors, identical pixels become black
      ctx.drawImage(img2, 0, 0, img1.width, img1.height);
      
      // Reset composite operation
      ctx.globalCompositeOperation = 'source-over';
      
      dropZone?.classList.add('hidden');
      settingsZone?.classList.remove('hidden');
    }

    downloadBtn?.addEventListener('click', () => {
      if (!previewCanvas) return;
      const dataUrl = previewCanvas.toDataURL('image/png');
      const a = document.createElement('a');
      a.href = dataUrl;
      a.download = `image-difference.png`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    });

    cancelBtn?.addEventListener('click', () => {
      if (fileInput1) fileInput1.value = '';
      if (fileInput2) fileInput2.value = '';
      img1 = null;
      img2 = null;
      if (uploadStatus) uploadStatus.textContent = '';
      settingsZone?.classList.add('hidden');
      dropZone?.classList.remove('hidden');
    });
  })();
</script>
