---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="color-picker-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 transition-colors cursor-pointer group">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline group-hover:border-hairline-strong transition-colors">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
    </div>
    <div class="text-center">
      <p class="text-base font-semibold text-ink">Select image to extract colors</p>
      <p class="mt-1 text-sm text-body">JPG, PNG, WebP, SVG supported.</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="image/*" />
  </div>

  <!-- Edit/Result State -->
  <div id="edit-zone" class="hidden w-full flex flex-col lg:flex-row gap-8 py-8">
    <!-- Canvas Area -->
    <div class="flex-1">
      <div class="relative w-full overflow-hidden rounded-md border border-hairline bg-canvas p-4 flex items-center justify-center bg-[url('/checker.svg')] bg-repeat cursor-crosshair">
        <canvas id="color-canvas" class="max-w-full max-h-[500px] shadow-sm rounded border border-hairline"></canvas>
      </div>
      <p class="text-xs text-mute mt-3 text-center">Click anywhere on the image to lock a color.</p>
    </div>
    
    <!-- Info Area -->
    <div class="w-full lg:w-80 flex flex-col gap-6">
      <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-sm">
        <h3 class="text-lg font-semibold text-ink mb-4">Selected Color</h3>
        
        <div class="flex items-center gap-4 mb-6">
          <div id="color-preview" class="w-16 h-16 rounded-full border border-hairline shadow-inner bg-transparent"></div>
          <div class="flex flex-col">
            <span id="color-hex-large" class="text-xl font-bold font-mono text-ink">#------</span>
            <span class="text-xs text-mute">Hover to preview, click to select</span>
          </div>
        </div>

        <div class="space-y-4 mb-6">
          <div>
            <div class="flex justify-between mb-1">
              <label class="text-xs font-semibold text-mute uppercase tracking-wider">HEX</label>
              <button id="copy-hex" class="text-xs text-link hover:underline">Copy</button>
            </div>
            <input type="text" id="hex-input" readonly class="w-full bg-canvas-soft border border-hairline rounded px-3 py-2 text-sm font-mono text-ink outline-none" value="#------" />
          </div>

          <div>
            <div class="flex justify-between mb-1">
              <label class="text-xs font-semibold text-mute uppercase tracking-wider">RGB</label>
              <button id="copy-rgb" class="text-xs text-link hover:underline">Copy</button>
            </div>
            <input type="text" id="rgb-input" readonly class="w-full bg-canvas-soft border border-hairline rounded px-3 py-2 text-sm font-mono text-ink outline-none" value="rgb(-, -, -)" />
          </div>

          <div>
            <div class="flex justify-between mb-1">
              <label class="text-xs font-semibold text-mute uppercase tracking-wider">HSL</label>
              <button id="copy-hsl" class="text-xs text-link hover:underline">Copy</button>
            </div>
            <input type="text" id="hsl-input" readonly class="w-full bg-canvas-soft border border-hairline rounded px-3 py-2 text-sm font-mono text-ink outline-none" value="hsl(-, -, -)" />
          </div>
        </div>
        
        <button id="reset-btn" class="w-full text-xs font-medium text-body hover:text-ink transition-colors py-2 border border-transparent hover:border-hairline rounded">Choose different image</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const editZone = document.getElementById('edit-zone');
    const canvas = document.getElementById('color-canvas') as HTMLCanvasElement;
    
    const colorPreview = document.getElementById('color-preview');
    const hexLarge = document.getElementById('color-hex-large');
    const hexInput = document.getElementById('hex-input') as HTMLInputElement;
    const rgbInput = document.getElementById('rgb-input') as HTMLInputElement;
    const hslInput = document.getElementById('hsl-input') as HTMLInputElement;

    const copyHex = document.getElementById('copy-hex');
    const copyRgb = document.getElementById('copy-rgb');
    const copyHsl = document.getElementById('copy-hsl');
    const resetBtn = document.getElementById('reset-btn');

    let ctx: CanvasRenderingContext2D | null = null;
    let lockedColor: { r: number, g: number, b: number } | null = null;
    let isImageLoaded = false;

    if (!dropZone || !fileInput || !canvas) return;

    ctx = canvas.getContext('2d', { willReadFrequently: true });

    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault(); e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const files = e.dataTransfer?.files;
      if (files?.length) handleFile(files[0]);
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.length) handleFile(fileInput.files[0]);
    });

    function handleFile(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          // Calculate display size vs actual size to ensure 1:1 pixel mapping
          const MAX_WIDTH = 800;
          let width = img.width;
          let height = img.height;
          
          if (width > MAX_WIDTH) {
            const ratio = MAX_WIDTH / width;
            width = MAX_WIDTH;
            height = height * ratio;
          }

          canvas.width = width;
          canvas.height = height;
          ctx?.drawImage(img, 0, 0, width, height);
          
          isImageLoaded = true;
          lockedColor = null;
          updateUI(255, 255, 255, true); // Reset UI
          showState('edit');
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    function getPixelColor(e: MouseEvent) {
      if (!ctx || !isImageLoaded) return null;
      
      const rect = canvas.getBoundingClientRect();
      // Calculate accurate scaling factor
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      
      const x = (e.clientX - rect.left) * scaleX;
      const y = (e.clientY - rect.top) * scaleY;
      
      const pixel = ctx.getImageData(x, y, 1, 1).data;
      return { r: pixel[0], g: pixel[1], b: pixel[2], a: pixel[3] };
    }

    canvas.addEventListener('mousemove', (e) => {
      if (lockedColor) return;
      const color = getPixelColor(e);
      if (color && color.a > 0) { // Don't pick completely transparent pixels
        updateUI(color.r, color.g, color.b);
      }
    });

    canvas.addEventListener('click', (e) => {
      const color = getPixelColor(e);
      if (color && color.a > 0) {
        lockedColor = { r: color.r, g: color.g, b: color.b };
        updateUI(color.r, color.g, color.b);
        // Visual feedback
        canvas.style.cursor = 'crosshair';
      }
    });

    function updateUI(r: number, g: number, b: number, reset = false) {
      if (!colorPreview || !hexLarge || !hexInput || !rgbInput || !hslInput) return;
      
      if (reset) {
        colorPreview.style.backgroundColor = 'transparent';
        hexLarge.textContent = '#------';
        hexInput.value = '#------';
        rgbInput.value = 'rgb(-, -, -)';
        hslInput.value = 'hsl(-, -, -)';
        return;
      }

      const hex = rgbToHex(r, g, b);
      const rgb = `rgb(${r}, ${g}, ${b})`;
      const hslData = rgbToHsl(r, g, b);
      const hsl = `hsl(${hslData[0]}, ${hslData[1]}%, ${hslData[2]}%)`;

      colorPreview.style.backgroundColor = hex;
      hexLarge.textContent = hex;
      hexInput.value = hex;
      rgbInput.value = rgb;
      hslInput.value = hsl;
    }

    function copyToClipboard(btn: HTMLElement | null, input: HTMLInputElement) {
      if (!btn) return;
      navigator.clipboard.writeText(input.value).then(() => {
        const originalText = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = originalText; }, 2000);
      });
    }

    copyHex?.addEventListener('click', () => copyToClipboard(copyHex, hexInput));
    copyRgb?.addEventListener('click', () => copyToClipboard(copyRgb, rgbInput));
    copyHsl?.addEventListener('click', () => copyToClipboard(copyHsl, hslInput));

    function rgbToHex(r: number, g: number, b: number) {
      return "#" + (1 << 24 | r << 16 | g << 8 | b).toString(16).slice(1).toUpperCase();
    }

    function rgbToHsl(r: number, g: number, b: number) {
      r /= 255; g /= 255; b /= 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      let h = 0, s = 0, l = (max + min) / 2;

      if (max !== min) {
        const d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        switch (max) {
          case r: h = (g - b) / d + (g < b ? 6 : 0); break;
          case g: h = (b - r) / d + 2; break;
          case b: h = (r - g) / d + 4; break;
        }
        h /= 6;
      }
      return [Math.round(h * 360), Math.round(s * 100), Math.round(l * 100)];
    }

    function showState(state: 'upload' | 'edit') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      editZone?.classList.toggle('hidden', state !== 'edit');
    }

    resetBtn?.addEventListener('click', () => {
      fileInput.value = '';
      isImageLoaded = false;
      lockedColor = null;
      showState('upload');
    });
  })();
</script>
