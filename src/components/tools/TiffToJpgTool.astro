---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="tiff-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 transition-colors cursor-pointer group">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline group-hover:border-hairline-strong transition-colors">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
    </div>
    <div class="text-center">
      <p class="text-base font-semibold text-ink">Select a TIFF image</p>
      <p class="mt-1 text-sm text-body">Supports .tiff and .tif files.</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept="image/tiff, .tiff, .tif" />
  </div>

  <!-- Settings State -->
  <div id="settings-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    
    <div class="w-full max-w-xl bg-canvas border border-hairline rounded-xl p-6 shadow-sm">
      <div class="flex items-center justify-between mb-6 pb-4 border-b border-hairline">
        <h3 class="text-lg font-semibold text-ink">File Selected</h3>
        <span id="file-name-badge" class="text-xs font-bold text-mute bg-canvas-soft px-2 py-1 rounded border border-hairline truncate max-w-[200px]">image.tiff</span>
      </div>
      
      <div class="space-y-6">
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-sm font-medium text-ink">JPG Quality</label>
            <span id="quality-val" class="text-sm text-body">90%</span>
          </div>
          <input type="range" id="quality-slider" min="10" max="100" value="90" class="w-full accent-link cursor-pointer">
        </div>
      </div>

      <div class="mt-8 flex gap-4">
        <button id="start-btn" class="flex-1 btn-primary">Convert to JPG</button>
        <button id="cancel-btn" class="px-6 py-2 border border-hairline rounded text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft transition-colors">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Processing State -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center gap-6 py-12">
    <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
    <div class="w-full max-w-md text-center">
      <p id="progress-text" class="text-sm font-mono text-mute uppercase tracking-widest">Decoding TIFF Data...</p>
    </div>
  </div>

  <!-- Result State -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-12">
    <div class="h-16 w-16 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <div class="text-center">
      <h3 class="text-xl font-bold text-ink">Conversion Complete!</h3>
      <p class="text-sm text-body mt-2">Your image is ready.</p>
    </div>
    
    <div class="flex flex-col items-center gap-4 mt-4 w-full max-w-xs">
      <a id="download-btn" class="w-full btn-primary text-center cursor-pointer">Download JPG</a>
      <button id="reset-btn" class="text-sm font-medium text-link hover:underline">Convert another image</button>
    </div>
  </div>
</div>

<script>
  import UTIF from 'utif';

  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const settingsZone = document.getElementById('settings-zone');
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    
    const fileNameBadge = document.getElementById('file-name-badge');
    const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
    const qualityVal = document.getElementById('quality-val');
    
    const startBtn = document.getElementById('start-btn');
    const cancelBtn = document.getElementById('cancel-btn');
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');
    const progressText = document.getElementById('progress-text');

    let originalFile: File | null = null;

    if (!dropZone || !fileInput) return;

    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault(); e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const file = e.dataTransfer?.files?.[0];
      if (file) handleFile(file);
    });

    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleFile(file);
    });

    qualitySlider?.addEventListener('input', () => {
      if (qualityVal) qualityVal.textContent = `${qualitySlider.value}%`;
    });

    function handleFile(file: File) {
      originalFile = file;
      fileNameBadge!.textContent = file.name;
      showState('settings');
    }

    startBtn?.addEventListener('click', async () => {
      if (!originalFile) return;
      showState('processing');
      
      try {
        const arrayBuffer = await originalFile.arrayBuffer();
        
        if (progressText) progressText.textContent = 'Decoding TIFF...';
        await new Promise(r => setTimeout(r, 50));
        
        const ifds = UTIF.decode(arrayBuffer);
        UTIF.decodeImage(arrayBuffer, ifds[0]);
        const rgba = UTIF.toRGBA8(ifds[0]);
        
        if (progressText) progressText.textContent = 'Rendering Image...';
        await new Promise(r => setTimeout(r, 50));
        
        const canvas = document.createElement('canvas');
        canvas.width = ifds[0].width;
        canvas.height = ifds[0].height;
        const ctx = canvas.getContext('2d');
        
        if (!ctx) throw new Error("Could not create canvas context");
        
        const imageData = ctx.createImageData(canvas.width, canvas.height);
        for (let i = 0; i < rgba.length; i++) {
            imageData.data[i] = rgba[i];
        }
        
        ctx.putImageData(imageData, 0, 0);
        
        const quality = parseInt(qualitySlider.value, 10) / 100;
        const dataUrl = canvas.toDataURL('image/jpeg', quality);
        
        const baseName = originalFile.name.substring(0, originalFile.name.lastIndexOf('.')) || originalFile.name;
        
        downloadBtn.href = dataUrl;
        downloadBtn.download = `${baseName}.jpg`;
        
        showState('result');
        
      } catch (e) {
        console.error('TIFF error', e);
        alert('Could not decode this TIFF file. It may be corrupted or unsupported.');
        showState('settings');
      }
    });

    cancelBtn?.addEventListener('click', resetTool);
    resetBtn?.addEventListener('click', resetTool);

    function resetTool() {
      fileInput.value = '';
      originalFile = null;
      showState('upload');
    }

    function showState(state: 'upload' | 'settings' | 'processing' | 'result') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      settingsZone?.classList.toggle('hidden', state !== 'settings');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }
  })();
</script>
