---
interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
---

<div id="heic-tool-root" class="w-full flex flex-col items-center">
  <!-- Upload State -->
  <div id="drop-zone" class="w-full min-h-[300px] flex flex-col items-center justify-center p-8 border-2 border-dashed border-hairline rounded-md bg-canvas-soft/30 hover:bg-canvas-soft/50 transition-colors cursor-pointer group">
    <div class="mb-4 h-12 w-12 rounded-full bg-canvas flex items-center justify-center text-ink border border-hairline group-hover:border-hairline-strong transition-colors">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
    </div>
    <div class="text-center">
      <p class="text-base font-semibold text-ink">Select HEIC/HEIF photo to convert</p>
      <p class="mt-1 text-sm text-body">Processed directly in your browser.</p>
    </div>
    <input type="file" id="file-input" class="hidden" accept=".heic,.heif,image/heic,image/heif" />
  </div>

  <!-- Processing State -->
  <div id="processing-zone" class="hidden w-full flex flex-col items-center gap-6 py-12">
    <div class="animate-spin h-8 w-8 border-2 border-link border-t-transparent rounded-full"></div>
    <p class="text-sm font-mono text-mute uppercase tracking-widest">Decoding HEIC Format…</p>
    <p class="text-xs text-mute mt-2">This may take a few seconds depending on file size.</p>
  </div>

  <!-- Result State -->
  <div id="result-zone" class="hidden w-full flex flex-col items-center gap-8 py-8">
    <div class="relative max-h-[300px] overflow-hidden rounded-md border border-hairline bg-canvas p-4">
      <img id="preview-img" class="max-h-[300px] w-auto object-contain" />
    </div>
    
    <div class="flex flex-col items-center gap-2">
      <span id="result-info" class="text-xs font-mono text-mute"></span>
      <a id="download-btn" class="btn-primary">Download JPG</a>
      <button id="reset-btn" class="text-xs font-medium text-body hover:text-ink transition-colors mt-2">Convert another photo</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const processingZone = document.getElementById('processing-zone');
    const resultZone = document.getElementById('result-zone');
    const previewImg = document.getElementById('preview-img') as HTMLImageElement;
    const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
    const resetBtn = document.getElementById('reset-btn');
    const resultInfo = document.getElementById('result-info');

    if (!dropZone || !fileInput) return;

    dropZone.addEventListener('click', () => fileInput.click());
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, e => {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const files = e.dataTransfer?.files;
      if (files?.length) handleFile(files[0]);
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files?.length) handleFile(fileInput.files[0]);
    });

    async function handleFile(file: File) {
      showState('processing');

      try {
        // Dynamic import to keep initial bundle size small
        const heic2any = (await import('heic2any')).default;
        
        const conversionResult = await heic2any({
          blob: file,
          toType: "image/jpeg",
          quality: 0.92
        });

        // heic2any can return an array if the HEIC contains multiple images
        const blob = Array.isArray(conversionResult) ? conversionResult[0] : conversionResult;
        
        const url = URL.createObjectURL(blob);
        previewImg.src = url;
        downloadBtn.href = url;
        
        // Use original filename but swap extension
        const baseName = file.name.replace(/\.(heic|heif)$/i, '');
        downloadBtn.download = `${baseName}.jpg`;
        
        resultInfo!.textContent = `${file.name} → ${(blob.size / 1024).toFixed(1)} KB`;
        showState('result');

      } catch (err) {
        console.error("HEIC Conversion failed", err);
        alert("Failed to decode HEIC file. Please try another image.");
        showState('upload');
      }
    }

    function showState(state: 'upload' | 'processing' | 'result') {
      dropZone?.classList.toggle('hidden', state !== 'upload');
      processingZone?.classList.toggle('hidden', state !== 'processing');
      resultZone?.classList.toggle('hidden', state !== 'result');
    }

    resetBtn?.addEventListener('click', () => {
      fileInput.value = '';
      showState('upload');
    });
  })();
</script>
