---
import { getTranslations, getLocalizedPath } from "../utils/i18n";
const locale = Astro.currentLocale || 'en';
const t = getTranslations(locale);
const year = new Date().getFullYear();

// Locale-specific footer text helpers
const showAll = locale === 'es' ? 'Ver todas las herramientas →' :
                locale === 'fr' ? 'Voir tous les outils →' :
                locale === 'de' ? 'Alle Werkzeuge anzeigen →' :
                locale === 'pt' ? 'Mostrar todas as ferramentas →' :
                locale === 'id' ? 'Tampilkan semua alat →' : 'Show all tools →';

const viewAll = locale === 'es' ? 'Ver todas las comparaciones →' :
                locale === 'fr' ? 'Voir toutes les comparaisons →' :
                locale === 'de' ? 'Alle Vergleiche anzeigen →' :
                locale === 'pt' ? 'Ver todas as comparações →' :
                locale === 'id' ? 'Lihat semua perbandingan →' : 'View all comparisons →';

const builtFor = locale === 'es' ? 'Creado para el rendimiento y la privacidad.' :
                 locale === 'fr' ? 'Conçu pour la performance et la confidentialité.' :
                 locale === 'de' ? 'Gebaut für Leistung und Datenschutz.' :
                 locale === 'pt' ? 'Construído para desempenho e privacidade.' :
                 locale === 'id' ? 'Dibuat untuk performa dan privasi.' : 'Built for performance and privacy.';
---
<footer class="mt-auto border-t border-hairline bg-canvas py-16 lg:py-24">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-12 sm:grid-cols-3 lg:grid-cols-6">
      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{t.nav.convert}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/tools/png-to-jpg", locale)} class="text-sm text-body hover:text-ink transition-colors">PNG to JPG Converter</a></li>
          <li><a href={getLocalizedPath("/tools/jpg-to-png", locale)} class="text-sm text-body hover:text-ink transition-colors">JPG to PNG Converter</a></li>
          <li><a href={getLocalizedPath("/tools/webp-to-png", locale)} class="text-sm text-body hover:text-ink transition-colors">WebP to PNG Converter</a></li>
          <li><a href={getLocalizedPath("/category/conversion", locale)} class="text-sm font-medium text-link hover:opacity-80 transition-opacity">{showAll}</a></li>
        </ul>
      </div>
      
      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{t.nav.edit}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/tools/image-compressor", locale)} class="text-sm text-body hover:text-ink transition-colors">Compressor</a></li>
          <li><a href={getLocalizedPath("/tools/image-resizer", locale)} class="text-sm text-body hover:text-ink transition-colors">Resizer</a></li>
          <li><a href={getLocalizedPath("/tools/crop-image", locale)} class="text-sm text-body hover:text-ink transition-colors">Crop Image</a></li>
          <li><a href={getLocalizedPath("/category/optimization", locale)} class="text-sm font-medium text-link hover:opacity-80 transition-opacity">{showAll}</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{t.nav.tools}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/tools/color-picker", locale)} class="text-sm text-body hover:text-ink transition-colors">Color Picker</a></li>
          <li><a href={getLocalizedPath("/tools/metadata-viewer", locale)} class="text-sm text-body hover:text-ink transition-colors">Metadata Viewer</a></li>
          <li><a href={getLocalizedPath("/tools/image-to-base64", locale)} class="text-sm text-body hover:text-ink transition-colors">Image to Base64</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{locale === 'es' ? 'Hora y Fecha' : locale === 'fr' ? 'Heure & Date' : locale === 'de' ? 'Zeit & Datum' : locale === 'pt' ? 'Hora e Data' : locale === 'id' ? 'Waktu & Tanggal' : 'Time & Date'}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/tools/unix-timestamp", locale)} class="text-sm text-body hover:text-ink transition-colors">{locale === 'es' ? 'Conversor Unix' : locale === 'fr' ? 'Convertisseur Unix' : locale === 'de' ? 'Unix-Timestamp' : locale === 'pt' ? 'Conversor Unix' : locale === 'id' ? 'Konverter Unix' : 'Unix Timestamp'}</a></li>
          <li><a href={getLocalizedPath("/tools/timezone-converter", locale)} class="text-sm text-body hover:text-ink transition-colors">{locale === 'es' ? 'Conversor Zona Horaria' : locale === 'fr' ? 'Convertisseur Fuseau' : locale === 'de' ? 'Zeitzonen-Konverter' : locale === 'pt' ? 'Conversor de Fuso' : locale === 'id' ? 'Konverter Zona Waktu' : 'Time Zone Converter'}</a></li>
          <li><a href={getLocalizedPath("/tools/date-calculator", locale)} class="text-sm text-body hover:text-ink transition-colors">{locale === 'es' ? 'Calculadora de Fecha' : locale === 'fr' ? 'Calculateur de Date' : locale === 'de' ? 'Datumsrechner' : locale === 'pt' ? 'Calculadora de Data' : locale === 'id' ? 'Kalkulator Tanggal' : 'Date Calculator'}</a></li>
          <li><a href={getLocalizedPath("/tools/age-calculator", locale)} class="text-sm text-body hover:text-ink transition-colors">{locale === 'es' ? 'Calculadora de Edad' : locale === 'fr' ? 'Calculateur d\'Âge' : locale === 'de' ? 'Altersrechner' : locale === 'pt' ? 'Calculadora de Idade' : locale === 'id' ? 'Kalkulator Usia' : 'Age Calculator'}</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{t.nav.compare}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/compare/png-vs-jpg", locale)} class="text-sm text-body hover:text-ink transition-colors">PNG vs JPG</a></li>
          <li><a href={getLocalizedPath("/compare/webp-vs-png", locale)} class="text-sm text-body hover:text-ink transition-colors">WebP vs PNG</a></li>
          <li><a href={getLocalizedPath("/compare/avif-vs-webp", locale)} class="text-sm text-body hover:text-ink transition-colors">AVIF vs WebP</a></li>
          <li><a href={getLocalizedPath("/compare", locale)} class="text-sm font-medium text-link hover:opacity-80 transition-opacity">{viewAll}</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute">{t.footer.legal}</span>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalizedPath("/articles", locale)} class="text-sm text-body hover:text-ink transition-colors">Articles & Guides</a></li>
          <li><a href={getLocalizedPath("/about", locale)} class="text-sm text-body hover:text-ink transition-colors">{t.footer.about}</a></li>
          <li><a href={getLocalizedPath("/privacy", locale)} class="text-sm text-body hover:text-ink transition-colors">{t.footer.privacy}</a></li>
          <li><a href={getLocalizedPath("/terms", locale)} class="text-sm text-body hover:text-ink transition-colors">{t.footer.terms}</a></li>
          <li><a href={getLocalizedPath("/contact", locale)} class="text-sm text-body hover:text-ink transition-colors">{t.footer.contact}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-hairline pt-8 md:flex-row">
      <div class="flex items-center gap-4">
        <img src="/favicon.svg" alt="Image Tool Stack Logo" class="h-5 w-5" />
        <span class="text-xs text-mute">&copy; {year} Image Tool Stack. {builtFor}</span>
      </div>
      
      <div class="flex items-center gap-6">
        <a href="https://x.com/prit_08" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-ink transition-colors">
          <span class="sr-only">X (formerly Twitter)</span>
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
