---
interface Props {
  source: string;
  is404?: boolean;
}

const { source, is404 = false } = Astro.props;
---

<section class="w-full my-8">
  <div class="relative overflow-hidden rounded-2xl border border-hairline bg-canvas-soft p-8 sm:p-10 transition-all hover:border-link/30 hover:shadow-lg">
    <!-- Subtle gradient background -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-link/5 to-transparent opacity-50"></div>
    
    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex-1 space-y-4 text-center md:text-left">
        <div class="inline-flex items-center gap-1.5 rounded-full border border-hairline bg-canvas px-2.5 py-1 text-[10px] font-mono uppercase tracking-widest text-mute">
          <span>✨ Community Driven</span>
        </div>
        
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink">
          {is404 ? "Need a tool that doesn't exist yet?" : "Can't Find the Image Tool You Need?"}
        </h2>
        
        <p class="text-body max-w-xl leading-relaxed">
          {is404 
            ? "Request it and we'll consider adding it to our suite of private, browser-based tools." 
            : "We're constantly adding new image tools. Tell us what you're looking for and we'll prioritize the most requested features."}
        </p>
        
        <p class="text-xs text-mute font-medium">
          Most requested tools are prioritized for development.
        </p>
      </div>

      <div class="shrink-0 flex flex-col items-center md:items-end gap-3">
        <a 
          href="https://tally.so/r/MeMMXk" 
          target="_blank" 
          rel="noopener noreferrer"
          class="request-tool-btn group inline-flex h-12 items-center justify-center gap-2 rounded-lg bg-ink px-6 text-sm font-medium text-on-primary shadow-sm transition-all hover:bg-ink/90 hover:ring-2 hover:ring-ink/20 focus:outline-none focus:ring-2 focus:ring-link focus:ring-offset-2"
          data-source={source}
          aria-label="Request a Tool in a new tab"
        >
          <span>Request a Tool</span>
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7" />
          </svg>
        </a>
        <span class="text-[10px] text-mute transition-opacity opacity-0" id={`request-thanks-${source}`}>Help us decide what to build next!</span>
      </div>
    </div>
  </div>
</section>

<script>
  // Setup Google Analytics tracking and success state
  function setupRequestButtons() {
    const buttons = document.querySelectorAll('.request-tool-btn');
    
    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        const source = button.getAttribute('data-source') || 'unknown';
        
        // Google Analytics Event
        if (typeof window !== 'undefined' && (window as any).gtag) {
          (window as any).gtag('event', 'request_tool_click', {
            'source': source
          });
        }
        
        // Show lightweight success state
        const thanksMsg = document.getElementById(`request-thanks-${source}`);
        if (thanksMsg) {
          thanksMsg.classList.remove('opacity-0');
          thanksMsg.classList.add('opacity-100');
          
          setTimeout(() => {
            thanksMsg.classList.remove('opacity-100');
            thanksMsg.classList.add('opacity-0');
          }, 4000);
        }
      });
    });
  }

  // Astro view transitions support
  document.addEventListener('astro:page-load', setupRequestButtons);
  // Initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupRequestButtons);
  } else {
    setupRequestButtons();
  }
</script>
