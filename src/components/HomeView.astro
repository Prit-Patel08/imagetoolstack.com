<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const toolCards = document.querySelectorAll('.tool-card');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset active states
        tabBtns.forEach(b => {
          b.classList.remove('text-link', 'border-link', 'active', 'font-semibold');
          b.classList.add('text-mute', 'border-transparent', 'font-medium');
        });
        
        // Set new active state
        btn.classList.add('text-link', 'border-link', 'active', 'font-semibold');
        btn.classList.remove('text-mute', 'border-transparent', 'font-medium');

        const target = btn.getAttribute('data-target');

        toolCards.forEach(card => {
          if (target === 'all' || card.getAttribute('data-category') === target) {
            // we use flex so we don't break the flex layout
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
