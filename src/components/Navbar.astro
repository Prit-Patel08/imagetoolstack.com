---
import toolsData from "../data/tools.json";
import comparisonsData from "../data/comparisons.json";
import { getTranslations, getLocalizedPath, translateTool } from "../utils/i18n";

const locale = Astro.currentLocale || 'en';
const t = getTranslations(locale);

const searchIndex = [
  ...toolsData.tools.map(tool => {
    const lTool = translateTool(tool, locale);
    return {
      name: lTool.name,
      slug: lTool.slug,
      description: lTool.description || "",
      inputFormats: lTool.inputFormats || [],
      outputFormats: lTool.outputFormats || [],
      category: toolsData.categories.find(c => c.id === lTool.categoryId)?.name || 'Tool',
      url: getLocalizedPath(`/tools/${lTool.slug}`, locale)
    };
  }),
  ...comparisonsData.comparisons.map(comp => ({
    name: comp.title,
    slug: comp.id,
    description: comp.description || "",
    inputFormats: [comp.format1, comp.format2],
    outputFormats: [],
    category: 'Comparison',
    url: getLocalizedPath(`/compare/${comp.id}`, locale)
  }))
];
---
<nav class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-8">
      <a href={getLocalizedPath("/", locale)} class="flex items-center gap-2 transition-opacity hover:opacity-80">
        <img src="/favicon.svg" alt="Image Tool Stack Logo" class="h-6 w-6 shrink-0" />
        <span class="text-sm sm:text-base font-semibold tracking-tight text-ink whitespace-nowrap">Image Tool Stack</span>
      </a>
      
      <div class="hidden md:flex items-center gap-1">
        <a href={getLocalizedPath("/category/conversion", locale)} class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">{t.nav.convert}</a>
        <a href={getLocalizedPath("/category/optimization", locale)} class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">{t.nav.edit}</a>
        <a href={getLocalizedPath("/category/utility", locale)} class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">{t.nav.tools}</a>
        <a href={getLocalizedPath("/compare", locale)} class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">{t.nav.compare}</a>
      </div>
    </div>

    <div class="flex items-center gap-2 sm:gap-4">
      <div class="relative group" id="search-container">
        <input 
          id="search-input"
          type="text" 
          placeholder={t.nav.searchPlaceholder}
          class="h-9 w-20 sm:w-48 lg:w-64 rounded-md border border-hairline bg-canvas-soft px-2 sm:px-3 py-1.5 text-xs sm:text-sm text-ink placeholder:text-mute focus:border-link focus:ring-1 focus:ring-link focus:outline-none transition-all"
          autocomplete="off"
        />
        <div id="search-dropdown" class="absolute top-full right-0 mt-2 w-72 rounded-md border border-hairline bg-canvas shadow-lg overflow-hidden hidden flex-col max-h-96 overflow-y-auto">
          <!-- Results injected here -->
        </div>
      </div>
      
      <a href={getLocalizedPath("/about", locale)} class="hidden sm:block text-sm font-medium text-ink hover:opacity-75 transition-opacity">{t.nav.about}</a>
      
      <!-- Language Selector -->
      <div class="relative" id="lang-selector-container">
        <button 
          id="lang-selector-btn" 
          class="flex items-center gap-1.5 h-9 px-2 text-xs font-semibold text-ink hover:bg-canvas-soft border border-hairline rounded-md transition-colors cursor-pointer"
          aria-label="Change Language"
        >
          <svg class="h-4 w-4 text-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h2m-4-3h9m-9 3h9m-9 3h9M5.055 11h.01M10 14h.01M19 14h.01M14 18h.01"/>
          </svg>
          <span class="uppercase">{locale}</span>
          <svg class="h-3 w-3 text-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div 
          id="lang-dropdown" 
          class="absolute right-0 top-full mt-2 w-32 rounded-md border border-hairline bg-canvas shadow-lg overflow-hidden hidden flex-col z-50"
        >
          <a href={getLocalizedPath(Astro.url.pathname, 'en')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>English</span>
            {locale === 'en' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
          <a href={getLocalizedPath(Astro.url.pathname, 'es')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>Español</span>
            {locale === 'es' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
          <a href={getLocalizedPath(Astro.url.pathname, 'fr')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>Français</span>
            {locale === 'fr' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
          <a href={getLocalizedPath(Astro.url.pathname, 'de')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>Deutsch</span>
            {locale === 'de' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
          <a href={getLocalizedPath(Astro.url.pathname, 'pt')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>Português</span>
            {locale === 'pt' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
          <a href={getLocalizedPath(Astro.url.pathname, 'id')} class="px-4 py-2 text-xs font-medium text-ink hover:bg-canvas-soft transition-colors flex items-center justify-between">
            <span>Indonesia</span>
            {locale === 'id' && <span class="h-1.5 w-1.5 rounded-full bg-success"></span>}
          </a>
        </div>
      </div>
      
      <button id="theme-toggle" class="flex items-center justify-center h-8 w-8 shrink-0 text-ink hover:bg-canvas-soft rounded-full transition-colors cursor-pointer" aria-label="Toggle Dark Mode">
        <svg id="theme-toggle-dark-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg id="theme-toggle-light-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </button>

      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center h-8 w-8 shrink-0 text-ink hover:bg-canvas-soft rounded-full transition-colors cursor-pointer" aria-label="Toggle Menu">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu container -->
<div id="mobile-menu" class="hidden md:hidden fixed top-16 left-0 w-full bg-canvas border-b border-hairline shadow-lg z-40">
  <div class="flex flex-col px-4 py-3 space-y-1">
    <a href={getLocalizedPath("/category/conversion", locale)} class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">{t.nav.convert}</a>
    <a href={getLocalizedPath("/category/optimization", locale)} class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">{t.nav.edit}</a>
    <a href={getLocalizedPath("/category/utility", locale)} class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">{t.nav.tools}</a>
    <a href={getLocalizedPath("/compare", locale)} class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">{t.nav.compare}</a>
    <a href={getLocalizedPath("/about", locale)} class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">{t.nav.about}</a>
  </div>
</div>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById('search-input');
  const dropdown = document.getElementById('search-dropdown');
  const container = document.getElementById('search-container');

  if (input && dropdown && container) {
    input.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (!query) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('flex');
        return;
      }

      // Token-Based Relevance Engine
      const queryTokens = query.split(/\s+/).filter(Boolean);
      const slugifiedQuery = query.replace(/\s+/g, '-');
      
      const scoredResults = searchIndex.map(tool => {
        let score = 0;
        const lowerName = tool.name.toLowerCase();
        const lowerDesc = tool.description.toLowerCase();
        const toolSlug = tool.slug.toLowerCase();
        const formats = [...tool.inputFormats, ...tool.outputFormats].map(f => f.toLowerCase());
        
        // 1. Full Query Substring Match (Huge boost)
        if (lowerName === query) score += 200;
        else if (lowerName.startsWith(query)) score += 100;
        else if (lowerName.includes(query)) score += 70;
        
        // 2. Slug Pattern Match (e.g. "jpg to png" -> "jpg-to-png")
        if (toolSlug === slugifiedQuery) score += 150;
        else if (toolSlug.includes(slugifiedQuery)) score += 80;

        // 3. Token Matching
        queryTokens.forEach(token => {
          if (lowerName.includes(token)) score += 30;
          if (lowerDesc.includes(token)) score += 10;
          if (formats.includes(token)) score += 20;
          if (toolSlug.includes(token)) score += 15;
        });
        
        return { ...tool, score };
      });
      
      const results = scoredResults
        .filter(t => t.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 6);

      if (results.length > 0) {
        dropdown.innerHTML = results.map(tool => `
          <a href="${tool.url}" class="flex flex-col px-4 py-2 hover:bg-canvas-soft border-b border-hairline last:border-b-0 transition-colors">
            <span class="text-sm font-semibold text-ink">${tool.name}</span>
            <span class="text-[10px] uppercase font-mono tracking-widest text-mute mt-0.5">${tool.category}</span>
          </a>
        `).join('');
      } else {
        dropdown.innerHTML = `<div class="px-4 py-3 text-sm text-mute">No tools found for "${e.target.value}"</div>`;
      }
      
      dropdown.classList.remove('hidden');
      dropdown.classList.add('flex');
    });

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target)) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('flex');
      }
    });
    
    input.addEventListener('focus', () => {
      if (input.value.trim()) {
        dropdown.classList.remove('hidden');
        dropdown.classList.add('flex');
      }
    });
  }

  // Theme Toggle Logic
  const themeToggleBtn = document.getElementById('theme-toggle');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');
  const lightIcon = document.getElementById('theme-toggle-light-icon');

  function updateIcons() {
    if (document.documentElement.classList.contains('dark')) {
      darkIcon.classList.add('hidden');
      lightIcon.classList.remove('hidden');
    } else {
      lightIcon.classList.add('hidden');
      darkIcon.classList.remove('hidden');
    }
  }
  
  if (themeToggleBtn) {
    updateIcons();
    
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });
  }

  // Mobile Menu Logic
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Language Selector Dropdown Logic
  const langBtn = document.getElementById('lang-selector-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  const langContainer = document.getElementById('lang-selector-container');

  if (langBtn && langDropdown && langContainer) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown.classList.toggle('hidden');
      langDropdown.classList.toggle('flex');
    });

    document.addEventListener('click', (e) => {
      if (!langContainer.contains(e.target)) {
        langDropdown.classList.add('hidden');
        langDropdown.classList.remove('flex');
      }
    });
  }
</script>
