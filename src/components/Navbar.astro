---
import toolsData from "../data/tools.json";
import comparisonsData from "../data/comparisons.json";

const searchIndex = [
  ...toolsData.tools.map(tool => ({
    name: tool.name,
    slug: tool.slug,
    description: tool.description || "",
    inputFormats: tool.inputFormats || [],
    outputFormats: tool.outputFormats || [],
    category: toolsData.categories.find(c => c.id === tool.categoryId)?.name || 'Tool',
    url: `/tools/${tool.slug}`
  })),
  ...comparisonsData.comparisons.map(comp => ({
    name: comp.title,
    slug: comp.id,
    description: comp.description || "",
    inputFormats: [comp.format1, comp.format2],
    outputFormats: [],
    category: 'Comparison',
    url: `/compare/${comp.id}`
  }))
];
---
<nav class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80">
        <img src="/favicon.svg" alt="Image Tool Stack Logo" class="h-6 w-6 shrink-0" />
        <span class="text-sm sm:text-base font-semibold tracking-tight text-ink whitespace-nowrap">Image Tool Stack</span>
      </a>
      
      <div class="hidden md:flex items-center gap-1">
        <a href="/category/conversion" class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">Convert</a>
        <a href="/category/optimization" class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">Edit</a>
        <a href="/category/utility" class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">Tools</a>
        <a href="/compare" class="px-3 py-1 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded-pill transition-colors">Compare</a>
      </div>
    </div>

    <div class="flex items-center gap-2 sm:gap-4">
      <div class="relative group" id="search-container">
        <input 
          id="search-input"
          type="text" 
          placeholder="Search tools…" 
          class="h-9 w-20 sm:w-48 lg:w-64 rounded-md border border-hairline bg-canvas-soft px-2 sm:px-3 py-1.5 text-xs sm:text-sm text-ink placeholder:text-mute focus:border-link focus:ring-1 focus:ring-link focus:outline-none transition-all"
          autocomplete="off"
        />
        <div id="search-dropdown" class="absolute top-full right-0 mt-2 w-72 rounded-md border border-hairline bg-canvas shadow-lg overflow-hidden hidden flex-col max-h-96 overflow-y-auto">
          <!-- Results injected here -->
        </div>
      </div>
      
      <a href="/about" class="hidden sm:block text-sm font-medium text-ink hover:opacity-75 transition-opacity">About</a>
      
      <button id="theme-toggle" class="flex items-center justify-center h-8 w-8 shrink-0 text-ink hover:bg-canvas-soft rounded-full transition-colors" aria-label="Toggle Dark Mode">
        <svg id="theme-toggle-dark-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg id="theme-toggle-light-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </button>

      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center h-8 w-8 shrink-0 text-ink hover:bg-canvas-soft rounded-full transition-colors" aria-label="Toggle Menu">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu container -->
<div id="mobile-menu" class="hidden md:hidden fixed top-16 left-0 w-full bg-canvas border-b border-hairline shadow-lg z-40">
  <div class="flex flex-col px-4 py-3 space-y-1">
    <a href="/category/conversion" class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">Convert</a>
    <a href="/category/optimization" class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">Edit</a>
    <a href="/category/utility" class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">Tools</a>
    <a href="/compare" class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">Compare</a>
    <a href="/about" class="px-3 py-2 text-sm text-body hover:text-ink hover:bg-canvas-soft rounded transition-colors">About</a>
  </div>
</div>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById('search-input');
  const dropdown = document.getElementById('search-dropdown');
  const container = document.getElementById('search-container');

  if (input && dropdown && container) {
    input.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (!query) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('flex');
        return;
      }

      // Token-Based Relevance Engine
      const queryTokens = query.split(/\s+/).filter(Boolean);
      const slugifiedQuery = query.replace(/\s+/g, '-');
      
      const scoredResults = searchIndex.map(tool => {
        let score = 0;
        const lowerName = tool.name.toLowerCase();
        const lowerDesc = tool.description.toLowerCase();
        const toolSlug = tool.slug.toLowerCase();
        const formats = [...tool.inputFormats, ...tool.outputFormats].map(f => f.toLowerCase());
        
        // 1. Full Query Substring Match (Huge boost)
        if (lowerName === query) score += 200;
        else if (lowerName.startsWith(query)) score += 100;
        else if (lowerName.includes(query)) score += 70;
        
        // 2. Slug Pattern Match (e.g. "jpg to png" -> "jpg-to-png")
        if (toolSlug === slugifiedQuery) score += 150;
        else if (toolSlug.includes(slugifiedQuery)) score += 80;

        // 3. Token Matching
        queryTokens.forEach(token => {
          if (lowerName.includes(token)) score += 30;
          if (lowerDesc.includes(token)) score += 10;
          if (formats.includes(token)) score += 20;
          if (toolSlug.includes(token)) score += 15;
        });
        
        return { ...tool, score };
      });
      
      const results = scoredResults
        .filter(t => t.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 6);

      if (results.length > 0) {
        dropdown.innerHTML = results.map(tool => `
          <a href="${tool.url}" class="flex flex-col px-4 py-2 hover:bg-canvas-soft border-b border-hairline last:border-b-0 transition-colors">
            <span class="text-sm font-semibold text-ink">${tool.name}</span>
            <span class="text-[10px] uppercase font-mono tracking-widest text-mute mt-0.5">${tool.category}</span>
          </a>
        `).join('');
      } else {
        dropdown.innerHTML = `<div class="px-4 py-3 text-sm text-mute">No tools found for "${e.target.value}"</div>`;
      }
      
      dropdown.classList.remove('hidden');
      dropdown.classList.add('flex');
    });

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target)) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('flex');
      }
    });
    
    input.addEventListener('focus', () => {
      if (input.value.trim()) {
        dropdown.classList.remove('hidden');
        dropdown.classList.add('flex');
      }
    });
  }

  // Theme Toggle Logic
  const themeToggleBtn = document.getElementById('theme-toggle');
  const darkIcon = document.getElementById('theme-toggle-dark-icon');
  const lightIcon = document.getElementById('theme-toggle-light-icon');

  function updateIcons() {
    if (document.documentElement.classList.contains('dark')) {
      darkIcon.classList.add('hidden');
      lightIcon.classList.remove('hidden');
    } else {
      lightIcon.classList.add('hidden');
      darkIcon.classList.remove('hidden');
    }
  }
  
  if (themeToggleBtn) {
    updateIcons();
    
    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });
  }

  // Mobile Menu Logic
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
