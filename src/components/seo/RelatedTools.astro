---
import toolsData from "../../data/tools.json";

interface Props {
  tool?: any;
}
const { tool } = Astro.props;

// If tool is passed, use its relatedTools. Otherwise fallback to some hardcoded ones or none.
const requestedSlugs = tool?.relatedTools || [
  "png-to-jpg",
  "image-compressor",
  "crop-image"
];

const relatedTools = toolsData.tools.filter(t => requestedSlugs.includes(t.slug));
---
{relatedTools.length > 0 && (
  <div class="card-marketing p-6 mb-8">
    <h4 class="font-mono text-[11px] font-semibold uppercase tracking-widest text-mute mb-4">Related Tools</h4>
    <ul class="space-y-2">
      {relatedTools.map((rt) => (
        <li>
          <a href={`/tools/${rt.slug}`} class="flex items-center justify-between p-2 rounded-md text-sm text-ink hover:text-link hover:bg-canvas-soft transition-all group">
            <span>{rt.name}</span>
            <svg class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
