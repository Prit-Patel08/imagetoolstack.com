---
import { getTranslations } from "../../utils/i18n";
interface Props {
  tool: any;
}
const { tool } = Astro.props;

const locale = Astro.currentLocale || 'en';
const t = getTranslations(locale);
const steps = tool.howToSteps || [];
---
{steps.length > 0 && (
  <section class="mb-16">
    <h2 class="text-2xl font-semibold tracking-tight text-ink mb-8">{t.toolTemplates.howToSteps.title} {tool.name}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {steps.map((step: string, index: number) => (
        <div class="flex flex-col gap-3 p-6 rounded-lg bg-canvas border border-hairline relative">
          <div class="absolute -top-3 -left-3 h-8 w-8 rounded-full bg-ink text-on-primary flex items-center justify-center text-sm font-semibold shadow-sm">{index + 1}</div>
          <p class="text-sm text-body leading-relaxed mt-2">{step}</p>
        </div>
      ))}
    </div>
  </section>
)}
