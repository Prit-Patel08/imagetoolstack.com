---
import filesizesData from "../../data/filesizes.json";
import { getLocalizedPath } from "../../utils/i18n";

const currentPath = Astro.url.pathname;
const currentLocale = currentPath.split('/')[1];
const locales = ['es', 'fr', 'de', 'pt', 'id'];
const locale = locales.includes(currentLocale) ? currentLocale : 'en';

const sizes = filesizesData.sizes;
---

<div class="mt-12 mb-8 bg-surface border border-hairline rounded-xl p-6">
  <h3 class="text-lg font-bold text-ink mb-4">Popular Target Compression Sizes</h3>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
    {sizes.map(size => {
      // Build the canonical URL
      const path = `/compress-image-to-${size.label}`;
      const localizedPath = getLocalizedPath(path, locale);
      
      return (
        <a 
          href={localizedPath} 
          class="text-sm text-link hover:underline truncate"
          title={`Compress image to ${size.label}`}
        >
          Compress to {size.label}
        </a>
      );
    })}
  </div>
</div>
