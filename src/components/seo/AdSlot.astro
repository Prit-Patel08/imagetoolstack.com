---
interface Props {
  id: string;
  className?: string;
  layout?: "horizontal" | "vertical" | "rectangle";
}

const { id, className = "", layout = "horizontal" } = Astro.props;

// Toggle this variable to true when you want ads to render
const ADS_ENABLED = false;
---

{ADS_ENABLED && (
  <div class={`ad-container ${className}`}>
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-9945105681064336"
      data-ad-slot={id}
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}
