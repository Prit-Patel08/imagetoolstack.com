---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import RequestToolSection from "../components/RequestToolSection.astro";
import toolsData from "../data/tools.json";
import comparisonsData from "../data/comparisons.json";

const seoKeywords = "Image tool, image converter, image compressor, image resizer, image cropper, image editor, free image tools, online image tools, browser based image tools, private image tools, secure image tools, image optimization tools, image format converter, image processing tools, online photo tools, photo converter, image utility tools, image toolkit, image conversion tools, image editing tools, image enhancement tools, image compressor online, image converter online, image resizer online, image cropper online, free image converter, free image compressor, free image resizer, free image editor, convert images online, optimize images online, edit images online, resize images online, crop images online, browser image converter, local image processing, no upload image converter, no upload image tools, offline image tools, image tools without registration, image converter without upload, secure image converter, privacy focused image tools, client side image processing, webassembly image tools, png to jpg, png to jpeg, png converter, convert png to jpg, convert png to jpeg, png image converter, free png to jpg converter, online png to jpg converter, png file converter, jpg to png, jpeg to png, convert jpg to png, convert jpeg to png, jpg converter, png converter online, image format conversion, transparent png converter, png image optimizer, webp to png, webp to jpg, webp converter, convert webp to png, convert webp to jpg, webp image converter, png to webp, jpg to webp, jpeg to webp, convert png to webp, convert jpg to webp, webp optimizer, webp compressor, webp image tool, webp format converter, heic to jpg, heic to jpeg, heic converter, heif to jpg, iphone photo converter, convert heic to jpg, convert heic to jpeg, free heic converter, online heic converter, iphone image converter, apple photo converter, heic image tool, svg to png, svg to jpg, svg converter, convert svg to png, convert svg to jpg, vector to png, vector image converter, svg image converter, online svg converter, rasterize svg, svg image tool, compress image, image compression, image compressor, reduce image size, shrink image size, optimize image size, compress jpg, compress jpeg, compress png, compress webp, photo compressor, image size reducer, image optimizer, lossless compression, online image compressor, resize image, image resizer, resize photo, change image dimensions, image size changer, resize jpg, resize png, resize webp, photo resizer, image dimensions tool, online image resizer, bulk image resize, crop image, image cropper, crop photo, crop jpg, crop png, crop webp, image cropping tool, online image cropper, free image cropper, aspect ratio cropper, photo crop tool, image metadata viewer, exif viewer, image metadata checker, exif data viewer, photo metadata viewer, image information tool, exif reader, metadata extractor, image properties viewer, color picker from image, image color picker, extract colors from image, image palette generator, color extractor, hex color picker, rgb color picker, dominant color extractor, image color tool, image to pdf, jpg to pdf, png to pdf, photo to pdf, convert image to pdf, merge images into pdf, image pdf converter, online image to pdf, free image to pdf converter, convert image without upload, browser based image converter, offline image converter, private image converter, secure image converter, local image processing, image converter without registration, image tools without signup, image converter works offline, browser image editor, privacy focused image tools, process images locally, client side image converter, image processing in browser";

const popularTools = toolsData.tools.slice(0, 6);
const recentTools = [...toolsData.tools].reverse().slice(0, 6);
const popularComparisons = comparisonsData.comparisons.slice(0, 6);
const categoriesWithTools = toolsData.categories.map(cat => ({
  ...cat,
  tools: toolsData.tools.filter(t => t.categoryId === cat.id)
}));

const heroToolsSlugs = ['png-to-jpg', 'jpg-to-png', 'image-compressor', 'image-resizer', 'crop-image', 'webp-to-png'];
const heroTools = heroToolsSlugs.map(slug => toolsData.tools.find(t => t.slug === slug)).filter(Boolean);

const stats = [
  { label: "Free Image Tools", value: toolsData.tools.length.toString() },
  { label: "Supported Formats", value: "12" },
  { label: "Browser Based", value: "100%" },
  { label: "File Uploads", value: "0" }
];

const faqs = [
  { q: "What is an online image converter?", a: "An online image converter is a web-based tool that allows you to change the file format of an image (e.g., PNG to JPG) directly in your browser without downloading heavy software." },
  { q: "How do I compress images without losing quality?", a: "By using our Image Compressor, you can utilize advanced algorithms that reduce file size while maintaining visual fidelity. This is often called 'lossless' or 'efficient lossy' compression." },
  { q: "Is Image Tool Stack safe to use?", a: "Yes, 100%. Unlike other websites, we process all images locally on your computer. Your files are never uploaded to our servers, ensuring your privacy is completely protected." },
  { q: "Can I convert WebP to PNG?", a: "Yes, our WebP to PNG tool handles this conversion instantly. Simply drop your WebP file and download the PNG version." },
  { q: "Does this work on mobile?", a: "Absolutely. Our platform is mobile-first and works perfectly on iOS, Android, and tablets." },
  { q: "How do I convert JPG to PNG?", a: "Use our JPG to PNG tool. It converts your Joint Photographic Experts Group image into a Portable Network Graphics file, supporting transparency if needed." },
  { q: "Can I resize images for social media?", a: "Yes, our Image Resizer allows you to set specific pixel dimensions optimized for Instagram, Twitter, or LinkedIn." },
  { q: "What is the best format for web images?", a: "Next-gen formats like WebP or AVIF are generally best for the web as they provide superior compression compared to JPG or PNG." },
  { q: "How many files can I process at once?", a: "Our current tools are optimized for single-file precision, but we are rolling out bulk processing for several tools shortly." },
  { q: "Is registration required?", a: "No. You can use all 100% of our features without creating an account or providing an email address." },
  { q: "Can I remove background from images?", a: "Yes, our AI-powered Background Remover works directly in your browser to isolate subjects from their background." },
  { q: "How do I view EXIF metadata?", a: "Our Metadata Viewer allows you to see hidden information like camera settings, location data, and date taken." },
  { q: "What is a SVG file?", a: "SVG stands for Scalable Vector Graphics. It is an XML-based format that can be scaled to any size without losing quality." },
  { q: "How do I convert HEIC to JPG?", a: "iPhone users can use our HEIC to JPG converter to make their photos compatible with all web platforms." },
  { q: "Are there any file size limits?", a: "We support files up to 50MB for local processing, which covers most high-resolution photography needs." }
];
---

<Layout 
  title="Free Online Image Tools - Convert, Compress & Edit" 
  description="The world's fastest, privacy-first online image tool collection. Convert, compress, resize and edit images in seconds without ever uploading your files."
>
	<Navbar />
	
	<main class="w-full relative overflow-hidden">
		<!-- Mesh Gradient Decoration -->
		<div class="pointer-events-none absolute -top-48 left-1/2 h-[700px] w-full -translate-x-1/2 mesh-gradient opacity-10"></div>

		<!-- Hero Section -->
		<section class="mx-auto max-w-[1400px] px-6 pb-20 pt-16 lg:px-8 lg:pt-24 text-center relative z-10">
			<h1 class="mx-auto max-w-5xl text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-6xl leading-[1.1] mb-8">
				Private Image Tools That Run <span class="bg-gradient-to-r from-link to-link-deep bg-clip-text text-transparent">In Your Browser</span>
			</h1>

			<div class="mx-auto flex flex-wrap items-center justify-center gap-4 sm:gap-8 mb-12 text-sm font-medium text-body">
				<div class="flex items-center gap-1.5"><svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> No uploads</div>
				<div class="flex items-center gap-1.5"><svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> No registration</div>
				<div class="flex items-center gap-1.5"><svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Works offline</div>
				<div class="flex items-center gap-1.5"><svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Instant processing</div>
			</div>
			
			<!-- Universal Quick Convert Dropzone -->
			<div class="mx-auto max-w-3xl mt-12 mb-8">
				<a href="/tools/image-compressor" class="group relative flex flex-col items-center justify-center p-12 rounded-2xl bg-canvas border-2 border-dashed border-hairline-strong hover:border-link hover:bg-link/5 transition-all cursor-pointer overflow-hidden shadow-sm hover:shadow-md">
					<div class="absolute inset-0 bg-gradient-to-b from-transparent to-canvas-soft opacity-50"></div>
					
					<div class="h-16 w-16 mb-6 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center group-hover:scale-110 group-hover:bg-link/10 group-hover:border-link/20 transition-all duration-300 relative z-10 shadow-sm">
						<svg class="h-8 w-8 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
						</svg>
					</div>
					
					<h3 class="text-2xl font-bold text-ink mb-2 relative z-10">Quick Convert & Optimize</h3>
					<p class="text-body text-center max-w-md relative z-10">Click here to access our all-in-one image tool. Upload any JPG, PNG, WebP or SVG to convert formats or reduce file size instantly.</p>
					
					<div class="mt-6 flex items-center gap-2 text-xs font-semibold text-mute bg-canvas-soft px-3 py-1.5 rounded-full border border-hairline relative z-10">
						<svg class="h-3 w-3 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
						100% Secure & Local Processing
					</div>
				</a>
			</div>
            
			<!-- SEO Legal Links -->
			<div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-[13px] font-medium text-mute">
				<a href="/about" class="hover:text-link transition-colors">About Us</a>
				<a href="/privacy" class="hover:text-link transition-colors">Privacy Policy</a>
				<a href="/terms" class="hover:text-link transition-colors">Terms & Conditions</a>
				<a href="/contact" class="hover:text-link transition-colors">Contact Us</a>
			</div>
		</section>

		<!-- Statistics Section -->
		<section class="border-y border-hairline bg-canvas py-12">
			<div class="mx-auto max-w-[1400px] px-6 lg:px-8">
				<div class="grid grid-cols-2 gap-8 md:grid-cols-4">
					{stats.map(stat => (
						<div class="text-center">
							<div class="text-3xl font-semibold text-ink">{stat.value}</div>
							<div class="text-sm font-medium text-mute mt-1 uppercase tracking-tighter">{stat.label}</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Popular Tools Section -->
		<section id="tools" class="mx-auto max-w-[1400px] px-6 py-24 lg:px-8">
			<div class="flex items-end justify-between mb-12">
				<div>
					<h2 class="text-3xl font-semibold tracking-tight text-ink">Popular Tools</h2>
					<p class="mt-2 text-body">Instant access to our most used utilities.</p>
				</div>
			</div>
			
			<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{popularTools.map((tool) => (
					<a href={`/tools/${tool.slug}`} class="card-marketing group flex flex-col items-start gap-4 hover:border-link hover:shadow-xl transition-all p-8">
						<div class="h-12 w-12 rounded-lg bg-canvas-soft-2 flex items-center justify-center border border-hairline group-hover:bg-link/5 transition-colors group-hover:border-link/20">
							<svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
						</div>
						<div class="w-full">
							<div class="flex items-center justify-between">
								<h3 class="text-xl font-semibold tracking-tight text-ink">{tool.name}</h3>
								<span class="text-[10px] font-mono font-bold text-success bg-success/10 px-2 py-0.5 rounded-full uppercase tracking-widest">Trending</span>
							</div>
							<p class="mt-2 text-sm text-body leading-relaxed">{tool.description}</p>
							<div class="mt-4 flex items-center gap-3 text-xs font-medium text-mute">

								{tool.communityRequested && <span class="flex items-center gap-1 text-link"><svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/></svg> Requested</span>}
							</div>
							<div class="mt-6 flex items-center gap-2 text-xs font-semibold text-link group-hover:translate-x-1 transition-transform">
								Launch Tool <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7M5 12h16"/></svg>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- Recently Added Tools Section -->
		<section class="mx-auto max-w-[1400px] px-6 py-24 lg:px-8 bg-canvas-soft-2 border-y border-hairline">
			<div class="flex items-end justify-between mb-12">
				<div>
					<h2 class="text-3xl font-semibold tracking-tight text-ink">Recently Added</h2>
					<p class="mt-2 text-body">The newest utilities added to our platform.</p>
				</div>
			</div>
			
			<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{recentTools.map((tool) => (
					<a href={`/tools/${tool.slug}`} class="card-marketing group flex flex-col items-start gap-4 hover:border-link hover:shadow-xl transition-all p-8 bg-canvas">
						<div class="h-12 w-12 rounded-lg bg-canvas-soft flex items-center justify-center border border-hairline group-hover:bg-link/5 transition-colors group-hover:border-link/20">
							<svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
							</svg>
						</div>
						<div class="w-full">
							<div class="flex items-center justify-between">
								<h3 class="text-xl font-semibold tracking-tight text-ink">{tool.name}</h3>
								<span class="text-[10px] font-mono font-bold text-link bg-link/10 px-2 py-0.5 rounded-full uppercase tracking-widest">New</span>
							</div>
							<p class="mt-2 text-sm text-body leading-relaxed">{tool.description}</p>
							<div class="mt-4 flex items-center gap-3 text-xs font-medium text-mute">

								{tool.communityRequested && <span class="flex items-center gap-1 text-link"><svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/></svg> Requested</span>}
							</div>
							<div class="mt-6 flex items-center gap-2 text-xs font-semibold text-link group-hover:translate-x-1 transition-transform">
								Try it now <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7M5 12h16"/></svg>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- Popular Comparisons Section -->
		<section class="mx-auto max-w-[1400px] px-6 py-24 lg:px-8 border-y border-hairline">
			<div class="flex items-end justify-between mb-12">
				<div>
					<h2 class="text-3xl font-semibold tracking-tight text-ink">Popular Format Comparisons</h2>
					<p class="mt-2 text-body">Discover which image format is right for your project.</p>
				</div>
			</div>
			
			<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{popularComparisons.map((comp) => (
					<a href={`/compare/${comp.id}`} class="card-marketing group flex flex-col items-start gap-4 hover:border-link hover:shadow-xl transition-all p-8">
						<div class="w-full">
							<h3 class="text-xl font-semibold tracking-tight text-ink">{comp.title}</h3>
							<p class="mt-2 text-sm text-body leading-relaxed">{comp.metaDescription}</p>
							<div class="mt-6 flex items-center gap-2 text-xs font-semibold text-link group-hover:translate-x-1 transition-transform">
								Read Guide <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7M5 12h16"/></svg>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
		<!-- Quick Category Links for Internal Linking -->
		<section class="mx-auto max-w-[1400px] px-6 pb-24 lg:px-8">
			<div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
				{categoriesWithTools.map((cat) => (
					<a href={`/category/${cat.slug}`} class="flex items-center gap-2 rounded-full border border-hairline bg-canvas px-5 py-2.5 text-sm font-medium text-ink hover:border-link hover:bg-link/5 hover:text-link transition-all shadow-sm">
						{cat.name} <span class="text-mute text-xs font-mono">({cat.tools.length})</span>
					</a>
				))}
			</div>
		</section>

		<!-- Tool Categories Section -->
		<section id="discovery" class="mx-auto max-w-[1400px] px-6 py-24 lg:px-8 border-t border-hairline">
			<h2 class="text-center text-3xl font-semibold tracking-tight text-ink mb-16 italic">Complete Tool Stack</h2>
			<div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
				{categoriesWithTools.map((cat) => (
					<div class="flex flex-col gap-6">
						<div class="flex items-center justify-between border-b border-hairline pb-4">
							<div class="flex items-center gap-3">
								<div class="h-8 w-8 rounded bg-canvas-soft-2 border border-hairline flex items-center justify-center">
									<svg class="h-4 w-4 text-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
								</div>
								<h3 class="text-xl font-semibold tracking-tight text-ink">{cat.name}</h3>
							</div>
							<span class="text-xs font-bold text-mute bg-canvas-soft px-2 py-0.5 rounded border border-hairline">{cat.tools.length} Tools</span>
						</div>
						<p class="text-sm text-body">{cat.description}</p>
						<ul class="space-y-3 pt-2">
							{cat.tools.map(tool => (
								<li class="flex items-center gap-2 before:content-[''] before:block before:h-1 before:w-1 before:rounded-full before:bg-hairline-strong">
									<a href={`/tools/${tool.slug}`} class="text-sm font-medium text-body hover:text-link transition-colors">
										{tool.name}
									</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</section>

		<!-- Why Choose Image Tool Stack & Trust Signals -->
		<section class="bg-canvas-soft py-24 text-ink border-t border-hairline">
			<div class="mx-auto max-w-[1400px] px-6 lg:px-8">
				
				<!-- Trust Signals -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24 text-center">
					<div class="p-8 rounded-2xl bg-canvas border border-hairline flex flex-col items-center hover:shadow-md transition-all">
						<svg class="h-10 w-10 text-link mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						<h3 class="text-xl font-bold text-ink">100% Browser Processing</h3>
					</div>
					<div class="p-8 rounded-2xl bg-canvas border border-hairline flex flex-col items-center hover:shadow-md transition-all">
						<svg class="h-10 w-10 text-link mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
						<h3 class="text-xl font-bold text-ink">Files Never Leave Your Device</h3>
					</div>
					<div class="p-8 rounded-2xl bg-canvas border border-hairline flex flex-col items-center hover:shadow-md transition-all">
						<svg class="h-10 w-10 text-link mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
						<h3 class="text-xl font-bold text-ink">No Registration Required</h3>
					</div>
				</div>

				<!-- Comparison Section -->
				<div class="max-w-4xl mx-auto">
					<h2 class="text-3xl font-semibold sm:text-4xl tracking-tight text-center mb-12 text-ink">Why choose Image Tool Stack?</h2>
					<div class="overflow-hidden rounded-2xl bg-canvas border border-hairline shadow-xl">
						<table class="w-full text-left border-collapse table-fixed">
							<thead>
								<tr class="bg-canvas-soft border-b border-hairline">
									<th class="p-6 text-lg font-medium text-ink">Feature</th>
									<th class="p-6 text-lg font-bold text-link border-l border-hairline bg-link/5">Us</th>
									<th class="p-6 text-lg font-medium text-mute border-l border-hairline">TinyPNG</th>
									<th class="p-6 text-lg font-medium text-mute border-l border-hairline">Convertio</th>
								</tr>
							</thead>
							<tbody class="text-ink text-lg">
