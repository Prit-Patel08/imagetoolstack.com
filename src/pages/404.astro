---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import RequestToolSection from "../components/RequestToolSection.astro";
import toolsData from "../data/tools.json";
import { translateTool, translateCategory, getLocalizedPath } from "../utils/i18n";

const locale = Astro.currentLocale || 'en';

const popularTools = toolsData.tools.slice(0, 4).map(t => translateTool(t, locale));
const categoriesWithTools = toolsData.categories.map(cat => ({
  ...translateCategory(cat, locale),
  tools: toolsData.tools.filter(t => t.categoryId === cat.id)
}));

const searchIndex = toolsData.tools.map(tool => {
  const translated = translateTool(tool, locale);
  return {
    name: translated.name,
    slug: translated.slug,
    description: translated.description || "",
    inputFormats: translated.inputFormats || [],
    outputFormats: translated.outputFormats || [],
    category: toolsData.categories.find(c => c.id === tool.categoryId)?.name || 'Tool'
  };
});

const title = locale === 'es' ? "404: Página no encontrada" :
              locale === 'fr' ? "404: Page non trouvée" :
              locale === 'de' ? "404: Seite nicht gefunden" :
              locale === 'pt' ? "404: Página não encontrada" :
              locale === 'id' ? "404: Halaman Tidak Ditemukan" : "404: Page Not Found";

const looksLost = locale === 'es' ? "¡Parece que te has perdido!" :
                  locale === 'fr' ? "Il semblerait que vous soyez perdu !" :
                  locale === 'de' ? "Es sieht so aus, als hätten Sie sich verlaufen!" :
                  locale === 'pt' ? "Parece que você está perdido!" :
                  locale === 'id' ? "Sepertinya Anda tersesat!" : "Looks like you're lost!";

const searchPlaceholder = locale === 'es' ? "Buscar una herramienta de imagen..." :
                            locale === 'fr' ? "Rechercher un outil d'image..." :
                            locale === 'de' ? "Nach einem Bildwerkzeug suchen..." :
                            locale === 'pt' ? "Buscar uma ferramenta de imagem..." :
                            locale === 'id' ? "Cari alat gambar..." : "Search for an image tool...";

const browseCategory = locale === 'es' ? "BUSCAR POR CATEGORÍA" :
                       locale === 'fr' ? "PARCOURIR PAR CATÉGORIE" :
                       locale === 'de' ? "NACH KATEGORIE DURCHSUCHEN" :
                       locale === 'pt' ? "NAVEGAR POR CATEGORIA" :
                       locale === 'id' ? "TELUSURI BERDASARKAN KATEGORI" : "BROWSE BY CATEGORY";

const popularToolsText = locale === 'es' ? "Herramientas populares" :
                           locale === 'fr' ? "Outils populaires" :
                           locale === 'de' ? "Beliebte Tools" :
                           locale === 'pt' ? "Ferramentas populares" :
                           locale === 'id' ? "Alat Populer" : "Popular Tools";

const noToolsFoundTemplate = locale === 'es' ? 'No se encontraron herramientas para "${e.target.value}"' :
                             locale === 'fr' ? 'Aucun outil trouvé pour "${e.target.value}"' :
                             locale === 'de' ? 'Keine Werkzeuge gefunden für "${e.target.value}"' :
                             locale === 'pt' ? 'Nenhuma ferramenta encontrada para "${e.target.value}"' :
                             locale === 'id' ? 'Tidak ada alat yang ditemukan untuk "${e.target.value}"' :
                             'No tools found for "${e.target.value}"';
---

<Layout title={title}>
  <Navbar />
  
  <main class="flex-1 flex flex-col items-center justify-start min-h-[60vh] py-20 px-6 text-center">
    
    <!-- Hero 404 Header -->
    <div class="h-20 w-20 rounded-3xl bg-canvas border border-hairline flex items-center justify-center mb-6 shadow-sm mx-auto">
      <svg class="h-8 w-8 text-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    
    <h1 class="text-5xl font-semibold tracking-tight text-ink mb-3">404</h1>
    <h2 class="text-xl font-semibold text-body mb-8">{looksLost}</h2>
    
    <!-- Search Box -->
    <div class="w-full max-w-xl mx-auto mb-16 relative" id="error-search-container">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input 
          id="error-search-input"
          type="text" 
          placeholder={searchPlaceholder} 
          class="h-14 w-full rounded-2xl border-2 border-hairline bg-canvas pl-12 pr-4 text-base text-ink placeholder:text-mute focus:border-link focus:ring-4 focus:ring-link/10 focus:outline-none transition-all shadow-sm"
          autocomplete="off"
        />
      </div>
      <div id="error-search-dropdown" class="absolute top-full left-0 right-0 mt-2 rounded-xl border border-hairline bg-canvas shadow-xl overflow-hidden hidden flex-col max-h-96 overflow-y-auto z-50 text-left">
        <!-- Results injected here -->
      </div>
    </div>

    <!-- Category Links -->
    <div class="w-full max-w-4xl mx-auto mb-16">
      <h3 class="text-sm font-semibold text-mute uppercase tracking-widest mb-6">{browseCategory}</h3>
      <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4">
        {categoriesWithTools.map((cat) => (
          <a href={getLocalizedPath(`/category/${cat.slug}`, locale)} class="flex items-center gap-2 rounded-full border border-hairline bg-canvas px-5 py-2 text-sm font-medium text-ink hover:border-link hover:bg-link/5 hover:text-link transition-all shadow-sm">
            {cat.name} <span class="text-mute text-xs font-mono">({cat.tools.length})</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Popular Tools -->
    <div class="w-full max-w-5xl mx-auto mb-20 text-left">
      <h3 class="text-sm font-semibold text-mute uppercase tracking-widest mb-6 text-center">{popularToolsText}</h3>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {popularTools.map((tool) => (
          <a href={getLocalizedPath(`/tools/${tool.slug}`, locale)} class="card-marketing group flex flex-col items-start gap-4 hover:border-link hover:shadow-xl transition-all p-6 rounded-2xl border border-hairline bg-canvas">
            <div class="h-10 w-10 rounded-lg bg-canvas-soft-2 flex items-center justify-center border border-hairline group-hover:bg-link/5 transition-colors group-hover:border-link/20">
              <svg class="h-5 w-5 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="w-full">
              <h4 class="text-lg font-semibold tracking-tight text-ink mb-1">{tool.name}</h4>
              <p class="text-xs text-body line-clamp-2">{tool.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    
    <!-- Request a Tool -->
    <div class="w-full max-w-2xl mx-auto pt-8 border-t border-hairline">
      <RequestToolSection source="404_page" is404={true} />
    </div>
    
  </main>

  <Footer />

  <script define:vars={{ searchIndex, locale, noToolsFoundTemplate }}>
    const input = document.getElementById('error-search-input');
    const dropdown = document.getElementById('error-search-dropdown');
    const container = document.getElementById('error-search-container');

    if (input && dropdown && container) {
      input.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        
        if (!query) {
          dropdown.classList.add('hidden');
          dropdown.classList.remove('flex');
          return;
        }

        // Fuzzy Search Relevance Engine
        const scoredResults = searchIndex.map(tool => {
          let score = 0;
          const lowerName = tool.name.toLowerCase();
          const lowerDesc = tool.description.toLowerCase();
          const formats = [...tool.inputFormats, ...tool.outputFormats].map(f => f.toLowerCase());
          
          if (lowerName === query) score += 100;
          else if (lowerName.startsWith(query)) score += 80;
          else if (lowerName.includes(query)) score += 50;
          
          if (formats.some(f => f === query)) score += 60;
          if (formats.some(f => query.includes(f))) score += 40;
          
          if (lowerDesc.includes(query)) score += 20;

          let sIdx = 0;
          for (let i = 0; i < lowerName.length; i++) {
            if (lowerName[i] === query[sIdx]) {
              sIdx++;
            }
            if (sIdx === query.length) {
              score += 10;
              break;
            }
          }
          
          return { ...tool, score };
        });
        
        const results = scoredResults
          .filter(t => t.score > 0)
          .sort((a, b) => b.score - a.score)
          .slice(0, 5);

        if (results.length > 0) {
          dropdown.innerHTML = results.map(tool => {
            const path = locale === 'en' ? `/tools/${tool.slug}` : `/${locale}/tools/${tool.slug}`;
            return `
              <a href="${path}" class="flex flex-col px-4 py-3 hover:bg-canvas-soft border-b border-hairline last:border-b-0 transition-colors">
                <span class="text-sm font-semibold text-ink">${tool.name}</span>
                <span class="text-xs text-mute mt-0.5 line-clamp-1">${tool.description}</span>
              </a>
            `;
          }).join('');
        } else {
          // Replace placeholder query in the template
          const text = noToolsFoundTemplate.replace('"${e.target.value}"', `"${e.target.value}"`);
          dropdown.innerHTML = `<div class="px-4 py-4 text-sm text-mute text-center">${text}</div>`;
        }
        
        dropdown.classList.remove('hidden');
        dropdown.classList.add('flex');
      });

      document.addEventListener('click', (e) => {
        if (!container.contains(e.target)) {
          dropdown.classList.add('hidden');
          dropdown.classList.remove('flex');
        }
      });
      
      input.addEventListener('focus', () => {
        if (input.value.trim()) {
          dropdown.classList.remove('hidden');
          dropdown.classList.add('flex');
        }
      });
    }
  </script>
</Layout>
