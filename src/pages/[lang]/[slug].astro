---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { defaultLocale } from "../../data/translations";

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const locales = ['es', 'fr', 'de', 'pt', 'id'];
  
  return locales.flatMap(lang => 
    articles.map(entry => ({
      params: { lang, slug: entry.id },
      props: { entry },
    }))
  );
}

const { lang } = Astro.params;
const { entry } = Astro.props;
import { render } from 'astro:content';
const { Content } = await render(entry);

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.id !== entry.id)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 4);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Image Tool Stack"
  }
};

let homeStr = "Home";
let articlesStr = "Articles";
let moreGuidesStr = "More Guides & Articles";
let readArticleStr = "Read article";
let startProcessingStr = "Start Processing Images Now";
let startProcessingSubStr = "Use our 100% free, private, browser-based image tools.";
let browseToolsStr = "Browse All Tools";

if (lang === 'es') {
  homeStr = "Inicio"; articlesStr = "Artículos"; moreGuidesStr = "Más Guías y Artículos"; readArticleStr = "Leer artículo";
  startProcessingStr = "Comience a Procesar Imágenes Ahora"; startProcessingSubStr = "Use nuestras herramientas de imagen gratuitas, privadas y basadas en el navegador."; browseToolsStr = "Ver Todas las Herramientas";
} else if (lang === 'fr') {
  homeStr = "Accueil"; articlesStr = "Articles"; moreGuidesStr = "Plus de Guides"; readArticleStr = "Lire l'article";
  startProcessingStr = "Commencez le Traitement d'Images"; startProcessingSubStr = "Utilisez nos outils d'image gratuits et privés."; browseToolsStr = "Parcourir Tous les Outils";
} else if (lang === 'de') {
  homeStr = "Startseite"; articlesStr = "Artikel"; moreGuidesStr = "Weitere Leitfäden"; readArticleStr = "Artikel lesen";
  startProcessingStr = "Jetzt Bilder Bearbeiten"; startProcessingSubStr = "Nutzen Sie unsere kostenlosen, privaten Bildwerkzeuge."; browseToolsStr = "Alle Werkzeuge Durchsuchen";
} else if (lang === 'pt') {
  homeStr = "Início"; articlesStr = "Artigos"; moreGuidesStr = "Mais Guias e Artigos"; readArticleStr = "Ler artigo";
  startProcessingStr = "Comece a Processar Imagens Agora"; startProcessingSubStr = "Use nossas ferramentas de imagem gratuitas e privadas."; browseToolsStr = "Navegar em Todas as Ferramentas";
} else if (lang === 'id') {
  homeStr = "Beranda"; articlesStr = "Artikel"; moreGuidesStr = "Panduan Lainnya"; readArticleStr = "Baca artikel";
  startProcessingStr = "Mulai Memproses Gambar Sekarang"; startProcessingSubStr = "Gunakan alat gambar gratis dan privat kami."; browseToolsStr = "Jelajahi Semua Alat";
}

---
<Layout title={`${entry.data.title} | Image Tool Stack`} description={entry.data.description}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[800px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={`/${lang}`} class="hover:text-ink transition-colors">{homeStr}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={`/${lang}/articles`} class="hover:text-ink transition-colors">{articlesStr}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink truncate">{entry.data.title}</span>
      </nav>
    </div>

    <article class="mx-auto max-w-[800px] px-6 py-12 lg:px-8 lg:py-16">
      <header class="mb-12">
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{entry.data.title}</h1>
        <p class="text-xl text-body leading-relaxed">{entry.data.description}</p>
        <div class="mt-6 flex items-center gap-4 text-sm text-mute">
          <span>By Image Tool Stack</span>
          <span>•</span>
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </header>

      <div class="prose prose-lg max-w-none text-body prose-headings:text-ink prose-a:text-link hover:prose-a:text-link-hover prose-strong:text-ink mb-16">
        <Content />
      </div>

      <!-- Related Guides -->
      {relatedArticles.length > 0 && (
        <section class="mb-16 border-t border-hairline pt-12">
          <h2 class="text-2xl font-bold text-ink mb-6">{moreGuidesStr}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedArticles.map((related) => (
              <a href={`/${lang}/${related.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex flex-col justify-between h-full">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors mb-2">{related.data.title}</h3>
                  <p class="text-sm text-body line-clamp-2">{related.data.description}</p>
                </div>
                <div class="mt-4 flex items-center text-xs font-semibold text-link">
                  {readArticleStr} <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="p-8 rounded-2xl bg-canvas-soft border border-hairline text-center">
        <h2 class="text-2xl font-bold text-ink mb-4">{startProcessingStr}</h2>
        <p class="text-body mb-6">{startProcessingSubStr}</p>
        <a href={`/${lang}`} class="inline-flex items-center justify-center rounded-lg bg-link px-6 py-3 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
          {browseToolsStr}
        </a>
      </div>
    </article>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
</Layout>
