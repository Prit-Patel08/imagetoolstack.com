    snippetSectionDesc: "Memilih format yang benar sangat penting untuk performa web dan SEO. Berikut jawaban langsung untuk pertanyaan yang sering diajukan.",
    
    q1: "Apakah kualitas PNG lebih tinggi daripada JPG?",
    a1: "Ya. PNG secara teknis memiliki kualitas lebih tinggi karena menggunakan kompresi lossless, artinya tidak ada informasi piksel atau warna yang dibuang. JPG menggunakan kompresi lossy, yang menghapus data secara permanen untuk memperkecil ukuran file.",
    
    q2: "Format mana yang harus digunakan untuk kecepatan website, PNG atau JPG?",
    a2: "Untuk kecepatan web dan Core Web Vitals, gunakan JPG (atau WebP) untuk semua foto. Hanya gunakan PNG untuk logo transparan, ikon, atau tangkapan layar dengan teks. Menyimpan foto sebagai PNG akan sangat memperlambat pemuatan halaman.",
    
    q3: "Mana yang lebih baik untuk cetak, PNG or JPG?",
    a3: "JPG jauh lebih baik untuk cetak daripada PNG. Format JPG mendukung profil warna CMYK secara asli yang digunakan oleh mesin cetak profesional, serta menyimpan metadata EXIF dan DPI. PNG hanya untuk layar RGB.",
    
    q4: "Mengapa ukuran file PNG jauh lebih besar daripada JPG?",
    a4: "Ukuran file PNG lebih besar karena menyimpan salinan gambar yang sempurna secara matematis. JPG menyederhanakan blok piksel dan membuang detail visual yang tidak disadari mata manusia, memangkas ukuran hingga 80-90%.",
    
    q5: "Mengapa JPG tidak mendukung transparansi?",
    a5: "JPG tidak mendukung transparansi karena standarnya hanya mendefinisikan saluran warna Merah, Hijau, Biru (RGB) dan tidak memiliki 'saluran Alpha' (RGBA) untuk opasitas. Bagian transparan pada gambar yang disimpan ke JPG otomatis diisi warna putih.",
    
    faqTitle: "Pertanyaan yang Sering Diajukan",
    moreComparisons: "Perbandingan Lainnya",
    ctaTitle: "Perlu mengonversi file PNG besar ke JPG?",
    ctaDesc: "Gunakan alat gratis di browser kami untuk mengompresi dan mengonversi gambar Anda secara instan tanpa mengunggah ke server.",
    ctaButton: "Coba Konverter PNG ke JPG",
    homeText: "Beranda",
    compareLinkText: "Bandingkan"
  }
};

const text = pageTranslations[locale] || pageTranslations.es;

// FAQ Schema
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": text.seoTitle,
      "description": text.seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": text.q1,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a1
          }
        },
        {
          "@type": "Question",
          "name": text.q2,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a2
          }
        },
        {
          "@type": "Question",
          "name": text.q3,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a3
          }
        },
        {
          "@type": "Question",
          "name": text.q4,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a4
          }
        },
        {
          "@type": "Question",
          "name": text.q5,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a5
          }
        }
      ]
    }
  ]
};

// Get 4 related comparisons
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "png-vs-jpg" && (["PNG", "JPG", "JPEG"].includes(comp.format1) || ["PNG", "JPG", "JPEG"].includes(comp.format2)))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "png-to-jpg");
---

<Layout title={text.seoTitle} description={text.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{text.homeText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{text.compareLinkText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">PNG vs JPG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PNG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">JPG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          {text.intro}
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useJpgFor}</strong> {text.useJpgForDesc}</p>
          <p><strong class="text-ink">{text.usePngFor}</strong> {text.usePngForDesc}</p>
          <p><strong class="text-ink">{text.useWebpFor}</strong> {text.useWebpForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thPng}</th>
                <th class="p-4">{text.thJpg}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompression}</td>
                <td class="p-4">{text.tdCompressionPng}</td>
                <td class="p-4">{text.tdCompressionJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTransparency}</td>
                <td class="p-4">{text.tdTransparencyPng}</td>
                <td class="p-4">{text.tdTransparencyJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdQuality}</td>
                <td class="p-4">{text.tdQualityPng}</td>
                <td class="p-4">{text.tdQualityJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdMetadata}</td>
                <td class="p-4">{text.tdMetadataPng}</td>
                <td class="p-4">{text.tdMetadataJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdAnimation}</td>
                <td class="p-4">{text.tdAnimationPng}</td>
                <td class="p-4">{text.tdAnimationJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdIdealFor}</td>
                <td class="p-4">{text.tdIdealForPng}</td>
                <td class="p-4">{text.tdIdealForJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileSize}</td>
                <td class="p-4">{text.tdFileSizePng}</td>
                <td class="p-4">{text.tdFileSizeJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdWebSpeed}</td>
                <td class="p-4">{text.tdWebSpeedPng}</td>
                <td class="p-4">{text.tdWebSpeedJpg}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
        <FormatConverter toolId="png-to-jpg" />
      </section>

      <!-- Detailed Comparisons & Use Cases (Featured Snippet Targeting) -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.snippetSectionTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.snippetSectionDesc}
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q1}</h3>
            <p class="leading-relaxed">{text.a1}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q2}</h3>
            <p class="leading-relaxed">{text.a2}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q3}</h3>
            <p class="leading-relaxed">{text.a3}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q4}</h3>
            <p class="leading-relaxed">{text.a4}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q5}</h3>
            <p class="leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{text.moreComparisons}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{text.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{text.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {text.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="PNG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
