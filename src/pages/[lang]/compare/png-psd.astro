    differenceDesc: "Perbedaan utamanya adalah PSD adalah format file kerja yang berisi struktur layer yang kaya, sedangkan PNG adalah format gambar datar (flat) hasil ekspor final.",
    thFeature: "Fitur / Aspek",
    thPng: "PNG (Portable Network Graphics)",
    thPsd: "PSD (Photoshop Document)",
    tdFileType: "Jenis File",
    tdFileTypePng: "Grafis raster terkompresi",
    tdFileTypePsd: "File proyek desain berlapis",
