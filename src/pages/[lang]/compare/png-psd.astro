    tdLayersPsd: "Ya (Layer & folder tak terbatas)",
    tdEdit: "Kemudahan Diedit",
    tdEditPng: "Tidak (Teks dan vektor tidak dapat diedit langsung)",
    tdEditPsd: "Ya (Teks, filter, dan masker dapat diedit sepenuhnya)",
    tdWeb: "Dukungan Web",
    tdWebPng: "Universal (Didukung oleh semua browser web)",
    tdWebPsd: "Tidak (Memerlukan konversi)",
