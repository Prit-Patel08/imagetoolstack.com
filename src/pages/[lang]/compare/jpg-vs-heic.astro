// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "jpg-vs-heic")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "heic-to-jpg");
---

<Layout title={text.seoTitle} description={text.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{text.homeText || "Home"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{text.compareLinkText || "Compare"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">JPG vs HEIC</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">JPG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">HEIC</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">{text.intro}</p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useTiffFor}</strong> {text.useTiffForDesc}</p>
          <p><strong class="text-ink">{text.useJxlFor}</strong> {text.useJxlForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm mb-8">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thTiff}</th>
                <th class="p-4">{text.thJxl}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompStandard}</td>
                <td class="p-4">{text.tdCompStandardTiff}</td>
                <td class="p-4">{text.tdCompStandardJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileSize}</td>
                <td class="p-4">{text.tdFileSizeTiff}</td>
                <td class="p-4 text-success">{text.tdFileSizeJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdColorDepth}</td>
                <td class="p-4 text-error">{text.tdColorDepthTiff}</td>
                <td class="p-4 text-success">{text.tdColorDepthJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdBrowser}</td>
                <td class="p-4 text-success">{text.tdBrowserTiff}</td>
                <td class="p-4 text-error">{text.tdBrowserJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdPrint}</td>
                <td class="p-4 text-error">{text.tdPrintTiff}</td>
                <td class="p-4 text-success">{text.tdPrintJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTranscoding}</td>
                <td class="p-4 text-error">{text.tdTranscodingTiff}</td>
                <td class="p-4 text-success">{text.tdTranscodingJxl}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
        <HeicToJpgTool toolId="heic-to-jpg" />
      </section>

      <!-- Deep Dive: JPG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveTiffTitle}</h2>
        <p>{text.diveTiffP1}</p>
        <p>{text.diveTiffP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveTiffAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveTiffAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- Deep Dive: HEIC -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveJxlTitle}</h2>
        <p>{text.diveJxlP1}</p>
        <p>{text.diveJxlP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveJxlAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveJxlAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.faqTitle}</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q1}</h3>
            <p class="text-body leading-relaxed">{text.a1}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q2}</h3>
            <p class="text-body leading-relaxed">{text.a2}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q3}</h3>
            <p class="text-body leading-relaxed">{text.a3}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q4}</h3>
            <p class="text-body leading-relaxed">{text.a4}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q5}</h3>
            <p class="text-body leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{text.moreComparisons || "Explore More Comparisons"}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{text.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{text.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {text.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="JPEG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
