    tdCompStandardTiff: "Vektor / Jalur matematika",
    tdCompStandardJxl: "Raster / Kisi piksel",
    tdFileSize: "Skalabilitas",
    tdFileSizeTiff: "Tak terbatas (Selalu tajam sempurna)",
    tdFileSizeJxl: "Terbatas (Pecah jika diperbesar)",
    tdColorDepth: "Paling Cocok Untuk",
    tdColorDepthTiff: "Logo, ikon antarmuka, desain datar",
    tdColorDepthJxl: "Foto, screenshot, ilustrasi detail",
    tdBrowser: "Ukuran File",
    tdBrowserTiff: "Bergantung pada kerumitan jalur",
    tdBrowserJxl: "Bergantung pada resolusi piksel gambar",
    tdPrint: "Gaya & Interaktivitas",
    tdPrintTiff: "Ya (Dapat diatur dengan CSS & Javascript)",
    tdPrintJxl: "Tidak (Piksel gambar statis)",
    tdTranscoding: "Performa Web",
    tdTranscodingTiff: "Sangat baik (Bisa dipasang langsung di HTML)",
    tdTranscodingJxl: "Loading jaringan standar",
    converterTitle: "Konversi SVG ke PNG (Offline & Privat)",
    diveTiffTitle: "Analisis Mendalam: Apa itu SVG?",
    diveTiffP1: "SVG (Scalable Vector Graphics) adalah format vektor berbasis XML yang diakui W3C sejak tahun 1999. SVG menyimpan rumus matematika untuk mendefinisikan bentuk garis, warna, dan teks.",
    diveTiffP2: "Struktur teks ini membuat SVG mudah dimuat browser. Anda bisa menempelkan kodenya langsung (inline) di HTML untuk menghemat request jaringan, serta mengatur warnanya dengan CSS.",
    diveTiffAdv: "Kelebihan SVG",
    diveTiffAdvList: [
      "Skalabilitas Sempurna: Tetap tajam di monitor resolusi tinggi seperti Retina Display.",
      "File Ringan: Ukuran dokumen sangat kecil untuk aset grafis flat.",
      "Fleksibel: Bisa dimodifikasi warnanya dan dianimasikan dengan CSS/JS."
    ],
    diveJxlTitle: "Analisis Mendalam: Apa itu PNG?",
    diveJxlP1: "PNG singkaran dari Portable Network Graphics. Dirilis tahun 1996, ia menggunakan kompresi lossless DEFLATE untuk menyimpan setiap piksel gambar secara akurat tanpa buram.",
    diveJxlP2: "Dukungan transparansi detail (alpha channel 8-bit) membuatnya menjadi standar utama untuk gambar tumpuk web dan screenshot, meskipun gambarnya akan pecah jika diperbesar.",
    diveJxlAdv: "Kelebihan PNG",
    diveJxlAdvList: [
      "Akurasi Piksel: Tidak ada kompresi pixel kasar di sekitar teks atau objek.",
      "Transparansi Halus: Mendukung gradasi opacity dan bayangan transparan.",
      "Dukungan Universal: Terbuka instan di semua jenis browser dan OS."
    ],
    q1: "Apa perbedaan antara SVG dan PNG?",
    a1: "SVG adalah format vektor matematika yang tajam pada resolusi mana pun. PNG adalah format raster berbasis piksel yang akan pecah jika diperbesar melebihi ukuran aslinya.",
    q2: "Kapan saya sebaiknya memakai SVG dibanding PNG?",
    a2: "Gunakan SVG untuk logo dan ikon agar tajam di semua layar. Gunakan PNG untuk foto berkualitas tinggi atau tangkapan layar (screenshot) beresolusi tinggi.",
    q3: "Apakah saya bisa mengubah file SVG ke PNG?",
    a3: "Ya. Anda bisa merender kode vektor SVG menjadi gambar PNG transparan secara instan dan lokal di browser menggunakan pengonversi gratis kami.",
    q4: "Format mana yang memuat halaman web lebih cepat?",
    a4: "Untuk grafis antarmuka, SVG memuat jauh lebih cepat karena kodenya ringan dan bisa disatukan ke HTML. Namun vektor yang terlalu rumit bisa membebani CPU browser, sehingga PNG menjadi pilihan yang lebih aman.",
    q5: "Apakah SVG dan PNG mendukung transparansi?",
    a5: "Ya, kedua format mendukung transparansi. SVG mengaturnya via kode, sedangkan PNG menggunakan saluran alpha 8-bit untuk gradasi transparansi yang halus.",
    faqTitle: "Pertanyaan yang Sering Diajukan",
    moreComparisons: "Perbandingan Lainnya",
    ctaTitle: "Butuh mengonversi file SVG Anda?",
    ctaDesc: "Gunakan alat lokal kami untuk mengekspor gambar vektor SVG Anda menjadi file PNG transparan secara instan tanpa kirim data ke server.",
    ctaButton: "Coba Pengonversi SVG",
    homeText: "Beranda",
    compareLinkText: "Bandingkan"
  }
};

const text = pageTranslations[locale] || pageTranslations.es;

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": text.seoTitle,
      "description": text.seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": text.q1,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a1
          }
        },
        {
          "@type": "Question",
          "name": text.q2,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a2
          }
        },
        {
          "@type": "Question",
          "name": text.q3,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a3
          }
        },
        {
          "@type": "Question",
          "name": text.q4,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a2
          }
        },
        {
          "@type": "Question",
          "name": text.q5,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a5
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "svg-vs-png")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "svg-to-png");
---

<Layout title={text.seoTitle} description={text.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{text.homeText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{text.compareLinkText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">SVG vs PNG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">SVG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PNG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">{text.intro}</p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useTiffFor}</strong> {text.useTiffForDesc}</p>
          <p><strong class="text-ink">{text.useJxlFor}</strong> {text.useJxlForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm mb-8">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thTiff}</th>
                <th class="p-4">{text.thJxl}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompStandard}</td>
                <td class="p-4">{text.tdCompStandardTiff}</td>
                <td class="p-4">{text.tdCompStandardJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileSize}</td>
                <td class="p-4 text-success">{text.tdFileSizeTiff}</td>
                <td class="p-4 text-error">{text.tdFileSizeJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdColorDepth}</td>
                <td class="p-4">{text.tdColorDepthTiff}</td>
                <td class="p-4">{text.tdColorDepthJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdBrowser}</td>
                <td class="p-4">{text.tdBrowserTiff}</td>
                <td class="p-4">{text.tdBrowserJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdPrint}</td>
                <td class="p-4 text-success">{text.tdPrintTiff}</td>
                <td class="p-4 text-error">{text.tdPrintJxl}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTranscoding}</td>
                <td class="p-4 text-success">{text.tdTranscodingTiff}</td>
                <td class="p-4 text-error">{text.tdTranscodingJxl}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
        <FormatConverter toolId="svg-to-png" />
      </section>

      <!-- Deep Dive: SVG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveTiffTitle}</h2>
        <p>{text.diveTiffP1}</p>
        <p>{text.diveTiffP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveTiffAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveTiffAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- Deep Dive: PNG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveJxlTitle}</h2>
        <p>{text.diveJxlP1}</p>
        <p>{text.diveJxlP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveJxlAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveJxlAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.faqTitle}</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q1}</h3>
            <p class="text-body leading-relaxed">{text.a1}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q2}</h3>
            <p class="text-body leading-relaxed">{text.a2}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q3}</h3>
            <p class="text-body leading-relaxed">{text.a3}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q4}</h3>
            <p class="text-body leading-relaxed">{text.a4}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q5}</h3>
            <p class="text-body leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{text.moreComparisons || "Explore More Comparisons"}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{text.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{text.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {text.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="SVG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
