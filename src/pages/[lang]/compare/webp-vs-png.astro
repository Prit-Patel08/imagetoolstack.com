          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PNG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          {text.intro}
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useWebpFor}</strong> {text.useWebpForDesc}</p>
          <p><strong class="text-ink">{text.usePngFor}</strong> {text.usePngForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thWebp}</th>
                <th class="p-4">{text.thPng}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompression}</td>
                <td class="p-4">{text.tdCompressionWebp}</td>
                <td class="p-4">{text.tdCompressionPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTransparency}</td>
                <td class="p-4">{text.tdTransparencyWebp}</td>
                <td class="p-4">{text.tdTransparencyPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdQuality}</td>
                <td class="p-4">{text.tdQualityWebp}</td>
                <td class="p-4">{text.tdQualityPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdMetadata}</td>
                <td class="p-4">{text.tdMetadataWebp}</td>
                <td class="p-4">{text.tdMetadataPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdAnimation}</td>
                <td class="p-4">{text.tdAnimationWebp}</td>
                <td class="p-4">{text.tdAnimationPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdIdealFor}</td>
                <td class="p-4">{text.tdIdealForWebp}</td>
                <td class="p-4">{text.tdIdealForPng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileSize}</td>
                <td class="p-4">{text.tdFileSizeWebp}</td>
                <td class="p-4">{text.tdFileSizePng}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdWebSpeed}</td>
                <td class="p-4">{text.tdWebSpeedWebp}</td>
                <td class="p-4">{text.tdWebSpeedPng}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
        <FormatConverter toolId="webp-to-png" />
      </section>

      <!-- Real World Tests -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.testTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-8">
          {text.testDesc}
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <!-- PNG Test -->
          <div class="p-6 rounded-xl bg-canvas border border-hairline flex flex-col h-full">
            <div class="h-32 bg-gradient-to-br from-indigo-100 to-purple-100 rounded-lg mb-4 flex items-center justify-center relative overflow-hidden">
              <span class="text-indigo-800 font-bold text-lg">PNG (Lossless)</span>
            </div>
            <h3 class="font-bold text-ink text-xl mb-2">850 KB</h3>
            <p class="text-sm text-body flex-grow">{text.testPngDesc}</p>
          </div>
          
          <!-- WebP Lossless Test -->
          <div class="p-6 rounded-xl bg-canvas border border-link flex flex-col h-full relative">
            <div class="absolute -top-3 right-4 bg-link text-white text-xs font-bold px-3 py-1 rounded-full">Winner</div>
            <div class="h-32 bg-gradient-to-br from-green-100 to-emerald-100 rounded-lg mb-4 flex items-center justify-center relative overflow-hidden">
              <span class="text-emerald-800 font-bold text-lg">WebP (Lossless)</span>
            </div>
            <h3 class="font-bold text-ink text-xl mb-2">612 KB</h3>
            <p class="text-sm text-body flex-grow">{text.testWebpLosslessDesc}</p>
          </div>
          
          <!-- WebP Lossy Test -->
          <div class="p-6 rounded-xl bg-canvas border border-hairline flex flex-col h-full">
            <div class="h-32 bg-gradient-to-br from-orange-100 to-red-100 rounded-lg mb-4 flex items-center justify-center relative overflow-hidden">
              <span class="text-red-800 font-bold text-lg">WebP (Lossy 85%)</span>
            </div>
            <h3 class="font-bold text-ink text-xl mb-2">145 KB</h3>
            <p class="text-sm text-body flex-grow">{text.testWebpLossyDesc}</p>
          </div>
        </div>

        <p class="text-lg text-body leading-relaxed p-6 bg-canvas-soft rounded-lg border-l-4 border-link">
          {text.testTakeaway}
        </p>
      </section>

      <!-- Deep Dives -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.diveWebpTitle}</h2>
        <p>{text.diveWebpP1}</p>
        <p>{text.diveWebpP2}</p>
        
        <h3 class="text-2xl font-bold text-ink mt-8">{text.diveWebpAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveWebpAdvList.map((adv) => (
            <li>{adv}</li>
          ))}
        </ul>

        <h3 class="text-2xl font-bold text-ink mt-8">{text.diveWebpDis}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveWebpDisList.map((dis) => (
            <li>{dis}</li>
          ))}
        </ul>
      </section>

      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.divePngTitle}</h2>
        <p>{text.divePngP1}</p>
        <p>{text.divePngP2}</p>
        
        <h3 class="text-2xl font-bold text-ink mt-8">{text.divePngAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.divePngAdvList.map((adv) => (
            <li>{adv}</li>
          ))}
        </ul>

        <h3 class="text-2xl font-bold text-ink mt-8">{text.divePngDis}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.divePngDisList.map((dis) => (
            <li>{dis}</li>
          ))}
        </ul>
      </section>

      <!-- Detailed Comparisons & Use Cases (Featured Snippet Targeting) -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.snippetSectionTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.snippetSectionDesc}
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q1}</h3>
            <p class="leading-relaxed">{text.a1}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q2}</h3>
            <p class="leading-relaxed">{text.a2}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q3}</h3>
            <p class="leading-relaxed">{text.a3}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q4}</h3>
            <p class="leading-relaxed">{text.a4}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q5}</h3>
            <p class="leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{text.moreComparisons}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{text.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{text.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {text.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="WEBP" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
