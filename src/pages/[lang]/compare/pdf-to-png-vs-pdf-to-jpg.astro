const text = pageTranslations[locale] || pageTranslations.es;

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": text.seoTitle,
      "description": text.seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": text.q1,
          "acceptedAnswer": {
