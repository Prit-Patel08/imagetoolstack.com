const text = pageTranslations[locale] || pageTranslations.es;

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": text.seoTitle,
      "description": text.seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": text.q1,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a1
          }
        },
        {
          "@type": "Question",
          "name": text.q2,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a2
          }
        },
        {
          "@type": "Question",
          "name": text.q3,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a3
          }
        },
        {
          "@type": "Question",
          "name": text.q4,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a4
          }
        },
        {
          "@type": "Question",
          "name": text.q5,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": text.a5
          }
        }
      ]
