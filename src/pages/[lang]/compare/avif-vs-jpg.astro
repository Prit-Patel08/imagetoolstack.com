    differenceDesc: "Perbedaan utama ada pada teknologi kompresi. JPG adalah format 8-bit lawas tahun 90-an, sedangkan AVIF didasarkan pada codec video AV1 modern.",
    thFeature: "Fitur / Aspek",
    thTiff: "AVIF (AV1 Image File Format)",
    thJxl: "JPG (Joint Photographic Experts Group)",
    tdCompStandard: "Algoritma Kompresi",
    tdCompStandardTiff: "AV1 Intra-frame (Canggih)",
    tdCompStandardJxl: "Discrete Cosine Transform (DCT)",
    tdFileSize: "Ukuran File",
    tdFileSizeTiff: "Sangat kecil (hingga 50% lebih kecil dari JPG)",
    tdFileSizeJxl: "Standar hingga besar",
    tdColorDepth: "Dukungan Transparansi",
    tdColorDepthTiff: "Ya (mendukung saluran Alpha)",
    tdColorDepthJxl: "Tidak (latar belakang menjadi putih)",
    tdBrowser: "Kedalaman Warna",
    tdBrowserTiff: "Hingga 12-bit (mendukung HDR)",
    tdBrowserJxl: "Terbatas 8-bit (hanya SDR)",
    tdPrint: "Dukungan Browser",
    tdPrintTiff: "~97%+ (Semua browser modern)",
    tdPrintJxl: "100% universal",
    tdTranscoding: "Dukungan Animasi",
    tdTranscodingTiff: "Ya (AVIFS)",
    tdTranscodingJxl: "Tidak",
    converterTitle: "Konversi AVIF ke JPG (Offline & Privat)",
    diveTiffTitle: "Analisis Mendalam: Apa itu AVIF?",
    diveTiffP1: "AVIF singkatan dari AV1 Image File Format. Dikembangkan oleh Alliance for Open Media (AOMedia) tahun 2019, AVIF mengompresi gambar menggunakan codec video AV1 yang bebas royalti, dibungkus dalam wadah ISOBMFF.",
    diveTiffP2: "Karena efisiensi kompresinya yang luar biasa, AVIF sangat ideal untuk web modern. AVIF dapat menangani transparansi halus, rentang warna HDR, dan detail gambar yang tajam tanpa blur piksel kasar seperti JPG.",
    diveTiffAdv: "Kelebihan AVIF",
    diveTiffAdvList: [
      "Kompresi Superior: Memangkas ukuran file hingga 50% dibanding JPG dengan kualitas visual yang sama.",
      "Transparansi Sebenarnya: Mendukung opacity saluran alpha, menjadi pengganti PNG yang ideal.",
      "Warna Mendalam 12-bit: Mendukung monitor HDR tanpa adanya color banding."
    ],
    diveJxlTitle: "Analisis Mendalam: Apa itu JPG?",
