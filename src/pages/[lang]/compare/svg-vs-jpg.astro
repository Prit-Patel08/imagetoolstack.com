const t = pageTranslations[locale];

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": t.seoTitle,
      "description": t.seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": t.q1,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t.a1
          }
        },
        {
          "@type": "Question",
          "name": t.q2,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t.a2
          }
        },
        {
          "@type": "Question",
          "name": t.q3,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t.a3
          }
        },
        {
          "@type": "Question",
          "name": t.q4,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t.a4
          }
        },
        {
          "@type": "Question",
          "name": t.q5,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t.a5
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "svg-vs-jpg")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "image-to-svg");
---

<Layout title={t.seoTitle} description={t.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{t.homeText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{t.compareLinkText}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">SVG vs JPG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">SVG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">JPG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{t.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">{t.intro}</p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {t.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{t.usePngFor}</strong> {t.usePngForDesc}</p>
          <p><strong class="text-ink">{t.useIcoFor}</strong> {t.useIcoForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{t.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">{t.differenceDesc}</p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{t.thFeature}</th>
                <th class="p-4">{t.thPng}</th>
                <th class="p-4">{t.thIco}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdFileNature}</td>
                <td class="p-4 text-success">{t.tdFileNaturePng}</td>
                <td class="p-4">{t.tdFileNatureIco}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdFallback}</td>
                <td class="p-4 text-success">{t.tdFallbackPng}</td>
                <td class="p-4 text-error">{t.tdFallbackIco}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdPurpose}</td>
                <td class="p-4 text-error">{t.tdPurposePng}</td>
                <td class="p-4 text-success">{t.tdPurposeIco}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdResolutions}</td>
                <td class="p-4 text-success">{t.tdResolutionsPng}</td>
                <td class="p-4">{t.tdResolutionsIco}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdSize}</td>
                <td class="p-4 text-success">{t.tdSizePng}</td>
                <td class="p-4 text-error">{t.tdSizeIco}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{t.tdTrans}</td>
                <td class="p-4 text-success">{t.tdTransPng}</td>
                <td class="p-4 text-error">{t.tdTransIco}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{t.converterTitle}</h2>
        <VectorizerTool toolId="jpg-to-svg" />
      </section>

      <!-- Deep Dive: SVG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{t.divePngTitle}</h2>
        <p>{t.divePngP1}</p>
        <p>{t.divePngP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{t.divePngAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {t.divePngAdvList.map((adv) => (
            <li><strong>{adv.split(":")[0]}:</strong>{adv.split(":")[1]}</li>
          ))}
        </ul>
      </section>

      <!-- Deep Dive: JPG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{t.diveIcoTitle}</h2>
        <p>{t.diveIcoP1}</p>
        <p>{t.diveIcoP2}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{t.diveIcoAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {t.diveIcoAdvList.map((adv) => (
            <li><strong>{adv.split(":")[0]}:</strong>{adv.split(":")[1]}</li>
          ))}
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{t.faqTitle}</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{t.q1}</h3>
            <p class="text-body leading-relaxed">{t.a1}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{t.q2}</h3>
            <p class="text-body leading-relaxed">{t.a2}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{t.q3}</h3>
            <p class="text-body leading-relaxed">{t.a3}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{t.q4}</h3>
            <p class="text-body leading-relaxed">{t.a4}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{t.q5}</h3>
            <p class="text-body leading-relaxed">{t.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{t.moreComparisons}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{t.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{t.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {t.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="SVG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
