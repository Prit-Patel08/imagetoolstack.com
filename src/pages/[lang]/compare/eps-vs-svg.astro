<Layout title={text.seoTitle} description={text.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{text.homeText || "Home"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{text.compareLinkText || "Compare"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">EPS vs SVG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 px-6 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">EPS</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 px-6 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">SVG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          {text.intro}
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useEpsFor}</strong> {text.useEpsForDesc}</p>
          <p><strong class="text-ink">{text.useSvgFor}</strong> {text.useSvgForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm mb-8">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thEps}</th>
                <th class="p-4">{text.thSvg}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdPrimaryTarget || "Primary Target"}</td>
                <td class="p-4">{text.tdPrimaryTargetEps}</td>
                <td class="p-4">{text.tdPrimaryTargetSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdBrowserSupport || "Browser Support"}</td>
                <td class="p-4 text-error">{text.tdBrowserSupportEps}</td>
                <td class="p-4 text-success">{text.tdBrowserSupportSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCodeStyling || "Code-Based Styling"}</td>
                <td class="p-4 text-error">{text.tdCodeStylingEps}</td>
                <td class="p-4 text-success">{text.tdCodeStylingSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdAnimation || "Animation"}</td>
                <td class="p-4 text-error">{text.tdAnimationEps}</td>
                <td class="p-4 text-success">{text.tdAnimationSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileStructure || "File Structure"}</td>
                <td class="p-4">{text.tdFileStructureEps}</td>
                <td class="p-4">{text.tdFileStructureSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdPrintOpt || "Print Optimization"}</td>
                <td class="p-4 text-success">{text.tdPrintOptEps}</td>
                <td class="p-4">{text.tdPrintOptSvg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTransparency || "Transparency Support"}</td>
                <td class="p-4 text-success">{text.tdTransparencyEps}</td>
                <td class="p-4 text-success">{text.tdTransparencySvg}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
