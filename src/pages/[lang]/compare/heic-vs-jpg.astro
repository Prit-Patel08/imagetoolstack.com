const relatedTool = toolsData.tools.find(t => t.slug === "heic-to-jpg");
---

<Layout title={text.seoTitle} description={text.seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href={getLocalizedPath("/", locale)} class="hover:text-ink transition-colors">{text.homeText || "Home"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={getLocalizedPath("/compare", locale)} class="hover:text-ink transition-colors">{text.compareLinkText || "Compare"}</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">HEIC vs JPG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">HEIC</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">JPG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{text.title}</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          {text.intro}
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          {text.quickAnswer}
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">{text.useHeicFor}</strong> {text.useHeicForDesc}</p>
          <p><strong class="text-ink">{text.useJpgFor}</strong> {text.useJpgForDesc}</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">{text.differenceTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.differenceDesc}
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">{text.thFeature}</th>
                <th class="p-4">{text.thHeic}</th>
                <th class="p-4">{text.thJpg}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompStandard || "Compression Standard"}</td>
                <td class="p-4">{text.tdCompStandardHeic}</td>
                <td class="p-4">{text.tdCompStandardJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdFileSize || "Average File Size"}</td>
                <td class="p-4 text-success">{text.tdFileSizeHeic}</td>
                <td class="p-4">{text.tdFileSizeJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdColorDepth || "Color Depth Support"}</td>
                <td class="p-4 text-success">{text.tdColorDepthHeic}</td>
                <td class="p-4 text-error">{text.tdColorDepthJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdTransparency || "Transparency Support"}</td>
                <td class="p-4 text-success">{text.tdTransparencyHeic}</td>
                <td class="p-4 text-error">{text.tdTransparencyJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdContainer || "Multi-Image Container"}</td>
                <td class="p-4 text-success">{text.tdContainerHeic}</td>
                <td class="p-4 text-error">{text.tdContainerJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdBrowser || "Web Browser Support"}</td>
                <td class="p-4 text-error">{text.tdBrowserHeic}</td>
                <td class="p-4 text-success">{text.tdBrowserJpg}</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">{text.tdCompatibility || "Compatibility"}</td>
                <td class="p-4 text-error">{text.tdCompatibilityHeic}</td>
                <td class="p-4 text-success">{text.tdCompatibilityJpg}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">{text.converterTitle}</h2>
        <HeicToJpgTool toolId="heic-to-jpg" />
      </section>

      <!-- Real World Tests -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.testTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-8">
          {text.testDesc}
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <!-- HEIC Test -->
          <div class="p-6 rounded-xl bg-canvas border border-link flex flex-col h-full relative">
            <div class="absolute -top-3 right-4 bg-link text-white text-xs font-bold px-3 py-1 rounded-full">{locale === 'es' ? 'Ganador de almacenamiento' : locale === 'fr' ? 'Gagnant Stockage' : locale === 'de' ? 'Speicher-Gewinner' : locale === 'pt' ? 'Vencedor para Armazenamento' : 'Pemenang Penyimpanan'}</div>
            <div class="h-32 bg-gradient-to-br from-indigo-100 to-purple-100 rounded-lg mb-4 flex flex-col items-center justify-center relative overflow-hidden">
              <span class="text-indigo-800 font-bold text-lg mb-1">{text.testHeicTitle}</span>
              <span class="text-indigo-900/60 text-xs">{text.testHeicSub}</span>
            </div>
            <h3 class="font-bold text-ink text-xl mb-2">{text.testHeicSize}</h3>
            <p class="text-sm text-body flex-grow">{text.testHeicDesc}</p>
          </div>
          
          <!-- JPG Test -->
          <div class="p-6 rounded-xl bg-canvas border border-hairline flex flex-col h-full">
            <div class="h-32 bg-gradient-to-br from-orange-100 to-red-100 rounded-lg mb-4 flex flex-col items-center justify-center relative overflow-hidden">
              <span class="text-red-800 font-bold text-lg mb-1">{text.testJpgTitle}</span>
              <span class="text-red-900/60 text-xs">{text.testJpgSub}</span>
            </div>
            <h3 class="font-bold text-ink text-xl mb-2">{text.testJpgSize}</h3>
            <p class="text-sm text-body flex-grow">{text.testJpgDesc}</p>
          </div>
        </div>
      </section>

      <!-- Deep Dive: HEIC -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveHeicTitle}</h2>
        <p>{text.diveHeicP1}</p>
        <p>{text.diveHeicP2}</p>
        
        <h3 class="text-2xl font-bold text-ink mt-8">{locale === 'es' ? 'Más que solo compresión' : locale === 'fr' ? 'Plus que de la compression' : locale === 'de' ? 'Mehr als nur Kompression' : locale === 'pt' ? 'Mais do que apenas compressão' : 'Lebih dari sekadar kompresi'}</h3>
        <p>{text.diveHeicP3}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveHeicAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveHeicAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-error">{locale === 'es' ? 'Desventajas de HEIC' : locale === 'fr' ? 'Inconvénients du HEIC' : locale === 'de' ? 'Nachteile von HEIC' : locale === 'pt' ? 'Desvantagens do HEIC' : 'Kekurangan HEIC'}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveHeicDisList.map((dis) => (
            <li><strong>{dis.split(':')[0]}:</strong>{dis.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- Deep Dive: JPG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">{text.diveJpgTitle}</h2>
        <p>{text.diveJpgP1}</p>
        <p>{text.diveJpgP2}</p>
        
        <h3 class="text-2xl font-bold text-ink mt-8">{locale === 'es' ? 'El rey indiscutible de la compatibilidad' : locale === 'fr' ? 'Le roi incontesté de la compatibilité' : locale === 'de' ? 'Der unangefochtene König der Kompatibilität' : locale === 'pt' ? 'O rei indiscutível da compatibilidade' : 'Raja kompatibilitas yang tak terbantahkan'}</h3>
        <p>{text.diveJpgP3}</p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">{text.diveJpgAdv}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveJpgAdvList.map((adv) => (
            <li><strong>{adv.split(':')[0]}:</strong>{adv.split(':')[1]}</li>
          ))}
        </ul>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-error">{locale === 'es' ? 'Desventajas de JPG' : locale === 'fr' ? 'Inconvénients du JPG' : locale === 'de' ? 'Nachteile von JPG' : locale === 'pt' ? 'Desvantagens do JPG' : 'Kekurangan JPG'}</h3>
        <ul class="list-disc pl-6 space-y-2">
          {text.diveJpgDisList.map((dis) => (
            <li><strong>{dis.split(':')[0]}:</strong>{dis.split(':')[1]}</li>
          ))}
        </ul>
      </section>

      <!-- Detailed Comparisons & Use Cases -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.snippetSectionTitle}</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          {text.snippetSectionDesc}
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q1}</h3>
            <p class="leading-relaxed">{text.a1}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q2}</h3>
            <p class="leading-relaxed">{text.a2}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q3}</h3>
            <p class="leading-relaxed">{text.a3}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q4}</h3>
            <p class="leading-relaxed">{text.a4}</p>
          </div>

          <div>
            <h3 class="text-xl font-bold text-ink mb-2">{text.q5}</h3>
            <p class="leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">{text.faqTitle}</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q1}</h3>
            <p class="text-body leading-relaxed">{text.a1}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q2}</h3>
            <p class="text-body leading-relaxed">{text.a2}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q3}</h3>
            <p class="text-body leading-relaxed">{text.a3}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q4}</h3>
            <p class="text-body leading-relaxed">{text.a4}</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">{text.q5}</h3>
            <p class="text-body leading-relaxed">{text.a5}</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">{text.moreComparisons}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={getLocalizedPath(`/compare/${relatedComp.id}`, locale)} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">{text.ctaTitle}</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">{text.ctaDesc}</p>
          <a href={getLocalizedPath(`/tools/${relatedTool.slug}`, locale)} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            {text.ctaButton}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="HEIC" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
