---
import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { defaultLocale } from "../../data/translations";

export function getStaticPaths() {
  const locales = ['es', 'fr', 'de', 'pt', 'id'];
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const articles = await getCollection('articles');

// Sort by date descending
const sortedArticles = articles.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
const heroArticle = sortedArticles[0];
const remainingArticles = sortedArticles.slice(1);

// Basic localized SEO strings (could use i18n dictionary if wanted)
let seoTitle = "Image Formats & Optimization Guides";
let seoDescription = "Learn everything about image formats, compression, and SEO optimization. Read our comprehensive guides to mastering digital images.";
let headingPrefix = "Expert ";
let headingHighlight = "Guides";
let headingSuffix = " & Insights";
let subheading = "Master image optimization, improve Core Web Vitals, and learn the exact techniques professionals use to build faster, higher-ranking websites.";
let readArticleStr = "Read Full Guide";
let allArticlesStr = "All Articles";
let featuredStr = "Featured";
let guideStr = "Guide";

if (lang === 'es') {
  seoTitle = "Guías de Optimización de Imagen y SEO";
  seoDescription = "Lea nuestras guías detalladas sobre optimización de imágenes, Core Web Vitals y mejores prácticas de SEO.";
  headingPrefix = "Guías y ";
  headingHighlight = "Perspectivas";
  headingSuffix = " de Expertos";
  subheading = "Domine la optimización de imágenes, mejore Core Web Vitals y aprenda las técnicas exactas que utilizan los profesionales para crear sitios web más rápidos.";
  readArticleStr = "Leer guía completa";
  allArticlesStr = "Todos los artículos";
  featuredStr = "Destacado";
  guideStr = "Guía";
} else if (lang === 'fr') {
  seoTitle = "Guides d'Optimisation d'Image et SEO";
  seoDescription = "Lisez nos guides approfondis sur l'optimisation des images, les Core Web Vitals et les meilleures pratiques SEO.";
  headingPrefix = "Guides et ";
  headingHighlight = "Aperçus";
  headingSuffix = " d'Experts";
  subheading = "Maîtrisez l'optimisation des images, améliorez les Core Web Vitals et apprenez les techniques exactes utilisées par les professionnels.";
  readArticleStr = "Lire le guide complet";
  allArticlesStr = "Tous les articles";
  featuredStr = "En vedette";
  guideStr = "Guide";
} else if (lang === 'de') {
  seoTitle = "Bildoptimierungs-Guides & SEO-Tipps";
  seoDescription = "Lesen Sie unsere detaillierten Leitfäden zur Bildoptimierung, Core Web Vitals und SEO-Best-Practices.";
  headingPrefix = "Experten-";
  headingHighlight = "Guides";
  headingSuffix = " & Einblicke";
  subheading = "Meistern Sie die Bildoptimierung, verbessern Sie die Core Web Vitals und lernen Sie die genauen Techniken der Profis.";
  readArticleStr = "Vollständigen Leitfaden lesen";
  allArticlesStr = "Alle Artikel";
  featuredStr = "Empfohlen";
  guideStr = "Leitfaden";
} else if (lang === 'pt') {
  seoTitle = "Guias de Otimização de Imagem e SEO";
  seoDescription = "Leia nossos guias detalhados sobre otimização de imagens, Core Web Vitals e melhores práticas de SEO.";
  headingPrefix = "Guias e ";
  headingHighlight = "Insights";
  headingSuffix = " de Especialistas";
  subheading = "Domine a otimização de imagens, melhore os Core Web Vitals e aprenda as técnicas exatas que os profissionais usam.";
  readArticleStr = "Ler guia completo";
  allArticlesStr = "Todos os artigos";
  featuredStr = "Destaque";
  guideStr = "Guia";
} else if (lang === 'id') {
  seoTitle = "Panduan Optimasi Gambar & Tips SEO";
  seoDescription = "Baca panduan mendalam kami tentang optimasi gambar, Core Web Vitals, dan praktik terbaik SEO.";
  headingPrefix = "Panduan & ";
  headingHighlight = "Wawasan";
  headingSuffix = " Ahli";
  subheading = "Kuasai optimasi gambar, tingkatkan Core Web Vitals, dan pelajari teknik tepat yang digunakan para profesional.";
  readArticleStr = "Baca Panduan Lengkap";
  allArticlesStr = "Semua Artikel";
  featuredStr = "Unggulan";
  guideStr = "Panduan";
}
---

<Layout title={seoTitle} description={seoDescription}>
  <Navbar />
  
  <main class="w-full bg-canvas pb-24">
    <!-- Header Section -->
    <div class="relative overflow-hidden border-b border-hairline bg-canvas-soft pt-16 pb-20 lg:pt-24 lg:pb-28">
      <!-- Decorative background glow -->
      <div class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-link/10 blur-3xl mix-blend-multiply opacity-70 animate-pulse-slow"></div>
      
      <div class="relative mx-auto max-w-[1400px] px-6 lg:px-8 text-center">
        <h1 class="text-5xl font-extrabold tracking-tight text-ink sm:text-6xl mb-6">
          {headingPrefix}<span class="text-transparent bg-clip-text bg-gradient-to-r from-link to-purple-500">{headingHighlight}</span>{headingSuffix}
        </h1>
        <p class="mx-auto max-w-2xl text-xl text-body leading-relaxed">
          {subheading}
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-[1400px] px-6 lg:px-8 -mt-10 relative z-10">
      <!-- Hero Article -->
      {heroArticle && (
        <a href={`/${lang}/${heroArticle.id}`} class="group block mb-16 rounded-3xl bg-canvas border border-hairline shadow-lg overflow-hidden transition-all hover:shadow-xl hover:border-link/50 hover:-translate-y-1">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-10 lg:p-14 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-6">
                <span class="inline-flex items-center rounded-full bg-link/10 px-3 py-1 text-xs font-semibold text-link uppercase tracking-wider">
                  {heroArticle.data.category || featuredStr}
                </span>
                <time class="text-sm font-medium text-mute" datetime={heroArticle.data.pubDate.toISOString()}>
                  {new Date(heroArticle.data.pubDate).toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h2 class="text-3xl lg:text-4xl font-bold text-ink mb-6 group-hover:text-link transition-colors leading-tight">
                {heroArticle.data.title}
              </h2>
              <p class="text-lg text-body leading-relaxed mb-8 line-clamp-3">
                {heroArticle.data.description}
              </p>
              <div class="mt-auto inline-flex items-center text-sm font-bold text-link group-hover:gap-2 transition-all">
                {readArticleStr}
                <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
              </div>
            </div>
            <!-- Abstract Hero Pattern -->
            <div class="hidden lg:block bg-gradient-to-br from-canvas-soft to-canvas border-l border-hairline relative overflow-hidden">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,_var(--tw-gradient-stops))] from-link/20 via-transparent to-transparent opacity-50"></div>
              <div class="absolute right-0 bottom-0 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl transform translate-x-1/2 translate-y-1/2"></div>
              <div class="w-full h-full flex items-center justify-center p-12">
                <div class="w-full max-w-sm aspect-square rounded-2xl bg-white/5 shadow-2xl border border-white/10 backdrop-blur-sm flex items-center justify-center transform group-hover:scale-105 group-hover:rotate-3 transition-transform duration-500">
                  <svg class="w-32 h-32 text-link/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"></path></svg>
                </div>
              </div>
            </div>
          </div>
        </a>
      )}

      <!-- Articles Grid -->
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-2xl font-bold text-ink">{allArticlesStr}</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {remainingArticles.map((article) => (
          <a href={`/${lang}/${article.id}`} class="group flex flex-col p-8 rounded-2xl bg-canvas border border-hairline hover:border-link/50 transition-all hover:shadow-lg hover:-translate-y-1 h-full">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center rounded-full bg-canvas-soft px-2.5 py-0.5 text-xs font-semibold text-body uppercase tracking-wider group-hover:bg-link/10 group-hover:text-link transition-colors">
                {article.data.category || guideStr}
              </span>
              <time class="text-xs font-medium text-mute" datetime={article.data.pubDate.toISOString()}>
                {new Date(article.data.pubDate).toLocaleDateString(lang, { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h2 class="text-xl font-bold text-ink mb-4 group-hover:text-link transition-colors leading-snug">
              {article.data.title}
            </h2>
            <p class="text-sm text-body leading-relaxed flex-grow line-clamp-3 mb-6">
              {article.data.description}
            </p>
            <div class="mt-auto flex items-center text-sm font-semibold text-link">
              {readArticleStr}
              <svg class="ml-1.5 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
