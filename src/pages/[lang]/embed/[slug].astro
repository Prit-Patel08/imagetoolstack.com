---
import EmbedLayout from "../../../layouts/EmbedLayout.astro";
import FormatConverter from "../../../components/tools/FormatConverter.astro";
import Base64Converter from "../../../components/tools/Base64Converter.astro";
import ImageResizer from "../../../components/tools/ImageResizer.astro";
import ColorPickerTool from "../../../components/tools/ColorPickerTool.astro";
import MetadataViewerTool from "../../../components/tools/MetadataViewerTool.astro";
import CropperTool from "../../../components/tools/CropperTool.astro";
import HeicToJpgTool from "../../../components/tools/HeicToJpgTool.astro";
import BulkResizerTool from "../../../components/tools/BulkResizerTool.astro";
import RemoveBgTool from "../../../components/tools/RemoveBgTool.astro";
import ImageToPdfTool from "../../../components/tools/ImageToPdfTool.astro";
import PdfToJpgTool from "../../../components/tools/PdfToJpgTool.astro";
import RotateImageTool from "../../../components/tools/RotateImageTool.astro";
import FlipImageTool from "../../../components/tools/FlipImageTool.astro";
import AddWatermarkTool from "../../../components/tools/AddWatermarkTool.astro";
import GrayscaleFilterTool from "../../../components/tools/GrayscaleFilterTool.astro";
import TiffToJpgTool from "../../../components/tools/TiffToJpgTool.astro";
import Base64ToImageTool from "../../../components/tools/Base64ToImageTool.astro";
import IcoConverterTool from "../../../components/tools/IcoConverterTool.astro";
import FaviconGeneratorTool from "../../../components/tools/FaviconGeneratorTool.astro";
import ImageSharpenerTool from "../../../components/tools/ImageSharpenerTool.astro";
import BlurImageTool from "../../../components/tools/BlurImageTool.astro";
import InvertColorsTool from "../../../components/tools/InvertColorsTool.astro";
import SepiaFilterTool from "../../../components/tools/SepiaFilterTool.astro";
import BrightnessAdjusterTool from "../../../components/tools/BrightnessAdjusterTool.astro";
import ContrastAdjusterTool from "../../../components/tools/ContrastAdjusterTool.astro";
import ImageSplitterTool from "../../../components/tools/ImageSplitterTool.astro";
import CollageMakerTool from "../../../components/tools/CollageMakerTool.astro";
import TextOverlayTool from "../../../components/tools/TextOverlayTool.astro";
import CircleCropTool from "../../../components/tools/CircleCropTool.astro";
import SocialResizerTool from "../../../components/tools/SocialResizerTool.astro";
import ImageDifferenceTool from "../../../components/tools/ImageDifferenceTool.astro";
import MergePdfTool from "../../../components/tools/MergePdfTool.astro";
import SplitPdfTool from "../../../components/tools/SplitPdfTool.astro";
import CompressPdfTool from "../../../components/tools/CompressPdfTool.astro";
import JpgToPdfTool from "../../../components/tools/JpgToPdfTool.astro";
import PdfToPngTool from "../../../components/tools/PdfToPngTool.astro";
import RemovePdfPagesTool from "../../../components/tools/RemovePdfPagesTool.astro";
import RotatePdfTool from "../../../components/tools/RotatePdfTool.astro";
import DefaultTool from "../../../components/ImageTool.astro";
import toolsData from "../../../data/tools.json";
import { translateTool } from '../../../utils/i18n';

export async function getStaticPaths() {
  const locales = ['es', 'fr', 'de', 'pt', 'id'];
  return locales.flatMap(lang => 
    toolsData.tools.map((tool) => ({
      params: { lang, slug: tool.slug },
      props: { tool },
    }))
  );
}

const { lang } = Astro.params;
const { tool } = Astro.props;
const localizedTool = translateTool(tool, lang);

let ToolComponent = DefaultTool;

const formatConverters = ['png-to-jpg', 'jpg-to-png', 'webp-to-png', 'png-to-webp', 'svg-to-png', 'image-compressor', 'jpg-to-webp', 'gif-to-png', 'bmp-to-jpg', 'avif-to-png', 'png-to-avif', 'webp-to-jpg', 'jpg-to-avif'];

if (formatConverters.includes(tool.slug)) {
  ToolComponent = FormatConverter;
} else if (tool.slug === 'image-to-base64') {
  ToolComponent = Base64Converter;
} else if (tool.slug === 'image-resizer') {
  ToolComponent = ImageResizer;
} else if (tool.slug === 'color-picker') {
  ToolComponent = ColorPickerTool;
} else if (tool.slug === 'metadata-viewer') {
  ToolComponent = MetadataViewerTool;
} else if (tool.slug === 'crop-image') {
  ToolComponent = CropperTool;
} else if (tool.slug === 'heic-to-jpg') {
  ToolComponent = HeicToJpgTool;
} else if (tool.slug === 'bulk-resizer') {
  ToolComponent = BulkResizerTool;
} else if (tool.slug === 'remove-bg') {
  ToolComponent = RemoveBgTool;
} else if (tool.slug === 'image-to-pdf' || tool.slug === 'screenshot-to-pdf') {
  ToolComponent = ImageToPdfTool;
} else if (tool.slug === 'pdf-to-jpg') {
  ToolComponent = PdfToJpgTool;
} else if (tool.slug === 'rotate-image') {
  ToolComponent = RotateImageTool;
} else if (tool.slug === 'flip-image') {
  ToolComponent = FlipImageTool;
} else if (tool.slug === 'add-watermark') {
  ToolComponent = AddWatermarkTool;
} else if (tool.slug === 'grayscale-filter') {
  ToolComponent = GrayscaleFilterTool;
} else if (tool.slug === 'tiff-to-jpg') {
  ToolComponent = TiffToJpgTool;
} else if (tool.slug === 'base64-to-image') {
  ToolComponent = Base64ToImageTool;
} else if (tool.slug === 'ico-converter') {
  ToolComponent = IcoConverterTool;
} else if (tool.slug === 'favicon-generator') {
  ToolComponent = FaviconGeneratorTool;
} else if (tool.slug === 'image-sharpener') {
  ToolComponent = ImageSharpenerTool;
} else if (tool.slug === 'blur-image') {
  ToolComponent = BlurImageTool;
} else if (tool.slug === 'invert-colors') {
  ToolComponent = InvertColorsTool;
} else if (tool.slug === 'sepia-filter') {
  ToolComponent = SepiaFilterTool;
} else if (tool.slug === 'adjust-brightness') {
  ToolComponent = BrightnessAdjusterTool;
} else if (tool.slug === 'adjust-contrast') {
  ToolComponent = ContrastAdjusterTool;
} else if (tool.slug === 'image-splitter') {
  ToolComponent = ImageSplitterTool;
} else if (tool.slug === 'collage-maker') {
  ToolComponent = CollageMakerTool;
} else if (tool.slug === 'meme-generator' || tool.slug === 'add-text-to-image') {
  ToolComponent = TextOverlayTool;
} else if (tool.slug === 'circle-crop') {
  ToolComponent = CircleCropTool;
} else if (tool.slug === 'passport-photo-maker' || tool.slug === 'instagram-resizer' || tool.slug === 'twitter-header-maker' || tool.slug === 'youtube-thumbnail' || tool.slug === 'linkedin-banner' || tool.slug === 'facebook-cover') {
  ToolComponent = SocialResizerTool;
} else if (tool.slug === 'compare-images') {
  ToolComponent = ImageDifferenceTool;
} else if (tool.slug === 'merge-pdf') {
  ToolComponent = MergePdfTool;
} else if (tool.slug === 'split-pdf') {
  ToolComponent = SplitPdfTool;
} else if (tool.slug === 'compress-pdf') {
  ToolComponent = CompressPdfTool;
} else if (tool.slug === 'jpg-to-pdf') {
  ToolComponent = JpgToPdfTool;
} else if (tool.slug === 'pdf-to-png') {
  ToolComponent = PdfToPngTool;
} else if (tool.slug === 'remove-pdf-pages') {
  ToolComponent = RemovePdfPagesTool;
} else if (tool.slug === 'rotate-pdf') {
  ToolComponent = RotatePdfTool;
}

let localText = "100% Local";
if (lang === 'es') localText = "100% Local";
else if (lang === 'fr') localText = "100% Local";
else if (lang === 'de') localText = "100% Lokal";
else if (lang === 'pt') localText = "100% Local";
else if (lang === 'id') localText = "100% Lokal";

---

<EmbedLayout title={localizedTool.name}>
  <div class="w-full max-w-4xl mx-auto min-h-[400px] flex flex-col items-center justify-center bg-canvas-soft/50 p-6 rounded-lg border border-hairline relative">
    <div class="absolute top-4 right-4 flex items-center gap-1.5 px-2 py-1 bg-success/10 text-success text-[10px] uppercase font-bold rounded-full border border-success/20">
      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      {localText}
    </div>
    
    <ToolComponent toolId={tool.id} />
  </div>
</EmbedLayout>
