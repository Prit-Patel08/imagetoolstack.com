---
import RootToolPage from "./tools/[slug].astro";
import toolsData from "../data/tools.json";

const baseTool = toolsData.tools.find((tool) => tool.slug === "image-sharpener");
const category = toolsData.categories.find((cat) => cat.id === baseTool?.categoryId);

const tool = {
  ...baseTool,
  name: "Sharpen Image Online",
  seoTitle: "Sharpen Image Online | Free Browser-Based Image Sharpener",
  seoDescription: "Sharpen images online for free. Improve photo clarity directly in your browser with no uploads, no signup, and private local processing.",
};
---

<RootToolPage tool={tool} category={category} />
