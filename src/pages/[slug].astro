---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
import { render } from 'astro:content';
const { Content } = await render(entry);

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.id !== entry.id)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 4);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Image Tool Stack"
  }
};

// Indexing: only finalized articles get index,follow
import indexablePages from "../data/indexable-pages.json";
const isIndexable = indexablePages.articles.includes(entry.id);
const robots = isIndexable ? "index, follow" : "noindex, nofollow";
---
<Layout title={`${entry.data.title} | Image Tool Stack`} description={entry.data.description} robots={robots} schema={articleSchema}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[800px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/articles" class="hover:text-ink transition-colors">Articles</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink truncate">{entry.data.title}</span>
      </nav>
    </div>

    <article class="mx-auto max-w-[800px] px-6 py-12 lg:px-8 lg:py-16">
      <header class="mb-12">
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{entry.data.title}</h1>
        <p class="text-xl text-body leading-relaxed">{entry.data.description}</p>
        <div class="mt-6 flex items-center gap-4 text-sm text-mute">
          <span>By Image Tool Stack</span>
          <span>•</span>
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </header>

      <div class="prose prose-lg max-w-none text-body prose-headings:text-ink prose-a:text-link hover:prose-a:text-link-hover prose-strong:text-ink mb-16">
        <Content />
      </div>

      <!-- Related Guides -->
      {relatedArticles.length > 0 && (
        <section class="mb-16 border-t border-hairline pt-12">
          <h2 class="text-2xl font-bold text-ink mb-6">More Guides & Articles</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedArticles.map((related) => (
              <a href={`/${related.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex flex-col justify-between h-full">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors mb-2">{related.data.title}</h3>
                  <p class="text-sm text-body line-clamp-2">{related.data.description}</p>
                </div>
                <div class="mt-4 flex items-center text-xs font-semibold text-link">
                  Read article <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="p-8 rounded-2xl bg-canvas-soft border border-hairline text-center">
        <h2 class="text-2xl font-bold text-ink mb-4">Start Processing Images Now</h2>
        <p class="text-body mb-6">Use our 100% free, private, browser-based image tools.</p>
        <a href="/" class="inline-flex items-center justify-center rounded-lg bg-link px-6 py-3 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
          Browse All Tools
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
