---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact Us">
  <Navbar />
  
  <main class="mx-auto max-w-3xl px-6 py-16 lg:px-8 lg:py-24 text-center">
    <h1 class="text-4xl font-semibold tracking-tight text-ink sm:text-5xl mb-6">Get in Touch</h1>
    <p class="text-lg text-body mb-12">Have a suggestion for a new tool or found a bug? We'd love to hear from you.</p>
    
    <div class="mx-auto max-w-lg text-left">
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-ink mb-2">Name</label>
          <input type="text" id="name" name="name" class="w-full rounded-md border border-hairline bg-canvas px-4 py-2 text-ink focus:border-ink focus:outline-none" placeholder="Jane Doe" required />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-ink mb-2">Email</label>
          <input type="email" id="email" name="email" class="w-full rounded-md border border-hairline bg-canvas px-4 py-2 text-ink focus:border-ink focus:outline-none" placeholder="jane@example.com" required />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
          <textarea id="message" name="message" rows="4" class="w-full rounded-md border border-hairline bg-canvas px-4 py-2 text-ink focus:border-ink focus:outline-none" placeholder="How can we help?" required></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">Send Message</button>
      </form>
      
      <div class="mt-16 border-t border-hairline pt-12 text-center">
        <h2 class="text-sm font-mono uppercase tracking-widest text-mute mb-4">Direct Email</h2>
        <a href="mailto:hello@imagetoolstack.com" class="text-xl font-semibold text-ink hover:text-link transition-colors">hello@imagetoolstack.com</a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
