---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import comparisonsData from "../../data/comparisons.json";
import { translateComparison, getLocalizedPath } from "../../utils/i18n";

const locale = Astro.currentLocale || 'en';

const seoTitle = locale === 'es' ? "Comparaciones de formatos de imagen | ¿Cuál es mejor?" :
                 locale === 'fr' ? "Comparaisons de formats d'image | Lequel choisir ?" :
                 locale === 'de' ? "Bildformatvergleiche | Was ist besser?" :
                 locale === 'pt' ? "Comparações de formatos de imagem | Qual é melhor?" :
                 locale === 'id' ? "Perbandingan Format Gambar | Mana yang Lebih Baik?" : "Image Format Comparisons | Which is Better?";

const seoDescription = locale === 'es' ? "Profundice en las diferencias técnicas entre los formatos de imagen populares. Compare PNG, JPG, WebP, AVIF, HEIC y más para encontrar el mejor." :
                       locale === 'fr' ? "Plongez dans les différences techniques entre les formats d'image populaires. Comparez PNG, JPG, WebP, AVIF, HEIC et plus encore." :
                       locale === 'de' ? "Tauchen Sie tief in die technischen Unterschiede zwischen beliebten Bildformaten ein. Vergleichen Sie PNG, JPG, WebP, AVIF, HEIC und mehr." :
                       locale === 'pt' ? "Aprofunde-se nas diferenças técnicas entre formatos de imagem populares. Compare PNG, JPG, WebP, AVIF, HEIC e muito mais." :
                       locale === 'id' ? "Pelajari lebih mendalam perbedaan teknis antara format gambar populer. Bandingkan PNG, JPG, WebP, AVIF, HEIC, dan lainnya." : "Deep dive into the technical differences between popular image formats. Compare PNG, JPG, WebP, AVIF, HEIC, and more to find the best format for your needs.";

const pageHeading = locale === 'es' ? "Comparaciones de formatos de imagen" :
                    locale === 'fr' ? "Comparaisons de formats d'image" :
                    locale === 'de' ? "Bildformat-Vergleiche" :
                    locale === 'pt' ? "Comparações de formatos de imagem" :
                    locale === 'id' ? "Perbandingan Format Gambar" : "Image Format Comparisons";

const pageSubtitle = locale === 'es' ? "¿No está seguro de qué formato de imagen usar? Hemos creado comparaciones técnicas detalladas para ayudarle a elegir el formato perfecto para diseño web, fotografía, impresión y más." :
                     locale === 'fr' ? "Vous ne savez pas quel format d'image utiliser ? Nous avons créé des comparaisons techniques approfondies pour vous aider à choisir le format parfait." :
                     locale === 'de' ? "Sie sind sich nicht sicher, welches Bildformat Sie verwenden sollen? Wir haben detaillierte technische Vergleiche erstellt, die Ihnen helfen." :
                     locale === 'pt' ? "Não tem certeza de qual formato de imagem usar? Criamos comparações técnicas detalhadas para ajudá-lo a escolher o formato perfeito." :
                     locale === 'id' ? "Tidak yakin format gambar mana yang harus digunakan? Kami telah membuat perbandingan teknis mendalam untuk membantu Anda memilih format yang sempurna." : "Not sure which image format to use? We've created deep-dive technical comparisons to help you choose the perfect format for web design, photography, printing, and more.";

const readText = locale === 'es' ? "Leer comparación" :
                 locale === 'fr' ? "Lire la comparaison" :
                 locale === 'de' ? "Vergleich lesen" :
                 locale === 'pt' ? "Ler comparação" :
                 locale === 'id' ? "Baca perbandingan" : "Read comparison";

const localizedComparisons = comparisonsData.comparisons.map((c) => translateComparison(c, locale));
---

<Layout title={seoTitle} description={seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-8 lg:py-24">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">{pageHeading}</h1>
        <p class="text-lg text-body leading-relaxed">
          {pageSubtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {localizedComparisons.map((comp) => (
          <a href={getLocalizedPath(`/compare/${comp.id}`, locale)} class="group flex flex-col p-8 rounded-2xl bg-canvas border border-hairline hover:border-link transition-all hover:shadow-md">
            <div class="flex items-center gap-4 mb-6">
              <span class="flex items-center justify-center h-12 w-12 rounded-xl bg-canvas-soft font-mono font-bold text-ink border border-hairline">{comp.format1}</span>
              <span class="text-mute italic text-sm">vs</span>
              <span class="flex items-center justify-center h-12 w-12 rounded-xl bg-canvas-soft font-mono font-bold text-ink border border-hairline">{comp.format2}</span>
            </div>
            <h2 class="text-xl font-bold text-ink mb-3 group-hover:text-link transition-colors">{comp.title}</h2>
            <p class="text-sm text-body leading-relaxed flex-grow">{comp.description}</p>
            <div class="mt-6 flex items-center text-sm font-semibold text-link">
              {readText}
              <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
