---
import CrossLinkBlock from "../../components/seo/CrossLinkBlock.astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import comparisonsData from "../../data/comparisons.json";
import toolsData from "../../data/tools.json";
import ImageToPdfTool from "../../components/tools/ImageToPdfTool.astro";

// SEO Metadata
const seoTitle = "HEIC vs PDF: Difference Between Photo and Document Formats";
const seoDescription = "HEIC vs PDF. We compare Apple's High Efficiency Image Format with the Portable Document Format. Learn when to use each for sharing and storage.";

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": seoTitle,
      "description": seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between HEIC and PDF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "HEIC is a modern raster image format designed by Apple specifically for storing highly compressed, high-fidelity digital photographs on iOS and macOS devices. PDF (Portable Document Format) is a universal document container designed by Adobe to display text, layout, and graphics consistently across any operating system or device."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use HEIC instead of PDF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use HEIC to capture and store digital photos on Apple devices, as it yields extremely small file sizes while maintaining rich color metadata (Display P3). Use PDF when you need to send documents, presentations, portfolios, or multi-page scanned forms where text formatting, layout, and font rendering must remain identical for the reader."
          }
        },
        {
          "@type": "Question",
          "name": "Can I convert HEIC to PDF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, you can easily convert HEIC photos to PDF documents. On Apple devices, you can do this natively via the Files app or Print dialog. Online or offline conversion tools allow you to package your photos into a clean PDF page structure for sharing."
          }
        },
        {
          "@type": "Question",
          "name": "Do web browsers support HEIC and PDF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Web browsers do not support HEIC files natively and cannot display them on web pages without conversion. However, all modern web browsers have native PDF renderers built-in, allowing users to view, scroll, and print PDF documents directly in a browser tab."
          }
        },
        {
          "@type": "Question",
          "name": "Why are PDF files larger than HEIC files?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PDF files are document containers that store layout descriptions, embedded fonts, vector graphics, and metadata, making them inherently heavier. HEIC uses advanced HEVC (H.265) video-based compression, allowing it to store high-resolution raster photographs in a fraction of the space."
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "heic-pdf")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "image-to-pdf");
---

<Layout title={seoTitle} description={seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/compare" class="hover:text-ink transition-colors">Compare</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">HEIC vs PDF</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">HEIC</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PDF</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">HEIC vs PDF: Which Format to Use?</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          Comparing an Apple photo file with a portable document container? We break down the differences between HEIC and PDF.
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Quick Answer
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">Use HEIC for:</strong> Digital photography on iOS, live photos, and high-dynamic-range photo storage with maximum compression.</p>
          <p><strong class="text-ink">Use PDF for:</strong> Multi-page documents, official forms, scanned invoices, books, and printable layouts where format integrity is vital.</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">What is the Difference Between HEIC and PDF?</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          The core distinction is that HEIC is an image compression container optimized for photos, while PDF is a layout presentation container designed for documents.
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">Feature / Aspect</th>
                <th class="p-4">HEIC (High Efficiency Image Format)</th>
                <th class="p-4">PDF (Portable Document Format)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">File Nature</td>
                <td class="p-4">Raster image container</td>
                <td class="p-4 text-success">Document layout container</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Multi-page Support</td>
                <td class="p-4 text-error">Limited (Bursts and Live Photos only)</td>
                <td class="p-4 text-success">Yes (Infinite paginated sheets)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Text Selection</td>
                <td class="p-4 text-error">No (Pixels only, needs OCR)</td>
                <td class="p-4 text-success">Yes (Selectable, searchable, editable text)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Universal Viewability</td>
                <td class="p-4 text-error">Poor (Requires modern OS or Apple device)</td>
                <td class="p-4 text-success">Universal (Supported natively by all OS)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">File Size</td>
                <td class="p-4 text-success">Extremely small (HEVC compressed)</td>
                <td class="p-4">Larger (Stores fonts, vectors, assets)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Transparency</td>
                <td class="p-4 text-success">Yes (Alpha channel)</td>
                <td class="p-4 text-success">Yes (Fully supported)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Print Ready</td>
                <td class="p-4 text-error">No</td>
                <td class="p-4 text-success">Yes (Industry standard for printing)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">Merge Exported Images to PDF (Offline & Private)</h2>
        <ImageToPdfTool toolId="image-to-pdf" />
      </section>

      <!-- Deep Dive: HEIC -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is HEIC?</h2>
        <p>
          HEIC stands for High Efficiency Image Coding. It is a variant of the HEIF (High Efficiency Image Format) standard developed by the MPEG group and popularized by Apple in macOS and iOS. HEIC files use advanced video compression (H.265/HEVC) to encode pixel grids.
        </p>
        <p>
          HEIC is highly specialized for photographic assets. It supports deep color metadata, high dynamic range (HDR), and allows multiple image exposures to be saved inside a single lightweight file, making it Apple's camera standard.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">HEIC Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Superior Photo Compression:</strong> Saves half the storage space of JPEGs.</li>
          <li><strong>Display P3 Color:</strong> Richer gradient and color capture for mobile screens.</li>
          <li><strong>Container Features:</strong> Bundles auxiliary files like live photo clips.</li>
        </ul>
      </section>

      <!-- Deep Dive: PDF -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is PDF?</h2>
        <p>
          PDF (Portable Document Format) is an open file format standard maintained by the ISO. Developed by Adobe, its goal was to solve the problem of document cross-compatibility, ensuring a document looked the same whether printed, viewed on Windows, or read on a Unix machine.
        </p>
        <p>
          A PDF stores a complete layout description, including font details, vector shapes, forms, and embedded bitmaps. Unlike image formats, PDFs support pagination, searchable text, hyperlinks, interactive forms, and digital signatures.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">PDF Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Format Preservation:</strong> Ensures layout, fonts, and images never shift on other devices.</li>
          <li><strong>Selectable Text:</strong> Allows copy-pasting text and indexing by search engines.</li>
          <li><strong>Multi-page Capabilities:</strong> Perfect for books, invoices, reports, and manuals.</li>
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">What is the difference between HEIC and PDF?</h3>
            <p class="text-body leading-relaxed">HEIC is a modern raster image format designed by Apple specifically for storing highly compressed, high-fidelity digital photographs on iOS and macOS devices. PDF (Portable Document Format) is a universal document container designed by Adobe to display text, layout, and graphics consistently across any operating system or device.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">When should I use HEIC instead of PDF?</h3>
            <p class="text-body leading-relaxed">Use HEIC to capture and store digital photos on Apple devices, as it yields extremely small file sizes while maintaining rich color metadata (Display P3). Use PDF when you need to send documents, presentations, portfolios, or multi-page scanned forms where text formatting, layout, and font rendering must remain identical for the reader.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Can I convert HEIC to PDF?</h3>
            <p class="text-body leading-relaxed">Yes, you can easily convert HEIC photos to PDF documents. On Apple devices, you can do this natively via the Files app or Print dialog. Online or offline conversion tools allow you to package your photos into a clean PDF page structure for sharing.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Do web browsers support HEIC and PDF?</h3>
            <p class="text-body leading-relaxed">Web browsers do not support HEIC files natively and cannot display them on web pages without conversion. However, all modern web browsers have native PDF renderers built-in, allowing users to view, scroll, and print PDF documents directly in a browser tab.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Why are PDF files larger than HEIC files?</h3>
            <p class="text-body leading-relaxed">PDF files are document containers that store layout descriptions, embedded fonts, vector graphics, and metadata, making them inherently heavier. HEIC uses advanced HEVC (H.265) video-based compression, allowing it to store high-resolution raster photographs in a fraction of the space.</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">Explore More Comparisons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={`/compare/${relatedComp.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">Want to generate PDF documents?</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">Try our client-side Image to PDF tool to merge multiple photos and images into a clean PDF document securely and fast.</p>
          <a href={`/tools/${relatedTool.slug}`} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            Try the {relatedTool.name}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="HEIC" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
