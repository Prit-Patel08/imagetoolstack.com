---
import CrossLinkBlock from "../../components/seo/CrossLinkBlock.astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import comparisonsData from "../../data/comparisons.json";
import toolsData from "../../data/tools.json";
import VectorizerTool from "../../components/tools/VectorizerTool.astro";

// SEO Metadata
const seoTitle = "SVG vs JPG: Difference Between Vector and Raster Image Formats";
const seoDescription = "SVG vs JPG. We compare Scalable Vector Graphics with Joint Photographic Experts Group raster images. Learn when to use each for web design and photos.";

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": seoTitle,
      "description": seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between SVG and JPG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SVG is a vector format that uses mathematical equations to render lines and curves, making it infinitely scalable. JPG is a raster format that stores pixels in a fixed grid, which is ideal for photographic detail but pixelates when enlarged."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use SVG instead of JPG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use SVG for logos, icons, text, and flat-color web illustrations. Use JPG for photographs, scanned images, or complex graphics with gradients and real-world color variations."
          }
        },
        {
          "@type": "Question",
          "name": "Can I convert a JPG to an SVG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, you can convert a JPG to an SVG using a process called vectorization or image tracing. Our free client-side Vectorizer tool allows you to trace JPG images into SVG vector paths directly in your browser."
          }
        },
        {
          "@type": "Question",
          "name": "Which format has smaller file sizes, SVG or JPG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It depends on the image. For simple graphics like logos and icons, SVG is typically much smaller. For complex photographs, JPG is far smaller than a vectorized version because vector paths cannot represent thousands of colors efficiently."
          }
        },
        {
          "@type": "Question",
          "name": "Do web browsers support both SVG and JPG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, all modern web browsers have full, native support for both SVG and JPG formats, allowing them to be loaded directly on websites."
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "svg-vs-jpg")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "image-to-svg");

// Indexing check
import indexablePages from "../../data/indexable-pages.json";
const isIndexable = indexablePages.comparisons.includes("svg-vs-jpg");
const robots = isIndexable ? "index, follow" : "noindex, nofollow";
---

<Layout title={seoTitle} description={seoDescription} robots={robots}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/compare" class="hover:text-ink transition-colors">Compare</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">SVG vs JPG</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">SVG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">JPG</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">SVG vs JPG: Which Format is Better?</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          Comparing a mathematical vector format with a pixel-grid raster image format. Learn when to use SVG and when to use JPG.
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Quick Answer
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">Use SVG for:</strong> Logos, vector icons, user interface graphics, text headings, and digital illustrations requiring infinite scaling and sharp edges.</p>
          <p><strong class="text-ink">Use JPG for:</strong> Photographs, complex digital paintings, realistic scans, and high-color images with soft gradients.</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">What is the Difference Between SVG and JPG?</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          SVG describes image structures mathematically using curves, lines, and shapes. JPG encodes color grids on a coordinate map of pixels.
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">Feature / Aspect</th>
                <th class="p-4">SVG (Scalable Vector Graphics)</th>
                <th class="p-4">JPG (Joint Photographic Experts Group)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">Image Category</td>
                <td class="p-4 text-success">Vector (Mathematical formulas)</td>
                <td class="p-4">Raster (Pixel grid map)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Infinite Scaling</td>
                <td class="p-4 text-success">Yes (Perfect resolution at any scale)</td>
                <td class="p-4 text-error">No (Becomes pixelated when scaled up)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Photographic Suitability</td>
                <td class="p-4 text-error">Very Poor (Produces giant files)</td>
                <td class="p-4 text-success">Excellent (Designed for photography)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Editability</td>
                <td class="p-4 text-success">High (Editable XML paths, styling with CSS/JS)</td>
                <td class="p-4">Low (Flattened pixel grid)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Transparency Support</td>
                <td class="p-4 text-success">Yes (Alpha opacity on paths)</td>
                <td class="p-4 text-error">No (Solid backgrounds only)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Animation</td>
                <td class="p-4 text-success">Yes (Via CSS, SMIL, or JS)</td>
                <td class="p-4 text-error">No</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">Trace JPG to SVG Vector (Offline & Private)</h2>
        <VectorizerTool toolId="jpg-to-svg" />
      </section>

      <!-- Deep Dive: SVG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is an SVG?</h2>
        <p>
          SVG stands for Scalable Vector Graphics. It is an XML-based file format designed by the World Wide Web Consortium (W3C) specifically to describe two-dimensional graphics. Because SVG files store coordinates, paths, stroke widths, and fill colors mathematically, they render perfectly at any resolution.
        </p>
        <p>
          SVG is highly customizable: since it is essentially XML code, web developers can embed SVGs directly in HTML, styling individual elements with CSS rules and animating paths with JavaScript. This makes SVG the gold standard for responsive web icons, logos, and UI elements.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">SVG Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Infinite Resolution:</strong> Graphics stay crisp on ultra-high-definition retina screens.</li>
          <li><strong>DOM Accessibility:</strong> Search engines can read and index text inside SVG paths.</li>
          <li><strong>Interactivity:</strong> Dynamic styling, hovering states, and animations are native.</li>
        </ul>
      </section>

      <!-- Deep Dive: JPG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is a JPG?</h2>
        <p>
          JPG (or JPEG) stands for Joint Photographic Experts Group. Released in 1992, it remains the most common format for digital photography. A JPG is a raster format, meaning it stores images as a flat, two-dimensional grid of pixels. It applies lossy compression to reduce file weights.
        </p>
        <p>
          JPG excels at capturing subtle tone changes, soft lighting, and detailed textures found in natural photography. However, because it discards high-frequency details to compress, editing or resaving a JPG multiple times can introduce compression noise and artifact blocks.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">JPG Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Optimized for Real-World Photos:</strong> Supports smooth gradients and millions of colors.</li>
          <li><strong>Small Photographic File Weights:</strong> Lossy compression allows fast page loads for photos.</li>
          <li><strong>Universal Compatibility:</strong> Supported by every image viewer, browser, and email client.</li>
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">What is the difference between SVG and JPG?</h3>
            <p class="text-body leading-relaxed">SVG is a vector format that uses mathematical equations to render lines and curves, making it infinitely scalable. JPG is a raster format that stores pixels in a fixed grid, which is ideal for photographic detail but pixelates when enlarged.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">When should I use SVG instead of JPG?</h3>
            <p class="text-body leading-relaxed">Use SVG for logos, icons, text, and flat-color web illustrations. Use JPG for photographs, scanned images, or complex graphics with gradients and real-world color variations.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Can I convert a JPG to an SVG?</h3>
            <p class="text-body leading-relaxed">Yes, you can convert a JPG to an SVG using a process called vectorization or image tracing. Our free client-side Vectorizer tool allows you to trace JPG images into SVG vector paths directly in your browser.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Which format has smaller file sizes, SVG or JPG?</h3>
            <p class="text-body leading-relaxed">It depends on the image. For simple graphics like logos and icons, SVG is typically much smaller. For complex photographs, JPG is far smaller than a vectorized version because vector paths cannot represent thousands of colors efficiently.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Do web browsers support both SVG and JPG?</h3>
            <p class="text-body leading-relaxed">Yes, all modern web browsers have full, native support for both SVG and JPG formats, allowing them to be loaded directly on websites.</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">Explore More Comparisons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={`/compare/${relatedComp.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">Need to vectorize PNG or JPG images?</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">Try our client-side Vectorizer to trace your raster images into clean SVG vectors 100% offline.</p>
          <a href={`/tools/${relatedTool.slug}`} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            Try the {relatedTool.name}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="SVG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
