---
import CrossLinkBlock from "../../components/seo/CrossLinkBlock.astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import comparisonsData from "../../data/comparisons.json";
import toolsData from "../../data/tools.json";
import HeicToJpgTool from "../../components/tools/HeicToJpgTool.astro";

// SEO Metadata
const seoTitle = "PNG vs HEIC: Difference Between Web and High-Efficiency Image Formats";
const seoDescription = "PNG vs HEIC. We compare Portable Network Graphics with High Efficiency Image Containers. Learn when to use each for web, iPhone photos, and editing.";

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": seoTitle,
      "description": seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between PNG and HEIC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PNG is a lossless raster format designed for web compatibility and graphics. HEIC is a high-efficiency format developed by Apple, designed to store phone photos at very small file sizes using advanced HEVC compression."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use PNG instead of HEIC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use PNG when you need to upload graphics to a website, share screenshots, or require transparent overlays. Use HEIC when saving photos on your iPhone to preserve storage space."
          }
        },
        {
          "@type": "Question",
          "name": "Can web browsers display HEIC files?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, web browsers do not support HEIC natively. To display HEIC images on a website, you must convert them to web-compatible formats like PNG, JPG, or WebP."
          }
        },
        {
          "@type": "Question",
          "name": "Which is higher quality, PNG or HEIC?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PNG is lossless, so it keeps 100% of the pixel detail with no degradation. HEIC is lossy (though it can be lossless) but uses advanced modern compression that makes compression artifacts virtually invisible, offering excellent quality at tiny file weights."
          }
        },
        {
          "@type": "Question",
          "name": "How do I convert a HEIC file to PNG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can convert HEIC to PNG using our free offline converter tool, or built-in utilities on Mac/Windows. Once converted to PNG, you can easily share it or use it on the web."
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "png-heic")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "heic-to-jpg");
---

<Layout title={seoTitle} description={seoDescription}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/compare" class="hover:text-ink transition-colors">Compare</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">PNG vs HEIC</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PNG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">HEIC</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">PNG vs HEIC: Which Format is Better?</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          Comparing a lossless web graphics format with Apple's high-efficiency photo container. Discover the differences between PNG and HEIC.
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Quick Answer
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">Use PNG for:</strong> Web pages, online layouts, screenshots, and logos that need universal browser compatibility and support for alpha transparency.</p>
          <p><strong class="text-ink">Use HEIC for:</strong> Photos taken on iPhones or iPads to save storage space while maintaining modern color profiles, Live Photos, and HDR detail.</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">What is the Difference Between PNG and HEIC?</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          PNG is designed for browser-friendly graphics and lossless clarity, while HEIC is built for mobile phone camera sensors to minimize file size.
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">Feature / Aspect</th>
                <th class="p-4">PNG (Portable Network Graphics)</th>
                <th class="p-4">HEIC (High Efficiency Image Container)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">Compression</td>
                <td class="p-4">Lossless (DEFLATE)</td>
                <td class="p-4 text-success">Lossy or Lossless (HEVC / H.265)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">File Size</td>
                <td class="p-4 text-error">Large (High bandwidth requirements)</td>
                <td class="p-4 text-success">Very Small (50% smaller than equivalent JPEGs)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Web Support</td>
                <td class="p-4 text-success">Universal (All web browsers)</td>
                <td class="p-4 text-error">Poor (Not supported natively in Chrome, Edge, Firefox)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Transparency Support</td>
                <td class="p-4 text-success">Excellent (Alpha channel)</td>
                <td class="p-4 text-success">Excellent (Supports transparency and depth maps)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Color Depth</td>
                <td class="p-4">8-bit or 16-bit per channel</td>
                <td class="p-4 text-success">Up to 16-bit (Supports HDR color rendering)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Animation</td>
                <td class="p-4">No (APNG is a separate extension)</td>
                <td class="p-4 text-success">Yes (Can store image sequences, Live Photos)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">Convert HEIC Files Offline (Private & Secure)</h2>
        <HeicToJpgTool toolId="heic-to-jpg" />
      </section>

      <!-- Deep Dive: PNG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is a PNG?</h2>
        <p>
          PNG stands for Portable Network Graphics. Developed in 1996 to replace the aging and patent-restricted GIF format, PNG is a lossless format that relies on the DEFLATE algorithm. Because it is lossless, it maintains a perfect pixel representation of an image, making it ideal for diagrams, screenshots, text-heavy graphics, and logos.
        </p>
        <p>
          Its strongest point is alpha channel transparency, allowing web layouts to place images with complex edges or semi-transparent drop shadows over any color background. However, because it keeps every pixel intact, saving high-resolution photograph assets in PNG leads to large files that slow down web performance.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">PNG Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Universal Compatibility:</strong> Loads and renders perfectly across all web platforms.</li>
          <li><strong>Crisp Raster Details:</strong> Zero blur or compression noise on text edges or logos.</li>
          <li><strong>Alpha Channel:</strong> Clean transparency blending for modern web design.</li>
        </ul>
      </section>

      <!-- Deep Dive: HEIC -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is a HEIC?</h2>
        <p>
          HEIC is the file extension used by Apple for the High Efficiency Image File Format (HEIF). Introduced in iOS 11, it utilizes the HEVC (High Efficiency Video Coding, or H.265) compression standard. By applying advanced video compression technologies to still images, HEIC reduces file sizes to roughly half that of a JPEG while keeping the same visual quality.
        </p>
        <p>
          HEIC files are extremely powerful. In addition to basic image pixels, a single HEIC file can contain transparency masks, depth information (used for portrait mode effects), HDR metadata, and sequences of images (which Apple uses to power Live Photos). The downside is compatibility: because of licensing and patent issues, web browsers do not support HEIC natively.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">HEIC Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Space Optimization:</strong> Save massive amounts of storage space on your device.</li>
          <li><strong>Multi-Asset Containers:</strong> Hold Live Photos, depth data, and image bursts in one file.</li>
          <li><strong>Advanced Colors:</strong> Supports 10-bit and 12-bit color gamuts for HDR captures.</li>
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">What is the difference between PNG and HEIC?</h3>
            <p class="text-body leading-relaxed">PNG is a lossless raster format designed for web compatibility and graphics. HEIC is a high-efficiency format developed by Apple, designed to store phone photos at very small file sizes using advanced HEVC compression.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">When should I use PNG instead of HEIC?</h3>
            <p class="text-body leading-relaxed">Use PNG when you need to upload graphics to a website, share screenshots, or require transparent overlays. Use HEIC when saving photos on your iPhone to preserve storage space.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Can web browsers display HEIC files?</h3>
            <p class="text-body leading-relaxed">No, web browsers do not support HEIC natively. To display HEIC images on a website, you must convert them to web-compatible formats like PNG, JPG, or WebP.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Which is higher quality, PNG or HEIC?</h3>
            <p class="text-body leading-relaxed">PNG is lossless, so it keeps 100% of the pixel detail with no degradation. HEIC is lossy (though it can be lossless) but uses advanced modern compression that makes compression artifacts virtually invisible, offering excellent quality at tiny file weights.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">How do I convert a HEIC file to PNG?</h3>
            <p class="text-body leading-relaxed">You can convert HEIC to PNG using our free offline converter tool, or built-in utilities on Mac/Windows. Once converted to PNG, you can easily share it or use it on the web.</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">Explore More Comparisons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={`/compare/${relatedComp.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">Need to convert HEIC photos on your PC?</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">Try our client-side HEIC Converter to convert your iPhone photos to web-friendly formats completely offline.</p>
          <a href={`/tools/${relatedTool.slug}`} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            Try the {relatedTool.name}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="PNG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
