---
import CrossLinkBlock from "../../components/seo/CrossLinkBlock.astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import comparisonsData from "../../data/comparisons.json";
import toolsData from "../../data/tools.json";
import FormatConverter from "../../components/tools/FormatConverter.astro";

// SEO Metadata
const seoTitle = "PNG vs PSD: Difference Between Image and Photoshop Formats";
const seoDescription = "PNG vs PSD. We compare Portable Network Graphics with Adobe Photoshop Documents. Learn when to use each for web design and editing.";

// Schema for FAQPage and Article
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": seoTitle,
      "description": seoDescription,
      "author": {
        "@type": "Organization",
        "name": "Image Tool Stack"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between PNG and PSD?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PNG is a flattened, compressed raster image format designed for web publishing and universal compatibility. PSD (Photoshop Document) is a raw working file format developed by Adobe that preserves editable layers, vector paths, text, and design history."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use PSD instead of PNG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use PSD when you are in the process of creating or editing a graphic, as it preserves separate layers, adjustments, and editable text. Use PNG when you are finished editing and need to export the final flat image for a website, presentation, or social media."
          }
        },
        {
          "@type": "Question",
          "name": "Can a PNG have layers like a PSD?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, PNG is a flattened format. While it supports background transparency, it does not support multiple independent layers. Saving an image as a PNG merges all layers into a single pixel layer, making further layer-based edits impossible."
          }
        },
        {
          "@type": "Question",
          "name": "How do I convert a PSD to PNG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can export a PSD to PNG using Adobe Photoshop (File > Export > Quick Export as PNG) or open-source editors like GIMP. Once exported, you can use our free browser-based image compressor to shrink the PNG file size for faster web loading."
          }
        },
        {
          "@type": "Question",
          "name": "Why are PSD files so much larger than PNG files?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "PSD files are significantly larger because they store complex meta-information, including individual layer graphics, masks, color profiles, smart objects, and edit history. PNG files discard this extra editing data and compress the pixels into a single optimized layer."
          }
        }
      ]
    }
  ]
};

// Get 4 stable related comparisons for the bottom
const relatedComparisons = comparisonsData.comparisons
  .filter(comp => comp.id !== "png-psd")
  .sort((a, b) => a.title.localeCompare(b.title))
  .slice(0, 4);

const relatedTool = toolsData.tools.find(t => t.slug === "image-compressor");

// Indexing check
import indexablePages from "../../data/indexable-pages.json";
const isIndexable = indexablePages.comparisons.includes("png-psd");
const robots = isIndexable ? "index, follow" : "noindex, nofollow";
---

<Layout title={seoTitle} description={seoDescription} robots={robots}>
  <Navbar />
  
  <main class="w-full">
    <!-- Breadcrumbs -->
    <div class="border-b border-hairline bg-canvas">
      <nav class="mx-auto max-w-[1400px] px-6 py-3 lg:px-8 flex items-center gap-2 text-xs font-medium text-mute">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/compare" class="hover:text-ink transition-colors">Compare</a>
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-ink">PNG vs PSD</span>
      </nav>
    </div>

    <div class="mx-auto max-w-[1000px] px-6 py-12 lg:px-8 lg:py-16">
      
      <!-- Header -->
      <header class="text-center mb-16">
        <div class="flex items-center justify-center gap-6 mb-8">
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PNG</span>
          <span class="text-mute italic text-xl">vs</span>
          <span class="flex items-center justify-center h-20 w-20 rounded-2xl bg-canvas-soft font-mono text-2xl font-bold text-ink border border-hairline shadow-sm">PSD</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl mb-6">PNG vs PSD: Which Format to Use?</h1>
        <p class="text-lg text-body leading-relaxed max-w-3xl mx-auto">
          Wondering about the difference between a raw Photoshop file and a finished web graphic? We break down the differences between PNG and PSD.
        </p>
      </header>

      <!-- Quick Answer -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border-2 border-link">
        <h2 class="text-2xl font-bold text-ink mb-6 flex items-center gap-2">
          <svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Quick Answer
        </h2>
        <div class="space-y-4 text-body text-lg">
          <p><strong class="text-ink">Use PSD for:</strong> Working project drafts, layered templates, and graphic design tasks where you need to preserve editable text, paths, layers, and masks.</p>
          <p><strong class="text-ink">Use PNG for:</strong> Web assets, social media graphics, email attachments, and finalized designs where you need a lightweight image with high-quality transparency.</p>
        </div>
      </section>

      <!-- Technical Comparison Matrix -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-6">What is the Difference Between PNG and PSD?</h2>
        <p class="text-lg text-body leading-relaxed mb-6">
          The core distinction is that PSD is a working file format containing rich layer structures, while PNG is a finalized flat distribution file format.
        </p>
        <div class="overflow-x-auto rounded-xl border border-hairline shadow-sm">
          <table class="w-full border-collapse text-left text-sm text-body">
            <thead>
              <tr class="bg-canvas-soft border-b border-hairline text-ink font-semibold">
                <th class="p-4">Feature / Aspect</th>
                <th class="p-4">PNG (Portable Network Graphics)</th>
                <th class="p-4">PSD (Photoshop Document)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline bg-canvas">
              <tr>
                <td class="p-4 font-semibold text-ink">File Type</td>
                <td class="p-4">Compressed raster graphic</td>
                <td class="p-4 text-success">Layered design project file</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Layer Support</td>
                <td class="p-4 text-error">No (Flattened into single layer)</td>
                <td class="p-4 text-success">Yes (Infinite layers & folders)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Editability</td>
                <td class="p-4 text-error">No (Cannot edit text or vectors)</td>
                <td class="p-4 text-success">Yes (Fully editable text, filters, masks)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Web Support</td>
                <td class="p-4 text-success">Universal (Supported by all web browsers)</td>
                <td class="p-4 text-error">No (Requires conversion)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">File Size</td>
                <td class="p-4 text-success">Small and optimized</td>
                <td class="p-4 text-error">Large (Often hundreds of megabytes)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Transparency</td>
                <td class="p-4 text-success">Yes (8-bit alpha channel)</td>
                <td class="p-4 text-success">Yes (Full layers & blends)</td>
              </tr>
              <tr>
                <td class="p-4 font-semibold text-ink">Lossless Quality</td>
                <td class="p-4 text-success">Yes</td>
                <td class="p-4 text-success">Yes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Active Converter Widget -->
      <section class="mb-16 p-8 rounded-2xl bg-canvas-soft border border-hairline shadow-sm">
        <h2 class="text-2xl font-bold text-ink mb-6 text-center">Compress PNG Exports (Offline & Private)</h2>
        <FormatConverter toolId="image-compressor" />
      </section>

      <!-- Deep Dive: PNG -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is a PNG?</h2>
        <p>
          PNG (Portable Network Graphics) is a compressed raster image format developed as a modern replacement for GIF. It is designed specifically for web and screen use, supporting losslessly compressed 24-bit color alongside high-quality alpha transparency.
        </p>
        <p>
          Since a PNG is a flattened file, it does not store any editable design history or individual layers. It is best used for final deployment on websites or applications because it loads quickly and maintains crisp edges on text and logos.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">PNG Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Universal Compatibility:</strong> Displays correctly in every browser and email client.</li>
          <li><strong>Web-Optimized Weight:</strong> Light file size relative to design source files.</li>
          <li><strong>Clean Transparency:</strong> Ideal for transparent logo and UI overlays.</li>
        </ul>
      </section>

      <!-- Deep Dive: PSD -->
      <section class="mb-16 prose prose-vercel max-w-none text-body">
        <h2 class="text-3xl font-bold text-ink">Deep Dive: What is a PSD?</h2>
        <p>
          PSD stands for Photoshop Document. It is the proprietary raw project file format used by Adobe Photoshop. A PSD file functions as a complete project workspace, storing layers, text fields, vector shapes, smart objects, masks, adjustment layers, and even design history.
        </p>
        <p>
          Unlike PNG, a PSD file is not meant to be shared directly online or embedded in web pages, as browsers cannot render them. Designers work inside a PSD and export the final results to web-friendly formats like PNG, JPEG, or WebP when finished.
        </p>
        
        <h3 class="text-xl font-bold text-ink mt-6 text-success">PSD Advantages</h3>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>Editable Layers:</strong> Go back and edit text, shapes, or filters at any time.</li>
          <li><strong>Non-Destructive Workflow:</strong> Apply adjustment masks and layer effects without altering the original pixels.</li>
          <li><strong>Smart Objects:</strong> Place high-resolution vector assets that scale without degradation.</li>
        </ul>
      </section>

      <!-- FAQs -->
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-ink mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">What is the difference between PNG and PSD?</h3>
            <p class="text-body leading-relaxed">PNG is a flattened, compressed raster image format designed for web publishing and universal compatibility. PSD (Photoshop Document) is a raw working file format developed by Adobe that preserves editable layers, vector paths, text, and design history.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">When should I use PSD instead of PNG?</h3>
            <p class="text-body leading-relaxed">Use PSD when you are in the process of creating or editing a graphic, as it preserves separate layers, adjustments, and editable text. Use PNG when you are finished editing and need to export the final flat image for a website, presentation, or social media.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Can a PNG have layers like a PSD?</h3>
            <p class="text-body leading-relaxed">No, PNG is a flattened format. While it supports background transparency, it does not support multiple independent layers. Saving an image as a PNG merges all layers into a single pixel layer, making further layer-based edits impossible.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">How do I convert a PSD to PNG?</h3>
            <p class="text-body leading-relaxed">You can export a PSD to PNG using Adobe Photoshop (File > Export > Quick Export as PNG) or open-source editors like GIMP. Once exported, you can use our free browser-based image compressor to shrink the PNG file size for faster web loading.</p>
          </div>
          <div class="bg-canvas-soft rounded-xl p-6">
            <h3 class="text-xl font-bold text-ink mb-3">Why are PSD files so much larger than PNG files?</h3>
            <p class="text-body leading-relaxed">PSD files are significantly larger because they store complex meta-information, including individual layer graphics, masks, color profiles, smart objects, and edit history. PNG files discard this extra editing data and compress the pixels into a single optimized layer.</p>
          </div>
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-ink mb-6">Explore More Comparisons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {relatedComparisons.map((relatedComp) => (
              <a href={`/compare/${relatedComp.id}`} class="p-6 rounded-xl bg-canvas border border-hairline hover:border-link group transition-colors flex items-center justify-between">
                <div>
                  <h3 class="font-bold text-ink group-hover:text-link transition-colors">{relatedComp.title}</h3>
                  <p class="text-sm text-body mt-1 line-clamp-1">{relatedComp.description}</p>
                </div>
                <svg class="h-5 w-5 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      {relatedTool && (
        <section class="p-8 rounded-2xl bg-ink text-on-primary text-center">
          <h2 class="text-2xl font-bold mb-4">Need to optimize your exported PNG files?</h2>
          <p class="text-mute mb-8 max-w-xl mx-auto">Try our client-side Image Compressor to optimize and compress your PNG files for web speed without losing quality.</p>
          <a href={`/tools/${relatedTool.slug}`} class="inline-flex items-center justify-center rounded-lg bg-link px-8 py-4 text-sm font-semibold text-white hover:bg-link-hover transition-colors">
            Try the {relatedTool.name}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7"/></svg>
          </a>
        </section>
      )}

      <!-- High-Density Internal Cross-Linking Block -->
      <CrossLinkBlock currentFormat="PNG" />

    </div>
  </main>

  <Footer />
  
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Layout>
